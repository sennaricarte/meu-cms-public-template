# ─── Painel Admin (/admin) ────────────────────────────────────────────────────
# Utilizador e senha para login. Renomeie este ficheiro para `.env` e use valores fortes.
ADMIN_USER=admin
# Preferido na Vercel / CI:
ADMIN_PASSWORD=troque-por-uma-senha-forte
# Alternativa legada (mesmo efeito que ADMIN_PASSWORD):
# ADMIN_PASS=troque-por-uma-senha-forte

# Opcional: melhora o segredo do token do cookie `admin_session` (recomendado em produção).
# Se omitido, usa-se a senha do admin como segredo do HMAC.
# SESSION_SECRET=gere-uma-string-longa-aleatoria
