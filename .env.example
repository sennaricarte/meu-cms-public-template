# ─── API central (Lovable) — autenticação do painel /admin ────────────────────
# Obrigatórias para o login admin (incluindo após OAuth na conta do cliente).
# Se estiverem vazias, /admin/login mostra instruções; páginas públicas e SEO usam
# apenas src/data/config.json (commit inicial com valores base).
# URL base da API que valida login, sessão e primeiro acesso (sem barra no fim).
CENTRAL_ADMIN_API_BASE=https://sua-api.lovable.app

# Identificador do site no painel central (o template envia isto em cada pedido).
SITE_ID=

# Opcional: visível no HTML de login (pode ser o mesmo que SITE_ID).
# PUBLIC_SITE_ID=

# Caminhos dos endpoints (predefinições se omitir):
# CENTRAL_ADMIN_PATH_LOGIN=/v1/admin/login
# CENTRAL_ADMIN_PATH_SESSION=/v1/admin/session
# CENTRAL_ADMIN_PATH_SETUP=/v1/admin/complete-setup
