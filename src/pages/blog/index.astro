---
// Gerada em build time — lista de posts da Content Collection.
export const prerender = true;

import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { readCategories, readTags } from '../../lib/taxonomy-data';

const categories = await readCategories();
const tags = await readTags();
const slugByCategoryName = new Map(categories.map((c) => [c.name.trim(), c.slug]));
const slugByTagName = new Map(tags.map((t) => [t.name.trim(), t.slug]));

const posts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

/** URL do arquivo da categoria ou null se o nome não existir em `categories.json`. */
function categoryArchiveUrl(categoryName: string | undefined): string | null {
	const n = categoryName?.trim();
	if (!n) return null;
	const slug = slugByCategoryName.get(n);
	return slug ? `/blog/categoria/${slug}/` : null;
}

const categoryCounts = new Map<string, number>();
const tagCounts = new Map<string, number>();
for (const p of posts) {
	const postTags = p.data.tags ?? [];
	for (const tagName of postTags) {
		const t = tagName.trim();
		if (!t) continue;
		const tSlug = slugByTagName.get(t);
		if (!tSlug) continue;
		tagCounts.set(tSlug, (tagCounts.get(tSlug) ?? 0) + 1);
	}

	const n = p.data.category?.trim();
	if (!n) continue;
	const slug = slugByCategoryName.get(n);
	if (!slug) continue;
	categoryCounts.set(slug, (categoryCounts.get(slug) ?? 0) + 1);
}
---

<!doctype html>
<html lang="pt-br">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			.post-category {
				margin: 0.35rem 0 0;
				line-height: 1.3;
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			{
				categories.length > 0 && (
					<nav
						class="blog-index-categories mb-8 rounded-xl border border-neutral-200 bg-neutral-50/90 px-4 py-4 sm:px-5"
						aria-labelledby="blog-index-cat-heading"
					>
						<h2
							id="blog-index-cat-heading"
							class="mb-3 text-xs font-semibold uppercase tracking-wide text-neutral-600"
						>
							Categorias
						</h2>
						<ul class="m-0 flex list-none flex-wrap gap-2 p-0">
							{categories.map((c) => {
								const count = categoryCounts.get(c.slug) ?? 0;
								const countLabel =
									count === 1 ? '1 artigo publicado' : `${count} artigos publicados`;
								return (
									<li>
										<a
											href={`/blog/categoria/${c.slug}/`}
											class="inline-flex items-center gap-1.5 rounded-full border border-neutral-200 bg-white px-3 py-1.5 text-sm font-medium text-neutral-800 shadow-sm transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)] focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-neutral-400"
											aria-label={`${c.name}: ${countLabel}`}
										>
											<span>{c.name}</span>
											<span class="text-xs font-normal tabular-nums text-neutral-500" aria-hidden="true">
												({count})
											</span>
										</a>
									</li>
								);
							})}
						</ul>
					</nav>
				)
			}
			{
				tags.length > 0 && (
					<nav
						class="blog-index-tags mb-8 rounded-xl border border-neutral-200 bg-neutral-50/90 px-4 py-4 sm:px-5"
						aria-labelledby="blog-index-tags-heading"
					>
						<h2
							id="blog-index-tags-heading"
							class="mb-3 text-xs font-semibold uppercase tracking-wide text-neutral-600"
						>
							Tags
						</h2>
						<ul class="m-0 flex list-none flex-wrap gap-2 p-0">
							{tags.map((t) => {
								const count = tagCounts.get(t.slug) ?? 0;
								const countLabel = count === 1 ? '1 artigo publicado' : `${count} artigos publicados`;
								return (
									<li>
										<a
											href={`/blog/tags/${t.slug}/`}
											class="inline-flex items-center gap-1.5 rounded-full border border-neutral-200 bg-white px-3 py-1.5 text-sm font-medium text-neutral-800 shadow-sm transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)] focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-neutral-400"
											aria-label={`${t.name}: ${countLabel}`}
										>
											<span>#{t.name}</span>
											<span class="text-xs font-normal tabular-nums text-neutral-500" aria-hidden="true">
												({count})
											</span>
										</a>
									</li>
								);
							})}
						</ul>
					</nav>
				)
			}

			<section aria-labelledby="blog-posts-heading">
				<h2 id="blog-posts-heading" class="sr-only">Artigos do blog</h2>
				<ul>
					{
						posts.map((post) => {
							const catLabel = post.data.category?.trim();
							const catHref = categoryArchiveUrl(post.data.category);
							return (
								<li>
									<a href={`/blog/${post.id}/`}>
										{post.data.heroImage && (
											<Image
												width={720}
												height={360}
												src={post.data.heroImage}
												alt={post.data.title}
												format="webp"
												quality="mid"
											/>
										)}
										<h4 class="title">{post.data.title}</h4>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</a>
									{catLabel &&
										(catHref ? (
											<p class="post-category">
												<span class="text-xs uppercase tracking-wide text-neutral-500">Categoria · </span>
												<a
													href={catHref}
													class="text-sm font-medium text-neutral-700 underline-offset-2 hover:text-[var(--accent)] hover:underline"
												>
													{catLabel}
												</a>
											</p>
										) : (
											<p class="post-category text-sm text-neutral-500">
												<span class="text-xs uppercase tracking-wide">Categoria · </span>
												{catLabel}
											</p>
										))}
								</li>
							);
						})
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
