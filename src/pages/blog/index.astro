---
// Usa SSR para suportar paginação por querystring (?page=2).
export const prerender = false;

import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import siteConfigJson from '../../data/config.json';
import { normalizeSiteConfig } from '../../lib/site-config';
import { readCategories, readTags } from '../../lib/taxonomy-data';

const PAGE_SIZE = 15;

const categories = await readCategories();
const tags = await readTags();
const slugByCategoryName = new Map(categories.map((c) => [c.name.trim(), c.slug]));
const slugByTagName = new Map(tags.map((t) => [t.name.trim(), t.slug]));

const allPosts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const site = normalizeSiteConfig(siteConfigJson);

const totalPages = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE));
const pageParamRaw = Astro.url.searchParams.get('page') ?? '1';
const parsedPage = Number.parseInt(pageParamRaw, 10);
const currentPage =
	Number.isFinite(parsedPage) && parsedPage > 0
		? Math.min(parsedPage, totalPages)
		: 1;
const pageStart = (currentPage - 1) * PAGE_SIZE;
const pagePosts = allPosts.slice(pageStart, pageStart + PAGE_SIZE);

const categoryCounts = new Map<string, number>();
const tagCounts = new Map<string, number>();
for (const post of allPosts) {
	const categoryName = post.data.category?.trim();
	if (categoryName) {
		const categorySlug = slugByCategoryName.get(categoryName);
		if (categorySlug) {
			categoryCounts.set(categorySlug, (categoryCounts.get(categorySlug) ?? 0) + 1);
		}
	}

	for (const rawTag of post.data.tags ?? []) {
		const tagName = rawTag.trim();
		if (!tagName) continue;
		const tagSlug = slugByTagName.get(tagName);
		if (!tagSlug) continue;
		tagCounts.set(tagSlug, (tagCounts.get(tagSlug) ?? 0) + 1);
	}
}

function buildPageHref(page: number): string {
	return page <= 1 ? '/blog' : `/blog?page=${page}`;
}

const pagesToShow = Array.from({ length: totalPages }, (_, i) => i + 1);
---

<!doctype html>
<html lang="pt-br">
	<head>
		<BaseHead title={site.siteName} description={site.siteDescription} />
	</head>
	<body class="bg-white text-gray-900 antialiased">
		<Header />
		<main id="main-content" class="mx-auto max-w-7xl space-y-8 px-6 py-10">
			<header class="space-y-2">
				<p class="text-xs font-bold uppercase tracking-[0.15em] text-gray-400">Blog</p>
				<h1 class="text-3xl font-extrabold tracking-tight text-gray-900 sm:text-4xl">
					Todos os artigos
				</h1>
				<p class="text-sm text-gray-500">
					Página {currentPage} de {totalPages} · {allPosts.length} artigos publicados
				</p>
			</header>

			{
				categories.length > 0 && (
					<nav
						class="rounded-xl border border-neutral-200 bg-neutral-50/90 px-4 py-4 sm:px-5"
						aria-labelledby="blog-index-cat-heading"
					>
						<h2
							id="blog-index-cat-heading"
							class="mb-3 text-xs font-semibold uppercase tracking-wide text-neutral-600"
						>
							Categorias
						</h2>
						<ul class="m-0 flex list-none flex-wrap gap-2 p-0" role="list">
							{categories.map((c) => {
								const count = categoryCounts.get(c.slug) ?? 0;
								const countLabel =
									count === 1 ? '1 artigo publicado' : `${count} artigos publicados`;
								return (
									<li>
										<a
											href={`/blog/categoria/${c.slug}/`}
											class="inline-flex items-center gap-1.5 rounded-full border border-neutral-200 bg-white px-3 py-1.5 text-sm font-medium text-neutral-800 shadow-sm transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)] focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-neutral-400"
											aria-label={`${c.name}: ${countLabel}`}
										>
											<span>{c.name}</span>
											<span class="text-xs font-normal tabular-nums text-neutral-500" aria-hidden="true">
												({count})
											</span>
										</a>
									</li>
								);
							})}
						</ul>
					</nav>
				)
			}
			{
				tags.length > 0 && (
					<nav
						class="rounded-xl border border-neutral-200 bg-neutral-50/90 px-4 py-4 sm:px-5"
						aria-labelledby="blog-index-tags-heading"
					>
						<h2
							id="blog-index-tags-heading"
							class="mb-3 text-xs font-semibold uppercase tracking-wide text-neutral-600"
						>
							Tags
						</h2>
						<ul class="m-0 flex list-none flex-wrap gap-2 p-0" role="list">
							{tags.map((t) => {
								const count = tagCounts.get(t.slug) ?? 0;
								const countLabel = count === 1 ? '1 artigo publicado' : `${count} artigos publicados`;
								return (
									<li>
										<a
											href={`/blog/tags/${t.slug}/`}
											class="inline-flex items-center gap-1.5 rounded-full border border-neutral-200 bg-white px-3 py-1.5 text-sm font-medium text-neutral-800 shadow-sm transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)] focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-neutral-400"
											aria-label={`${t.name}: ${countLabel}`}
										>
											<span>#{t.name}</span>
											<span class="text-xs font-normal tabular-nums text-neutral-500" aria-hidden="true">
												({count})
											</span>
										</a>
									</li>
								);
							})}
						</ul>
					</nav>
				)
			}

			<section aria-labelledby="blog-posts-heading">
				<h2
					id="blog-posts-heading"
					class="mb-6 text-xs font-bold uppercase tracking-[0.15em] text-gray-400"
				>
					Artigos
				</h2>
				<ul
					class="grid grid-cols-1 gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3"
					role="list"
					aria-label="Lista de artigos do blog"
				>
					{pagePosts.map((post) => (
						<li class="flex">
							<PostCard post={post} />
						</li>
					))}
				</ul>
			</section>

			{
				totalPages > 1 && (
					<nav
						class="flex flex-wrap items-center justify-center gap-2 border-t border-gray-100 pt-8"
						aria-label="Paginação de artigos"
					>
						<a
							href={buildPageHref(Math.max(1, currentPage - 1))}
							aria-disabled={currentPage <= 1}
							class:list={[
								'rounded-lg border px-3 py-2 text-sm font-medium transition-colors',
								currentPage <= 1
									? 'pointer-events-none border-gray-100 text-gray-300'
									: 'border-gray-200 text-gray-700 hover:border-[var(--accent)] hover:text-[var(--accent)]',
							]}
						>
							Anterior
						</a>

						{pagesToShow.map((page) => (
							<a
								href={buildPageHref(page)}
								aria-current={page === currentPage ? 'page' : undefined}
								class:list={[
									'rounded-lg border px-3 py-2 text-sm font-semibold transition-colors',
									page === currentPage
										? 'border-[var(--accent)] bg-blue-50 text-[var(--accent)]'
										: 'border-gray-200 text-gray-700 hover:border-[var(--accent)] hover:text-[var(--accent)]',
								]}
							>
								{page}
							</a>
						))}

						<a
							href={buildPageHref(Math.min(totalPages, currentPage + 1))}
							aria-disabled={currentPage >= totalPages}
							class:list={[
								'rounded-lg border px-3 py-2 text-sm font-medium transition-colors',
								currentPage >= totalPages
									? 'pointer-events-none border-gray-100 text-gray-300'
									: 'border-gray-200 text-gray-700 hover:border-[var(--accent)] hover:text-[var(--accent)]',
							]}
						>
							Próxima
						</a>
					</nav>
				)
			}
		</main>
		<Footer />
	</body>
</html>
