---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { readMediaMetadataMap } from '../../lib/media-metadata';
import { uiStatusMessages } from '../../lib/ui-status-messages';
import { readdir, stat } from 'node:fs/promises';
import { join } from 'node:path';

export const prerender = false;

type MediaItem = {
	name: string;
	url: string;
	size: number;
	updatedAt: string;
	alt?: string;
	title?: string;
	caption?: string;
	description?: string;
};

const uploadsDir = join(process.cwd(), 'public', 'uploads');
/** jpg, jpeg, png, webp, gif, svg */
const IMAGE_EXT = /\.(jpe?g|png|webp|gif|svg)$/i;

let initialImages: MediaItem[] = [];
try {
	const meta = await readMediaMetadataMap();
	const names = await readdir(uploadsDir);
	const rows = await Promise.all(
		names
			.filter((name) => IMAGE_EXT.test(name) && !name.startsWith('.'))
			.map(async (name) => {
				const abs = join(uploadsDir, name);
				const info = await stat(abs);
				return {
					name,
					url: `/uploads/${encodeURIComponent(name)}`,
					size: info.size,
					updatedAt: info.mtime.toISOString(),
					...(meta[name] ?? {}),
				} satisfies MediaItem;
			}),
	);
	initialImages = rows.sort((a, b) => +new Date(b.updatedAt) - +new Date(a.updatedAt));
} catch {
	initialImages = [];
}

const forParam = Astro.url.searchParams.get('for');
const mediaPickerMode =
	Astro.url.searchParams.get('picker') === '1' &&
	(forParam === 'logo' || forParam === 'favicon');
const mediaPickerFor = mediaPickerMode ? forParam : '';
const sectionTitle = mediaPickerMode ? undefined : 'Mídia';
const sectionActionLabel = mediaPickerMode ? undefined : 'Adicionar Novo';
const sectionActionHref = mediaPickerMode ? undefined : '#media-upload-heading';
---

<DashboardLayout
	title="Central de Mídia — Admin"
	heading="Central de mídia"
	sectionTitle={sectionTitle}
	sectionActionLabel={sectionActionLabel}
	sectionActionHref={sectionActionHref}
	minimalShell={mediaPickerMode}
>
	<div class="space-y-6">
		{
			mediaPickerMode && (
				<div
					class="rounded-xl border border-[#6D28D9]/35 bg-gradient-to-r from-violet-50 to-white px-4 py-3 shadow-sm sm:px-5"
					role="status"
				>
					<p class="text-sm font-medium text-violet-950">
						<span class="text-[#6D28D9]">Modo seleção</span> — 1) Clica numa imagem na biblioteca; 2) Confirma em{' '}
						<strong>«Confirmar como {mediaPickerFor === 'logo' ? 'logo' : 'favicon'}»</strong> abaixo da grelha.
					</p>
					<p class="mt-1 text-xs text-violet-800/90">
						Depois volta ao separador «Configurações»; a miniatura atualiza ao confirmar.
					</p>
				</div>
			)
		}
		<div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
			<p class="text-sm text-slate-600">
				Biblioteca de mídia do site (imagens para conteúdos, logo e favicon).
			</p>
		</div>
			<section class="mb-6 rounded-xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6" aria-labelledby="media-upload-heading">
				<h2 id="media-upload-heading" class="text-lg font-semibold text-neutral-900 mb-3">Upload</h2>
				<p class="text-sm text-neutral-600 mb-4">
					Arraste imagens para a zona abaixo ou clique para escolher. O servidor aceita
					<strong>JPEG, PNG, WebP e GIF</strong> e grava <strong>sempre</strong> um ficheiro
					<strong>WebP</strong> otimizado (máx. 1200px de largura) em <code class="text-xs bg-neutral-100 px-1 rounded">public/uploads/</code>.
				</p>
				<input
					id="media-file-input"
					type="file"
					accept="image/jpeg,image/png,image/webp,image/gif"
					class="sr-only"
					tabindex="-1"
				/>
				<label
					for="media-file-input"
					id="media-dropzone"
					tabindex="0"
					aria-label="Zona de upload: arrastar imagens ou clicar para escolher ficheiro"
					class="flex w-full cursor-pointer flex-col items-center justify-center gap-3 rounded-xl border-2 border-dashed border-slate-200 bg-slate-50/80 px-6 py-12 text-center transition-colors duration-200 hover:border-[#6D28D9]/40 hover:bg-violet-50/50 focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-[#6D28D9] focus-within:outline focus-within:outline-2 focus-within:outline-offset-2 focus-within:outline-[#6D28D9]"
				>
					<span class="text-sm font-medium text-neutral-800">Arraste e largue imagens aqui</span>
					<span class="text-xs text-neutral-500">ou clique para abrir o explorador de ficheiros</span>
				</label>
				<p id="media-upload-status" class="text-sm text-neutral-600 mt-3 min-h-[1.25rem]" role="status" aria-live="polite"></p>
			</section>

			<section class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6" aria-labelledby="media-library-heading">
				<div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between mb-4">
					<div>
						<h2 id="media-library-heading" class="text-lg font-semibold text-neutral-900">Biblioteca</h2>
						<p id="media-library-count" class="text-sm text-neutral-500 mt-1 tabular-nums">
							{initialImages.length} imagem(ns) no total
						</p>
					</div>
					<div class="w-full sm:max-w-xs shrink-0">
						<label for="media-search" class="block text-sm font-medium text-neutral-700 mb-1">Buscar por imagem</label>
						<input
							id="media-search"
							type="search"
							autocomplete="off"
							placeholder="Filtrar pelo nome do ficheiro…"
							class="w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-900 placeholder:text-slate-400 transition-colors focus:border-[#6D28D9] focus:outline focus:outline-2 focus:outline-[#6D28D9]"
							aria-controls="media-grid"
						/>
					</div>
				</div>
				<div
					id="media-grid"
					class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-3 sm:gap-4"
					role="list"
				>
				</div>
				<p id="media-empty" class="hidden text-sm text-neutral-500 italic py-8 text-center">
					{uiStatusMessages.empty.noImages}
				</p>
				<p id="media-empty-filter" class="hidden text-sm text-neutral-500 italic py-8 text-center">
					{uiStatusMessages.empty.noResults}
				</p>
				{
					mediaPickerMode && (
						<div
							id="media-picker-bar"
							class="hidden mt-4 rounded-xl border border-[#6D28D9]/35 bg-violet-50/95 p-4 shadow-sm sm:flex sm:flex-wrap sm:items-center sm:justify-between sm:gap-4"
							role="region"
							aria-labelledby="media-picker-heading"
						>
							<div class="min-w-0 flex-1">
								<p id="media-picker-heading" class="text-xs font-semibold uppercase tracking-wide text-violet-800">
									Imagem escolhida
								</p>
								<p id="media-picker-file" class="mt-1 truncate text-sm font-medium text-violet-950"></p>
								<p id="media-picker-feedback" class="mt-2 hidden text-sm font-medium text-emerald-800"></p>
							</div>
							<div id="media-picker-actions" class="mt-3 flex flex-wrap gap-2 sm:mt-0 sm:justify-end">
								<button
									type="button"
									id="btn-picker-clear"
									class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 shadow-sm transition-colors hover:bg-slate-50 focus:outline focus:outline-2 focus:outline-[#6D28D9]"
								>
									Limpar seleção
								</button>
								<button
									type="button"
									id="btn-picker-confirm"
									disabled
									class="rounded-xl bg-[#6D28D9] px-5 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-[#5b21b6] disabled:cursor-not-allowed disabled:opacity-45 focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-[#6D28D9]"
								>
									Confirmar como {mediaPickerFor === 'logo' ? 'logo' : 'favicon'}
								</button>
							</div>
						</div>
					)
				}
			</section>
	</div>

	<div
		id="media-modal"
		class="fixed inset-0 z-50 hidden"
		role="dialog"
		aria-modal="true"
		aria-labelledby="media-modal-title"
		aria-hidden="true"
	>
		<div id="media-modal-backdrop" class="absolute inset-0 bg-black/50" tabindex="-1"></div>
		<div class="absolute inset-0 p-4 sm:p-8 flex items-center justify-center pointer-events-none">
			<div
				class="pointer-events-auto w-full max-w-4xl rounded-xl bg-white shadow-2xl border border-neutral-200 overflow-hidden"
				role="document"
			>
				<div class="grid grid-cols-1 md:grid-cols-[minmax(0,1fr)_minmax(280px,400px)]">
					<div class="bg-neutral-100 flex items-center justify-center p-4 min-h-[260px]">
						<img id="modal-image" src="" alt="" class="max-h-[70vh] w-auto max-w-full rounded object-contain" />
					</div>
					<aside class="p-4 sm:p-5 border-t md:border-t-0 md:border-l border-neutral-200 max-h-[85vh] overflow-y-auto">
						<div class="flex items-start justify-between gap-3">
							<h3 id="media-modal-title" class="text-base font-semibold text-neutral-900">Pré-visualização</h3>
							<button
								id="media-modal-close"
								type="button"
								class="rounded border border-neutral-300 px-2 py-1 text-sm hover:bg-neutral-50 focus:outline focus:outline-2 focus:outline-blue-600"
								aria-label="Fechar modal"
							>
								Fechar
							</button>
						</div>
						<div class="mt-4 space-y-3 text-sm">
							<div>
								<p class="text-xs font-semibold text-neutral-500 uppercase">Nome</p>
								<p id="modal-name" class="break-all text-neutral-800"></p>
							</div>
							<div>
								<p class="text-xs font-semibold text-neutral-500 uppercase">URL</p>
								<p id="modal-url" class="break-all text-blue-700 font-mono text-xs"></p>
							</div>
							<div class="rounded-lg border border-slate-200 bg-slate-50/80 p-3 space-y-3">
								<p class="text-xs font-semibold text-neutral-700">SEO e acessibilidade</p>
								<div>
									<label for="field-media-alt" class="block text-xs font-medium text-neutral-700 mb-1">
										Texto alternativo (alt)
									</label>
									<textarea
										id="field-media-alt"
										rows="3"
										maxlength="500"
										class="w-full rounded-lg border border-neutral-300 px-2 py-1.5 text-sm text-neutral-900 placeholder:text-neutral-400 focus:border-[#6D28D9] focus:outline focus:outline-2 focus:outline-[#6D28D9]"
										placeholder="Descreva o conteúdo da imagem para leitores de ecrã e motores de busca."
									></textarea>
									<p class="text-[11px] text-neutral-500 mt-1">Recomendado para todas as imagens com significado.</p>
								</div>
								<div>
									<label for="field-media-title" class="block text-xs font-medium text-neutral-700 mb-1">
										Título (tooltip HTML opcional)
									</label>
									<input
										id="field-media-title"
										type="text"
										maxlength="300"
										class="w-full rounded-lg border border-neutral-300 px-2 py-1.5 text-sm text-neutral-900 placeholder:text-neutral-400 focus:border-[#6D28D9] focus:outline focus:outline-2 focus:outline-[#6D28D9]"
										placeholder="Tooltip opcional ao passar o rato."
									/>
								</div>
								<div>
									<label for="field-media-caption" class="block text-xs font-medium text-neutral-700 mb-1">
										Legenda
									</label>
									<textarea
										id="field-media-caption"
										rows="2"
										maxlength="500"
										class="w-full rounded-lg border border-neutral-300 px-2 py-1.5 text-sm text-neutral-900 placeholder:text-neutral-400 focus:border-[#6D28D9] focus:outline focus:outline-2 focus:outline-[#6D28D9]"
										placeholder="Texto curto visível junto à imagem (legenda)."
									></textarea>
								</div>
								<div>
									<label for="field-media-description" class="block text-xs font-medium text-neutral-700 mb-1">
										Descrição longa
									</label>
									<textarea
										id="field-media-description"
										rows="3"
										maxlength="2000"
										class="w-full rounded-lg border border-neutral-300 px-2 py-1.5 text-sm text-neutral-900 placeholder:text-neutral-400 focus:border-[#6D28D9] focus:outline focus:outline-2 focus:outline-[#6D28D9]"
										placeholder="Contexto extra (rich results, documentação interna)."
									></textarea>
								</div>
								<button
									id="btn-save-media-seo"
									type="button"
									class="w-full rounded-lg bg-[#6D28D9] px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-[#5b21b6] focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-[#6D28D9]"
								>
									Guardar SEO
								</button>
							</div>
							<div class="flex flex-wrap gap-2 pt-1">
								<button
									id="btn-copy-url"
									type="button"
									class="rounded-lg border border-neutral-300 px-3 py-2 text-sm font-medium hover:bg-neutral-50 focus:outline focus:outline-2 focus:outline-blue-600"
								>
									Copiar URL
								</button>
								<button
									id="btn-delete-media"
									type="button"
									class="rounded-lg border border-red-200 px-3 py-2 text-sm font-medium text-red-700 hover:bg-red-50 focus:outline focus:outline-2 focus:outline-red-600"
								>
									Excluir
								</button>
							</div>
							<p id="modal-status" class="text-xs text-neutral-600 min-h-[1rem]" role="status" aria-live="polite"></p>
						</div>
					</aside>
				</div>
			</div>
		</div>
	</div>

	<script is:inline define:vars={{ initialImages, mediaPickerMode, mediaPickerFor }}>
		globalThis.__mediaInitialImages = initialImages;
		globalThis.__mediaPickerMode = mediaPickerMode;
		globalThis.__mediaPickerFor = mediaPickerFor;
	</script>

	<script>
		import { actions } from 'astro:actions';
		import { uiStatusMessages } from '../../lib/ui-status-messages';

		type MediaItem = {
			name: string;
			url: string;
			size: number;
			updatedAt: string;
			alt?: string;
			title?: string;
			caption?: string;
			description?: string;
		};

		const MEDIA_SETTINGS_CHANNEL = 'blogonauta-settings-media';

		const initialRaw = (globalThis as Record<string, unknown>).__mediaInitialImages;
		const initialRows =
			initialRaw && Array.isArray(initialRaw) ? (initialRaw as MediaItem[]) : [];
		const g = globalThis as Record<string, unknown>;
		const mediaPickerMode = g.__mediaPickerMode === true;
		const mediaPickerFor =
			g.__mediaPickerFor === 'logo' || g.__mediaPickerFor === 'favicon'
				? (g.__mediaPickerFor as 'logo' | 'favicon')
				: null;
		let images = structuredClone(initialRows);
		let selected: MediaItem | null = null;
		let filterQuery = '';
		/** Pré-seleção no modo picker (confirmar envia ao BroadcastChannel). */
		let pickerChoice: MediaItem | null = null;

		const grid = document.getElementById('media-grid');
		const empty = document.getElementById('media-empty');
		const emptyFilter = document.getElementById('media-empty-filter');
		const libraryCount = document.getElementById('media-library-count');
		const dropzone = document.getElementById('media-dropzone');
		const uploadInput = document.getElementById('media-file-input');
		const uploadStatus = document.getElementById('media-upload-status');
		const searchInput = document.getElementById('media-search');

		const modal = document.getElementById('media-modal');
		const modalBackdrop = document.getElementById('media-modal-backdrop');
		const modalClose = document.getElementById('media-modal-close');
		const modalImage = document.getElementById('modal-image');
		const modalName = document.getElementById('modal-name');
		const modalUrl = document.getElementById('modal-url');
		const modalStatus = document.getElementById('modal-status');
		const btnCopyUrl = document.getElementById('btn-copy-url');
		const btnDelete = document.getElementById('btn-delete-media');
		const fieldAlt = document.getElementById('field-media-alt');
		const fieldTitle = document.getElementById('field-media-title');
		const fieldCaption = document.getElementById('field-media-caption');
		const fieldDescription = document.getElementById('field-media-description');
		const btnSaveSeo = document.getElementById('btn-save-media-seo');
		const pickerBar = document.getElementById('media-picker-bar');
		const pickerFile = document.getElementById('media-picker-file');
		const pickerFeedback = document.getElementById('media-picker-feedback');
		const pickerActions = document.getElementById('media-picker-actions');
		const btnPickerClear = document.getElementById('btn-picker-clear');
		const btnPickerConfirm = document.getElementById('btn-picker-confirm');

		function fmtBytes(bytes) {
			if (bytes < 1024) return `${bytes} B`;
			const kb = bytes / 1024;
			if (kb < 1024) return `${kb < 10 ? kb.toFixed(1) : Math.round(kb)} KB`;
			const mb = kb / 1024;
			return `${mb < 10 ? mb.toFixed(1) : Math.round(mb)} MB`;
		}

		function fmtDate(iso) {
			const d = new Date(iso);
			return d.toLocaleString('pt-BR', { dateStyle: 'short', timeStyle: 'short' });
		}

		function filteredImages() {
			const q = normalizeSearch(filterQuery);
			if (!q) return images;
			return images.filter((img) => normalizeSearch(img.name).includes(q));
		}

		function normalizeSearch(raw) {
			return String(raw ?? '')
				.toLowerCase()
				.normalize('NFD')
				.replace(/\p{M}/gu, '')
				.trim();
		}

		function updateLibraryCountLabel(total, shown) {
			if (!libraryCount) return;
			if (!total) {
				libraryCount.textContent = '0 imagens no total';
				return;
			}
			if (filterQuery.trim() && shown !== total) {
				libraryCount.textContent = `A mostrar ${shown} de ${total} imagem(ns)`;
			} else {
				libraryCount.textContent = `${total} imagem(ns) no total`;
			}
		}

		function syncPickerBar() {
			if (!mediaPickerMode || !pickerBar) return;
			if (!pickerChoice) {
				pickerBar.classList.add('hidden');
				if (pickerFile) pickerFile.textContent = '';
				if (pickerFeedback) {
					pickerFeedback.textContent = '';
					pickerFeedback.classList.add('hidden');
				}
				if (pickerActions) pickerActions.classList.remove('hidden');
				if (btnPickerConfirm instanceof HTMLButtonElement) btnPickerConfirm.disabled = true;
				return;
			}
			pickerBar.classList.remove('hidden');
			if (pickerFile) pickerFile.textContent = pickerChoice.name;
			if (pickerFeedback) {
				pickerFeedback.textContent = '';
				pickerFeedback.classList.add('hidden');
			}
			if (pickerActions) pickerActions.classList.remove('hidden');
			if (btnPickerConfirm instanceof HTMLButtonElement) btnPickerConfirm.disabled = false;
		}

		function applyPickerVisuals() {
			if (!mediaPickerMode || !grid) return;
			const buttons = grid.querySelectorAll('button[data-media-name]');
			buttons.forEach((node) => {
				const btn = node as HTMLButtonElement;
				const name = btn.dataset.mediaName;
				const on = !!pickerChoice && name === pickerChoice.name;
				btn.classList.toggle('ring-2', on);
				btn.classList.toggle('ring-[#6D28D9]', on);
				btn.classList.toggle('ring-offset-2', on);
				btn.classList.toggle('ring-offset-white', on);
				btn.setAttribute('aria-pressed', on ? 'true' : 'false');
			});
		}

		function renderGrid() {
			if (!grid) return;
			grid.replaceChildren();
			empty?.classList.add('hidden');
			emptyFilter?.classList.add('hidden');

			const total = images.length;
			if (!total) {
				empty?.classList.remove('hidden');
				updateLibraryCountLabel(0, 0);
				return;
			}

			const list = filteredImages();
			updateLibraryCountLabel(total, list.length);

			if (!list.length) {
				emptyFilter?.classList.remove('hidden');
				if (mediaPickerMode && pickerChoice) {
					pickerChoice = null;
					syncPickerBar();
				}
				return;
			}

			if (
				mediaPickerMode &&
				pickerChoice &&
				!list.some((i) => i.name === pickerChoice!.name)
			) {
				pickerChoice = null;
				syncPickerBar();
			}

			for (const img of list) {
				const card = document.createElement('button');
				card.type = 'button';
				card.className =
					'group overflow-hidden rounded-xl border border-slate-200 bg-white text-left shadow-sm transition-shadow duration-200 hover:shadow-md focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-[#6D28D9]';
				card.setAttribute('role', 'listitem');
				card.dataset.mediaName = img.name;
				if (mediaPickerMode && mediaPickerFor) {
					card.setAttribute('aria-label', `Selecionar ${img.name} para ${mediaPickerFor === 'logo' ? 'logo' : 'favicon'}`);
				} else {
					card.setAttribute('aria-label', `Abrir ${img.name}`);
				}
				const sizeBadge = fmtBytes(img.size);
				const safeName = img.name.replace(/"/g, '&quot;');
				card.innerHTML = `
					<div class="relative aspect-square overflow-hidden bg-slate-100">
						<img src="${img.url}" alt="" class="h-full w-full object-cover" loading="lazy" decoding="async" />
						<span class="absolute bottom-2 right-2 rounded-md bg-black/75 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-white tabular-nums" aria-label="Tamanho do ficheiro ${sizeBadge}">
							${sizeBadge}
						</span>
					</div>
					<div class="border-t border-slate-100 p-2">
						<p class="truncate text-xs font-medium text-slate-800" title="${safeName}">${img.name}</p>
						<p class="mt-1 text-[11px] text-slate-500">${fmtDate(img.updatedAt)}</p>
					</div>
				`;
				card.addEventListener('click', () => {
					if (mediaPickerMode && mediaPickerFor) {
						pickerChoice = img;
						syncPickerBar();
						applyPickerVisuals();
						return;
					}
					openModal(img);
				});
				grid.appendChild(card);
			}
			applyPickerVisuals();
			syncPickerBar();
		}

		btnPickerClear?.addEventListener('click', () => {
			pickerChoice = null;
			if (pickerFeedback) {
				pickerFeedback.textContent = '';
				pickerFeedback.classList.add('hidden');
			}
			syncPickerBar();
			applyPickerVisuals();
			if (btnPickerConfirm instanceof HTMLButtonElement) btnPickerConfirm.disabled = true;
		});

		btnPickerConfirm?.addEventListener('click', () => {
			if (!pickerChoice || !mediaPickerFor) return;
			try {
				const ch = new BroadcastChannel(MEDIA_SETTINGS_CHANNEL);
				ch.postMessage({
					type: 'picked',
					url: pickerChoice.url,
					target: mediaPickerFor,
				});
			} catch {
				/* ignorar */
			}
			if (pickerFeedback) {
				pickerFeedback.textContent =
					'Enviado para Configurações. Podes fechar esta janela, ou «Limpar seleção» para escolher outra imagem.';
				pickerFeedback.classList.remove('hidden');
			}
			if (btnPickerConfirm instanceof HTMLButtonElement) btnPickerConfirm.disabled = true;
			window.setTimeout(() => {
				try {
					window.close();
				} catch {
					/* ignorar */
				}
			}, 600);
		});

		function absoluteUrl(path) {
			try {
				return new URL(path, window.location.origin).href;
			} catch {
				return path;
			}
		}

		function openModal(item: MediaItem) {
			selected = item;
			if (modalImage instanceof HTMLImageElement) {
				modalImage.src = item.url;
				modalImage.alt =
					item.alt?.trim() || `Pré-visualização ampliada: ${item.name}`;
				modalImage.title = item.title?.trim() ?? '';
			}
			if (modalName) modalName.textContent = item.name;
			if (modalUrl) modalUrl.textContent = absoluteUrl(item.url);
			if (modalStatus) modalStatus.textContent = '';
			if (fieldAlt instanceof HTMLTextAreaElement) fieldAlt.value = item.alt ?? '';
			if (fieldTitle instanceof HTMLInputElement) fieldTitle.value = item.title ?? '';
			if (fieldCaption instanceof HTMLTextAreaElement) fieldCaption.value = item.caption ?? '';
			if (fieldDescription instanceof HTMLTextAreaElement)
				fieldDescription.value = item.description ?? '';
			modal?.classList.remove('hidden');
			modal?.setAttribute('aria-hidden', 'false');
			modalClose?.focus();
		}

		function closeModal() {
			selected = null;
			modal?.classList.add('hidden');
			modal?.setAttribute('aria-hidden', 'true');
			if (modalImage instanceof HTMLImageElement) {
				modalImage.removeAttribute('src');
				modalImage.alt = '';
			}
		}

		modalClose?.addEventListener('click', closeModal);
		modalBackdrop?.addEventListener('click', closeModal);

		document.addEventListener('keydown', (e) => {
			if (e.key !== 'Escape') return;
			if (modal && !modal.classList.contains('hidden')) closeModal();
		});

		btnSaveSeo?.addEventListener('click', async () => {
			if (!selected) return;
			const alt = fieldAlt instanceof HTMLTextAreaElement ? fieldAlt.value : '';
			const title = fieldTitle instanceof HTMLInputElement ? fieldTitle.value : '';
			const caption = fieldCaption instanceof HTMLTextAreaElement ? fieldCaption.value : '';
			const description =
				fieldDescription instanceof HTMLTextAreaElement ? fieldDescription.value : '';
			if (modalStatus) modalStatus.textContent = 'A guardar…';
			const { error } = await actions.saveMediaSeo({
				filename: selected.name,
				alt,
				title: title.trim() || undefined,
				caption: caption.trim() || undefined,
				description: description.trim() || undefined,
			});
			if (error) {
				if (modalStatus) modalStatus.textContent = error.message;
				return;
			}
			const at = alt.trim();
			const tt = title.trim();
			const cp = caption.trim();
			const ds = description.trim();
			const idx = images.findIndex((i) => i.name === selected.name);
			if (idx >= 0) {
				const next = { ...images[idx] };
				if (!at && !tt && !cp && !ds) {
					delete next.alt;
					delete next.title;
					delete next.caption;
					delete next.description;
				} else {
					if (at) next.alt = at;
					else delete next.alt;
					if (tt) next.title = tt;
					else delete next.title;
					if (cp) next.caption = cp;
					else delete next.caption;
					if (ds) next.description = ds;
					else delete next.description;
				}
				images[idx] = next;
				selected = next;
			}
			if (modalImage instanceof HTMLImageElement && selected) {
				modalImage.alt =
					selected.alt?.trim() || `Pré-visualização ampliada: ${selected.name}`;
				modalImage.title = selected.title?.trim() ?? '';
			}
			if (modalStatus) modalStatus.textContent = uiStatusMessages.success.seoSaved;
		});

		btnCopyUrl?.addEventListener('click', async () => {
			if (!selected) return;
			const full = absoluteUrl(selected.url);
			try {
				await navigator.clipboard.writeText(full);
				if (modalStatus) modalStatus.textContent = 'URL copiada para a área de transferência.';
			} catch {
				if (modalStatus) modalStatus.textContent = 'Não foi possível copiar automaticamente.';
			}
		});

		btnDelete?.addEventListener('click', async () => {
			if (!selected) return;
			if (!confirm(uiStatusMessages.confirm.deleteMediaFile(selected.name))) return;
			if (modalStatus) modalStatus.textContent = 'A excluir…';
			const { error } = await actions.deleteMediaFile({ filename: selected.name });
			if (error) {
				if (modalStatus) modalStatus.textContent = error.message;
				return;
			}
			images = images.filter((img) => img.name !== selected.name);
			renderGrid();
			closeModal();
		});

		async function uploadFiles(fileList) {
			const files = Array.from(fileList ?? []).filter((f) => f && f.size > 0);
			if (!files.length) {
				if (uploadStatus) uploadStatus.textContent = 'Nenhum ficheiro válido.';
				return;
			}
			if (uploadStatus) uploadStatus.textContent = `A enviar ${files.length} ficheiro(s)…`;
			let ok = 0;
			for (const file of files) {
				const fd = new FormData();
				fd.append('image', file);
				fd.append('title', file.name.replace(/\.[^.]+$/, ''));
				try {
					const r = await fetch('/api/upload', { method: 'POST', body: fd, credentials: 'same-origin' });
					const payload = await r.json();
					if (!r.ok || !payload?.url) {
						if (uploadStatus) uploadStatus.textContent = payload?.error ?? `Falha no upload: ${file.name}`;
						return;
					}
					const url = String(payload.url);
					const name =
						typeof payload.filename === 'string' && payload.filename
							? payload.filename
							: decodeURIComponent(url.split('/').pop() ?? file.name);
					const storedSize =
						typeof payload.size === 'number' && Number.isFinite(payload.size) ? payload.size : file.size;
					images.unshift({
						name,
						url,
						size: storedSize,
						updatedAt: new Date().toISOString(),
					});
					ok++;
				} catch (err) {
					if (uploadStatus) {
						uploadStatus.textContent =
							err instanceof Error ? err.message : uiStatusMessages.error.upload;
					}
					return;
				}
			}
			renderGrid();
			if (uploadInput instanceof HTMLInputElement) uploadInput.value = '';
			if (uploadStatus) uploadStatus.textContent = ok === 1 ? 'Upload concluído.' : `${ok} uploads concluídos.`;
		}

		['dragenter', 'dragover'].forEach((evt) => {
			dropzone?.addEventListener(evt, (e) => {
				e.preventDefault();
				e.stopPropagation();
				dropzone.classList.add('border-[#6D28D9]', 'bg-violet-50');
			});
		});

		['dragleave', 'drop'].forEach((evt) => {
			dropzone?.addEventListener(evt, (e) => {
				e.preventDefault();
				e.stopPropagation();
				dropzone?.classList.remove('border-[#6D28D9]', 'bg-violet-50');
			});
		});

		dropzone?.addEventListener('drop', (e) => {
			const dt = e.dataTransfer;
			if (!dt?.files?.length) return;
			void uploadFiles(dt.files);
		});

		uploadInput?.addEventListener('change', () => {
			if (uploadInput instanceof HTMLInputElement && uploadInput.files?.length) {
				void uploadFiles(uploadInput.files);
			}
		});

		searchInput?.addEventListener('input', () => {
			filterQuery = searchInput instanceof HTMLInputElement ? searchInput.value : '';
			renderGrid();
		});

		renderGrid();
	</script>
</DashboardLayout>
