---
export const prerender = false;

/**
 * Login via API central (Lovable). O painel admin **sempre** espera `CENTRAL_ADMIN_API_BASE` e `SITE_ID`
 * (incluindo após provisionamento OAuth na conta do cliente). Sem elas: mensagem amigável, sem pedidos.
 * SEO / páginas públicas usam `src/data/config.json` localmente — sem chamadas à API central.
 */
import { getCentralConfig, isCentralAdminConfigured } from '../../lib/central-admin-api';
import {
	ADMIN_SESSION_COOKIE,
	centralAdminLogin,
	isInitialSetupPending,
	isValidAdminSession,
} from '../../lib/admin-session';

const COOKIE_MAX_AGE = 60 * 60 * 8; // 8 horas

const cfg = getCentralConfig();
const centralConfigured = isCentralAdminConfigured();
const siteIdHint =
	(typeof import.meta.env.PUBLIC_SITE_ID === 'string' && import.meta.env.PUBLIC_SITE_ID.trim()) ||
	cfg?.siteId ||
	'';

const session = Astro.cookies.get(ADMIN_SESSION_COOKIE)?.value;

/** Cookie antigo sem API configurada — evita estado estranho no browser. */
if (!centralConfigured && session) {
	Astro.cookies.delete(ADMIN_SESSION_COOKIE, { path: '/' });
}

if (centralConfigured && session && (await isValidAdminSession(session))) {
	return Astro.redirect((await isInitialSetupPending(session)) ? '/admin/setup' : '/admin/dashboard');
}

const justConfigured = Astro.url.searchParams.get('configured') === '1';
const misconfigured = Astro.url.searchParams.get('misconfigured') === '1';

let error = '';

if (Astro.request.method === 'POST') {
	const form = await Astro.request.formData();
	const username = form.get('username')?.toString().trim() ?? '';
	const password = form.get('password')?.toString() ?? '';

	if (!centralConfigured) {
		error =
			'O painel admin não está ligado à API central. Configure CENTRAL_ADMIN_API_BASE e SITE_ID nas variáveis de ambiente (ex.: Vercel → Settings → Environment Variables) e volte a carregar esta página.';
	} else if (!username || !password) {
		error = 'Informe usuário e senha.';
	} else {
		const result = await centralAdminLogin(username, password);
		if (!result.ok) {
			error = result.error;
		} else {
			Astro.cookies.set(ADMIN_SESSION_COOKIE, result.sessionToken, {
				httpOnly: true,
				path: '/',
				maxAge: COOKIE_MAX_AGE,
				sameSite: 'strict',
				secure: import.meta.env.PROD,
			});
			return Astro.redirect(result.setupRequired ? '/admin/setup' : '/admin/dashboard');
		}
	}
}
---

<!doctype html>
<html lang="pt-br">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<meta name="robots" content="noindex, nofollow" />
	<title>Admin — Login</title>
	<link rel="icon" href="/favicon.ico" />
	<style>
		*, *::before, *::after { box-sizing: border-box; }
		body {
			margin: 0;
			font-family: system-ui, sans-serif;
			background: #f8fafc;
			display: flex;
			min-height: 100dvh;
			align-items: center;
			justify-content: center;
			padding: 1rem;
		}
		.card {
			background: #fff;
			border: 1px solid #e2e8f0;
			border-radius: 12px;
			padding: 2.5rem 2rem;
			width: 100%;
			max-width: 440px;
			box-shadow: 0 4px 24px rgba(0,0,0,.06);
		}
		h1 { margin: 0 0 .25rem; font-size: 1.4rem; color: #0f172a; }
		.subtitle { margin: 0 0 1.25rem; font-size: .875rem; color: #64748b; line-height: 1.45; }
		.config-help {
			margin: 0 0 1.5rem;
			padding: 1rem 1.1rem;
			background: #f1f5f9;
			border: 1px solid #cbd5e1;
			border-radius: 10px;
			color: #334155;
			font-size: .875rem;
			line-height: 1.55;
		}
		.config-help h2 {
			margin: 0 0 .5rem;
			font-size: .9375rem;
			font-weight: 700;
			color: #0f172a;
		}
		.config-help ol { margin: .5rem 0 0 1.1rem; padding: 0; }
		.config-help li { margin-bottom: .35rem; }
		label { display: block; font-size: .8125rem; font-weight: 600; color: #374151; margin-bottom: .4rem; }
		input[type="text"], input[type="password"] {
			width: 100%; padding: .6rem .75rem;
			border: 1px solid #d1d5db; border-radius: 8px;
			font-size: 1rem; outline: none;
			transition: border-color .15s;
		}
		fieldset:disabled input {
			background: #f9fafb;
			color: #6b7280;
			cursor: not-allowed;
		}
		input:focus:not(:disabled) { border-color: #2337ff; box-shadow: 0 0 0 3px rgba(35,55,255,.12); }
		.field { margin-bottom: 1rem; }
		fieldset { border: none; margin: 0; padding: 0; }
		button {
			margin-top: .5rem; width: 100%;
			background: #2337ff; color: #fff;
			border: none; border-radius: 8px;
			padding: .7rem 1rem; font-size: .9375rem;
			font-weight: 600; cursor: pointer;
			transition: background .15s;
		}
		button:hover:not(:disabled) { background: #000d8a; }
		button:disabled {
			background: #94a3b8;
			cursor: not-allowed;
		}
		.error {
			margin-top: 1rem; padding: .625rem .875rem;
			background: #fef2f2; border: 1px solid #fecaca;
			border-radius: 8px; color: #991b1b;
			font-size: .8125rem;
			line-height: 1.45;
		}
		.warning {
			margin-top: 1rem; padding: .625rem .875rem;
			background: #fffbeb; border: 1px solid #fcd34d;
			border-radius: 8px; color: #92400e;
			font-size: .8125rem;
			line-height: 1.45;
		}
		.success {
			margin-top: 1rem; padding: .625rem .875rem;
			background: #ecfdf5; border: 1px solid #6ee7b7;
			border-radius: 8px; color: #065f46;
			font-size: .8125rem;
			line-height: 1.45;
		}
		code { font-size: .8125em; word-break: break-all; }
	</style>
</head>
<body>
	<main class="card">
		<h1>Admin</h1>
		<p class="subtitle">
			O login do painel <strong>requer</strong> as variáveis <code>CENTRAL_ADMIN_API_BASE</code> e{' '}
			<code>SITE_ID</code> no deploy do cliente (incluindo fluxos com OAuth). O blog e o SEO público usam
			apenas ficheiros locais (<code>src/data/config.json</code>) — sem impacto na performance.
		</p>

		{!centralConfigured && (
			<div class="config-help" role="region" aria-labelledby="config-help-title">
				<h2 id="config-help-title">Configurar o painel (opcional neste ambiente)</h2>
				<p style="margin:0 0 .5rem">
					As variáveis <code>CENTRAL_ADMIN_API_BASE</code> e <code>SITE_ID</code> estão vazias ou incompletas.
					<strong>Não é um erro do site público</strong> — falta configurar o painel na API central (Lovable).
					O provisionamento OAuth do cliente <strong>não substitui</strong> estas duas variáveis no ambiente
					de deploy (ex.: Vercel).
				</p>
				<ol>
					<li>No painel da Vercel (ou no <code>.env</code> local), defina a URL base da API e o ID do site.</li>
					<li>Faça redeploy se alterar variáveis em produção.</li>
					<li>Recarregue esta página — o formulário abaixo será ativado automaticamente.</li>
				</ol>
				{misconfigured && (
					<p style="margin:.75rem 0 0; font-size:.8125rem; color:#64748b">
						Foi redirecionado aqui ao tentar aceder a uma área protegida do admin sem estas variáveis.
					</p>
				)}
			</div>
		)}

		{justConfigured && (
			<div class="success" role="status">
				Credenciais atualizadas na API central. Entre novamente com o <strong>novo utilizador e senha</strong>.
			</div>
		)}

		{centralConfigured && (
			<div class="warning" role="status">
				<strong>Site:</strong> <code>{siteIdHint}</code>
				<br />
				Primeiro acesso: após login válido, pode ser pedido que defina utilizador e senha definitivos na API
				central.
			</div>
		)}

		<form method="POST" autocomplete="on">
			<fieldset disabled={!centralConfigured}>
				<div class="field">
					<label for="username">Usuário</label>
					<input
						id="username"
						name="username"
						type="text"
						autocomplete="username"
						required
						autofocus={centralConfigured}
					/>
				</div>
				<div class="field">
					<label for="password">Senha</label>
					<input
						id="password"
						name="password"
						type="password"
						autocomplete="current-password"
						placeholder="••••••••"
						required
						aria-describedby={error ? 'login-error' : undefined}
					/>
				</div>
				{error && (
					<div id="login-error" class="error" role="alert">{error}</div>
				)}
				<button type="submit">Entrar</button>
			</fieldset>
		</form>
	</main>
	<script is:inline>
		try {
			localStorage.removeItem('blogonauta_admin_signed_in');
		} catch {
			/* ignorado */
		}
	</script>
</body>
</html>
