---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { loadPostForEditor } from '../../lib/blog-md-parse';
import { readCategories, readTags } from '../../lib/taxonomy-data';

export const prerender = false;

const today = new Date().toISOString().slice(0, 10);

const fileParam = Astro.url.searchParams.get('file');
let initialPost = null as Awaited<ReturnType<typeof loadPostForEditor>>;
if (fileParam) {
	initialPost = await loadPostForEditor(fileParam);
}

const taxonomyCategories = await readCategories();
const taxonomyTags = await readTags();
const tagSelectSize = Math.min(12, Math.max(4, taxonomyTags.length || 4));
---

<DashboardLayout title={initialPost ? 'Editar artigo' : 'Novo artigo'} heading={initialPost ? 'Editar artigo' : 'Novo artigo'}>
	<div class="space-y-8">
		<form id="editor-form" class="space-y-8">
			<div class="grid grid-cols-1 xl:grid-cols-[minmax(0,1fr)_minmax(20rem,24rem)] gap-8 items-start">
				<div class="min-w-0 space-y-6">
					<div class="rounded-xl border border-slate-200/90 bg-white p-4 shadow-sm sm:p-5">
						<label for="field-title" class="block font-medium text-neutral-800">Título do artigo</label>
						<p class="text-xs text-neutral-500 mt-0.5 mb-1">Aparece como H1 na página pública.</p>
						<input
							id="field-title"
							type="text"
							name="title"
							maxlength="60"
							required
							class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-200"
							autocomplete="off"
						/>
					</div>

					<div class="rounded-xl border border-slate-200/90 bg-white p-4 shadow-sm sm:p-5">
						<label for="field-author" class="block font-medium text-neutral-800">Autor (opcional)</label>
						<input
							id="field-author"
							type="text"
							name="author"
							maxlength="80"
							class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-200"
							autocomplete="name"
						/>
					</div>

					<div class="flex items-center gap-2">
						<input id="field-draft" type="checkbox" name="draft" class="rounded border-neutral-300" />
						<label for="field-draft" class="font-medium text-neutral-800">Salvar como rascunho (draft)</label>
					</div>

					<!-- Upload de Imagem com Preview -->
					<div class="rounded-xl border border-slate-200 p-4 text-center bg-white shadow-sm">
						<label for="image-upload" class="block font-medium mb-2">Imagem de destaque (enviada como WebP)</label>
						<input
							id="image-upload"
							type="file"
							accept="image/jpeg,image/png,image/webp"
							class="mb-4"
							aria-describedby="upload-hint"
						/>
						<input type="hidden" name="heroImage" id="heroImage-url" value="" />
						<p id="upload-hint" class="text-sm text-neutral-500 mb-2">Apenas JPEG, PNG ou WebP. Requer sessão admin.</p>
						<div id="preview-container" class="hidden">
							<img id="image-preview" src="" alt="Pré-visualização da imagem de destaque" class="max-h-48 mx-auto rounded" width="800" height="450" />
						</div>
					</div>

			<!-- Área de Conteúdo — WYSIWYG nativo (document.execCommand) -->
			<div class="space-y-3">
				<span id="field-content-label" class="block font-medium">Conteúdo</span>
				<div class="rounded-xl border border-slate-200/90 overflow-hidden bg-white shadow-sm">
					<div
						class="flex flex-wrap items-center justify-between gap-3 px-4 py-3 border-b border-slate-200 bg-white"
					>
						<label for="field-pubdate" class="text-sm font-medium text-neutral-800 shrink-0">
							Data de publicação
						</label>
						<input
							id="field-pubdate"
							type="date"
							name="pubDate"
							required
							value={today}
							title="Data no frontmatter do artigo (SEO, RSS e listagens)"
							class="min-w-[11rem] flex-1 max-w-[14rem] rounded-xl border border-slate-200 px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-violet-200 focus:border-violet-500"
						/>
					</div>
					<div
						id="wysiwyg-toolbar"
						class="flex flex-wrap items-center gap-1 p-2.5 border-b border-slate-200 bg-slate-50/70"
						role="toolbar"
						aria-labelledby="field-content-label"
					>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded-lg border border-slate-200 bg-white text-slate-700 hover:bg-violet-50 hover:text-violet-700 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-violet-600"
							data-cmd="formatBlock"
							data-value="h1"
							aria-label="Título nível 1"
						>
							H1
						</button>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="formatBlock"
							data-value="h2"
							aria-label="Título nível 2"
						>
							H2
						</button>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="formatBlock"
							data-value="h3"
							aria-label="Título nível 3"
						>
							H3
						</button>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="formatBlock"
							data-value="h4"
							aria-label="Título nível 4"
						>
							H4
						</button>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="formatBlock"
							data-value="h5"
							aria-label="Título nível 5"
						>
							H5
						</button>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="formatBlock"
							data-value="h6"
							aria-label="Título nível 6"
						>
							H6
						</button>
						<span class="w-px h-6 bg-neutral-300 mx-0.5 self-center shrink-0" aria-hidden="true"></span>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="insertUnorderedList"
							aria-label="Lista com marcadores"
						>
							Marcadores
						</button>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="insertOrderedList"
							aria-label="Lista numerada"
						>
							Numerada
						</button>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="formatBlock"
							data-value="blockquote"
							aria-label="Citação"
						>
							Citação
						</button>
						<button
							type="button"
							id="toolbar-insert-table"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="insertTable"
							aria-label="Inserir tabela 3 por 3 com bordas"
						>
							Tabela
						</button>
						<span class="w-px h-6 bg-neutral-300 mx-0.5 self-center shrink-0" aria-hidden="true"></span>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="bold"
							aria-label="Negrito"
						>
							Negrito
						</button>
						<button
							type="button"
							id="toolbar-insert-link"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="createLink"
							aria-label="Inserir link"
						>
							Link
						</button>
						<label class="inline-flex items-center gap-1.5 px-1 text-xs font-medium text-neutral-600">
							<span aria-hidden="true">Cor</span>
							<input
								type="color"
								id="wysiwyg-fg-color"
								value="#0f172a"
								class="h-9 w-11 cursor-pointer rounded border border-neutral-300 bg-white p-0"
								aria-label="Cor do texto"
								title="Cor do texto"
							/>
						</label>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="removeFormat"
							aria-label="Limpar formatação"
						>
							Limpar formatação
						</button>
						<span class="w-px h-6 bg-neutral-300 mx-0.5 self-center shrink-0" aria-hidden="true"></span>
						<button
							type="button"
							id="toolbar-insert-youtube"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							aria-label="Inserir vídeo do YouTube"
						>
							Vídeo
						</button>
						<button
							type="button"
							id="toolbar-open-media"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							aria-label="Inserir imagem das uploads"
						>
							Mídia
						</button>
						<span class="w-px h-6 bg-neutral-300 mx-0.5 self-center shrink-0" aria-hidden="true"></span>
						<button
							type="button"
							id="toolbar-toggle-source"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							aria-pressed="false"
							aria-label="Alternar entre edição visual e código HTML bruto"
						>
							HTML
						</button>
					</div>
					<div class="relative">
						<div
							id="wysiwyg-editor"
							contenteditable="true"
							lang="pt-br"
							class="wysiwyg-editor min-h-[20rem] max-h-[min(70vh,36rem)] overflow-y-auto p-4 text-sm text-neutral-800 leading-relaxed bg-white focus:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-violet-300"
							role="textbox"
							aria-multiline="true"
							aria-labelledby="field-content-label"
							spellcheck="false"
						></div>
						<label for="wysiwyg-source-view" class="sr-only">Código HTML do conteúdo</label>
						<textarea
							id="wysiwyg-source-view"
							class="hidden wysiwyg-source-view min-h-[20rem] max-h-[min(70vh,36rem)] w-full overflow-y-auto p-4 text-xs font-mono text-neutral-800 leading-relaxed border-0 focus:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-violet-300 resize-y"
							spellcheck="false"
							wrap="off"
							aria-hidden="true"
						></textarea>
					</div>
					<div
						id="wysiwyg-metrics-footer"
						class="flex flex-wrap items-center justify-between gap-2 px-4 py-2.5 border-t border-slate-200 bg-slate-50/80 text-xs text-neutral-600"
						aria-live="polite"
					>
						<span id="wysiwyg-seo-metrics" class="font-medium tabular-nums">Palavras: 0 | Caracteres: 0</span>
						<span class="text-neutral-400 hidden sm:inline">Texto visível (sem tags HTML)</span>
					</div>
				</div>
				<textarea id="field-content" name="content" required class="sr-only" tabindex="-1" aria-hidden="true"></textarea>
				<p class="text-sm text-neutral-500">Edição visual: o HTML é guardado no corpo do artigo. Texto simples existente é convertido em parágrafos ao abrir.</p>
			</div>
			<style>
				.wysiwyg-editor h1 {
					font-size: 1.75rem;
					font-weight: 700;
					margin: 0.75rem 0 0.5rem;
				}
				.wysiwyg-editor h2 {
					font-size: 1.375rem;
					font-weight: 700;
					margin: 0.75rem 0 0.5rem;
				}
				.wysiwyg-editor h3 {
					font-size: 1.125rem;
					font-weight: 600;
					margin: 0.5rem 0 0.35rem;
				}
				.wysiwyg-editor h4 {
					font-size: 1.0625rem;
					font-weight: 600;
					margin: 0.45rem 0 0.3rem;
				}
				.wysiwyg-editor h5 {
					font-size: 1rem;
					font-weight: 600;
					margin: 0.4rem 0 0.28rem;
				}
				.wysiwyg-editor h6 {
					font-size: 0.9375rem;
					font-weight: 600;
					margin: 0.35rem 0 0.25rem;
					color: #334155;
				}
				.wysiwyg-editor a {
					color: #2563eb;
					text-decoration: underline;
				}
				.wysiwyg-editor p {
					margin: 0.35rem 0;
				}
				.wysiwyg-editor figure.wysiwyg-youtube-embed {
					margin: 1rem 0;
					max-width: 100%;
				}
				.wysiwyg-editor .wysiwyg-youtube-inner {
					position: relative;
					padding-bottom: 56.25%;
					height: 0;
					overflow: hidden;
					max-width: 100%;
					border-radius: 8px;
					background: #0f172a;
				}
				.wysiwyg-editor .wysiwyg-youtube-inner iframe {
					position: absolute;
					top: 0;
					left: 0;
					width: 100%;
					height: 100%;
					border: 0;
				}
				.wysiwyg-editor img.wysiwyg-inserted-img {
					max-width: 100%;
					height: auto;
					border-radius: 6px;
					vertical-align: middle;
				}
				#wysiwyg-toolbar.wysiwyg-toolbar--source .wysiwyg-btn:not(#toolbar-toggle-source),
				#wysiwyg-toolbar.wysiwyg-toolbar--source label {
					pointer-events: none;
					opacity: 0.45;
				}
				#wysiwyg-toolbar .wysiwyg-btn {
					border-color: rgb(226 232 240);
					color: rgb(71 85 105);
				}
				#wysiwyg-toolbar .wysiwyg-btn:hover {
					background: rgb(245 243 255);
					color: rgb(109 40 217);
					border-color: rgb(196 181 253);
				}
				#wysiwyg-toolbar .wysiwyg-btn.wysiwyg-btn-active {
					background: #f5f3ff;
					border-color: #8b5cf6;
					color: #6d28d9;
					box-shadow: 0 0 0 1px #8b5cf6;
				}
				.wysiwyg-editor blockquote {
					margin: 0.75rem 0;
					padding: 0.5rem 0 0.5rem 1rem;
					border-left: 4px solid #cbd5e1;
					color: #475569;
					font-style: italic;
				}
				.wysiwyg-editor ul,
				.wysiwyg-editor ol {
					margin: 0.35rem 0;
					padding-left: 1.5rem;
				}
				.wysiwyg-editor li {
					margin: 0.15rem 0;
				}
			</style>
			<!-- Referência Tailwind para tabela 3×3 inserida por buildTable3x3Markup() -->
			<div class="hidden" aria-hidden="true">
				<table class="border-collapse border-2 border-slate-400 w-full text-sm my-2">
					<tbody>
						<tr>
							<td class="border border-slate-300 p-2 min-w-[4rem] align-top"></td>
							<td class="border border-slate-300 p-2 min-w-[4rem] align-top"></td>
							<td class="border border-slate-300 p-2 min-w-[4rem] align-top"></td>
						</tr>
						<tr>
							<td class="border border-slate-300 p-2 align-top"></td>
							<td class="border border-slate-300 p-2 align-top"></td>
							<td class="border border-slate-300 p-2 align-top"></td>
						</tr>
						<tr>
							<td class="border border-slate-300 p-2 align-top"></td>
							<td class="border border-slate-300 p-2 align-top"></td>
							<td class="border border-slate-300 p-2 align-top"></td>
						</tr>
					</tbody>
				</table>
			</div>

					<button
						type="submit"
						class="w-full sm:w-auto bg-violet-600 text-white px-6 py-2.5 rounded-xl hover:bg-violet-700 focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-violet-600 font-semibold shadow-sm"
					>
						Publicar Artigo
					</button>
				</div>

				<aside class="space-y-5 xl:sticky xl:top-6 self-start" aria-labelledby="seo-aside-heading">
					<section class="rounded-xl border border-slate-200/90 bg-white p-4 shadow-sm sm:p-5 space-y-5">
						<h2 id="seo-aside-heading" class="text-sm font-semibold text-neutral-900 border-b border-slate-200 pb-2">
							Configurações de SEO
						</h2>

					<div>
						<label for="field-focus-keyword" class="block text-sm font-medium text-neutral-800">Palavra-chave foco</label>
						<p class="text-xs text-neutral-500 mt-0.5 mb-1">
							Usada para o score e o checklist (não é gravada no artigo).
						</p>
						<input
							id="field-focus-keyword"
							type="text"
							name="focusKeyword"
							class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm bg-white shadow-sm focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-200"
							placeholder="ex: marketing digital"
							autocomplete="off"
							aria-describedby="focus-keyword-hint"
						/>
						<p id="focus-keyword-hint" class="text-xs text-neutral-500 mt-1">Análise em tempo real no painel abaixo.</p>
					</div>

					<div>
						<label for="field-seo-title" class="block text-sm font-medium text-neutral-800">Título SEO (opcional)</label>
						<p class="text-xs text-neutral-500 mt-0.5 mb-1">
							Sobrescreve o título do separador e das pré-visualizações sociais. Se vazio, usa o título do artigo.
						</p>
						<input
							id="field-seo-title"
							type="text"
							name="seoTitle"
							maxlength="60"
							class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm bg-white shadow-sm focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-200"
							placeholder="Máx. 60 caracteres"
							autocomplete="off"
							aria-describedby="seo-title-count"
						/>
						<p id="seo-title-count" class="text-xs text-neutral-500 mt-1 tabular-nums" aria-live="polite">0 / 60</p>
					</div>

					<div>
						<label for="field-description" class="block text-sm font-medium text-neutral-800">Meta description</label>
						<textarea
							id="field-description"
							name="description"
							rows="4"
							minlength="50"
							maxlength="160"
							required
							class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm bg-white shadow-sm focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-200"
							aria-describedby="meta-desc-count"
						></textarea>
						<p id="meta-desc-count" class="text-xs text-neutral-500 mt-1 tabular-nums" aria-live="polite">0 / 160</p>
						<p class="text-xs text-neutral-500 mt-1">Recomendado: 50–160 caracteres (regra da collection).</p>
					</div>

					<div>
						<label for="field-slug" class="block text-sm font-medium text-neutral-800">Slug (URL)</label>
						<input
							id="field-slug"
							type="text"
							name="slug"
							required
							class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm bg-white shadow-sm focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-200"
							placeholder="ex: meu-novo-post"
							spellcheck="false"
							autocomplete="off"
							aria-describedby="slug-hint"
						/>
						<p id="slug-hint" class="text-xs text-neutral-500 mt-1">
							Ficheiro <code class="text-xs bg-white px-1 rounded border border-neutral-200">slug.md</code> em
							<code class="text-xs">src/content/blog/</code>. Sugestão automática a partir do título até editares o slug manualmente.
						</p>
					</div>

					<div>
						<label for="field-post-category" class="block text-sm font-medium text-neutral-800">Categoria</label>
						<p class="text-xs text-neutral-500 mt-0.5 mb-1">Lista de <code class="text-xs">categories.json</code> (uma por artigo).</p>
						<select
							id="field-post-category"
							name="postCategory"
