---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { readCategories } from '../../lib/taxonomy-data';
import { uiStatusMessages } from '../../lib/ui-status-messages';

export const prerender = false;

const initialCategories = await readCategories();
---

<DashboardLayout
	title="Categorias — Admin"
	heading="Categorias"
	sectionTitle="Categorias do blog"
	sectionActionLabel="Adicionar Novo"
	sectionActionHref="#taxonomy-add-form"
>
	<div class="space-y-6">
			<div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
				<p class="text-sm text-slate-600">
					Gerencie aqui as categorias do blog.
					Para <strong class="font-medium text-slate-800">tags</strong>, usa a página{' '}
					<a href="/admin/tags" class="font-medium text-[#6D28D9] underline hover:text-[#5b21b6]">Tags</a>. Usa{' '}
					<strong class="font-medium text-slate-800">Editar SEO</strong> para o título e descrição das páginas de arquivo em{' '}
					<code class="rounded-md border border-slate-200 bg-slate-50 px-1.5 py-0.5 text-xs text-slate-800">/blog/categoria/…</code>.
				</p>
			</div>

			<div id="panel-taxonomy" class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10 items-start">
					<!-- Coluna esquerda: formulário -->
					<section class="space-y-4 rounded-xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6" aria-labelledby="form-taxonomy-heading">
						<div class="border-b border-slate-200 pb-3">
							<h2 id="form-taxonomy-heading" class="text-lg font-semibold text-slate-900">Adicionar nova categoria</h2>
							<p class="text-xs text-neutral-500 mt-1">
								O slug é usado na URL. Nas <strong class="font-medium text-neutral-700">categorias</strong>, o slug acompanha o nome enquanto escreves (podes editar o slug à parte).
							</p>
						</div>

						<form id="taxonomy-add-form" class="space-y-5" novalidate>
							<div>
								<label for="field-t-name" class="block text-sm font-semibold text-neutral-900 mb-1">Nome</label>
								<input
									id="field-t-name"
									type="text"
									name="name"
									required
									maxlength="80"
									autocomplete="off"
									class="wp-input w-full rounded border border-neutral-400 px-3 py-2 text-sm shadow-inner bg-white focus:border-[#2271b1] focus:ring-1 focus:ring-[#2271b1] focus:outline-none"
									placeholder="Ex.: Tecnologia"
								/>
							</div>
							<div>
								<label for="field-t-slug" class="block text-sm font-semibold text-neutral-900 mb-1">Slug</label>
								<div class="flex rounded border border-neutral-400 bg-neutral-50 overflow-hidden shadow-inner focus-within:border-[#2271b1] focus-within:ring-1 focus-within:ring-[#2271b1]">
									<span class="hidden sm:inline-flex items-center px-2.5 text-xs text-neutral-500 border-r border-neutral-300 bg-neutral-100 shrink-0" id="slug-prefix" aria-hidden="true">slug</span>
									<input
										id="field-t-slug"
										type="text"
										name="slug"
										required
										maxlength="80"
										spellcheck="false"
										autocomplete="off"
										class="flex-1 min-w-0 border-0 bg-white px-3 py-2 text-sm font-mono text-neutral-900 focus:ring-0 focus:outline-none"
										placeholder="tecnologia"
										aria-describedby="slug-help-default"
									/>
								</div>
								<p class="text-xs text-neutral-500 mt-1.5 space-y-1.5">
									<span id="slug-help-default" class="block text-neutral-500">
										O slug segue o nome enquanto escreves (ex.: «Marketing Digital» →{' '}
										<code class="rounded bg-neutral-100 px-1 font-mono text-[11px] text-neutral-800">marketing-digital</code>). Se editares o slug à mão, essa ligação pára até repores com o botão abaixo.
									</span>
									<button
										type="button"
										id="btn-resync-slug"
										class="text-[#2271b1] hover:underline font-medium"
										hidden
									>
										Repor slug a partir do nome
									</button>
								</p>
							</div>
							<div>
								<label for="field-t-description" class="block text-sm font-semibold text-neutral-900 mb-1">Descrição</label>
								<textarea
									id="field-t-description"
									name="description"
									rows="3"
									maxlength="5000"
									class="wp-input w-full resize-y rounded border border-neutral-400 px-3 py-2 text-sm shadow-inner bg-white focus:border-[#2271b1] focus:ring-1 focus:ring-[#2271b1] focus:outline-none"
									placeholder="Notas internas ou resumo para arquivo público..."
								></textarea>
							</div>
							<button
								type="submit"
								id="taxonomy-submit-btn"
								class="inline-flex items-center justify-center rounded-xl bg-[#6D28D9] px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors duration-200 ease-out hover:bg-[#5b21b6] focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-[#6D28D9] disabled:cursor-not-allowed disabled:opacity-70"
							>
								Adicionar categoria
							</button>
						</form>
						<p id="taxonomy-form-msg" class="text-sm min-h-[1.25rem] text-neutral-600" role="status" aria-live="polite"></p>
					</section>

					<!-- Coluna direita: tabela estilo lista WP -->
					<section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm" aria-labelledby="table-taxonomy-heading">
						<div class="flex items-center justify-between gap-2 border-b border-slate-200 bg-slate-50 px-5 py-4">
							<h2 id="table-taxonomy-heading" class="text-sm font-semibold text-slate-900">Todas as categorias</h2>
							<span class="text-xs tabular-nums text-slate-500" id="taxonomy-count">0 itens</span>
						</div>
						<div class="border-b border-slate-200 bg-white px-5 py-4">
							<label for="taxonomy-search" class="block text-sm font-medium text-slate-800">Buscar por categoria</label>
							<input
								id="taxonomy-search"
								type="search"
								class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-200"
								placeholder="Filtrar por nome, slug ou descrição..."
								autocomplete="off"
								aria-controls="taxonomy-main-table"
							/>
						</div>
						<div class="overflow-x-auto">
							<table id="taxonomy-main-table" class="w-full border-collapse text-left text-sm">
								<thead>
									<tr class="border-b border-slate-200 bg-slate-50">
										<th scope="col" class="w-24 px-6 py-5 text-xs font-semibold uppercase tracking-wider text-slate-800">ID</th>
										<th scope="col" class="px-6 py-5 text-xs font-semibold uppercase tracking-wider text-slate-800">Nome</th>
										<th scope="col" class="px-6 py-5 text-xs font-semibold uppercase tracking-wider text-slate-800">Slug</th>
										<th scope="col" class="col-seo w-28 px-6 py-5 text-center text-xs font-semibold uppercase tracking-wider text-slate-800">
											SEO
										</th>
										<th scope="col" class="w-24 px-6 py-5 text-right text-xs font-semibold uppercase tracking-wider text-slate-800">
											<span class="sr-only">Ações</span>
										</th>
									</tr>
								</thead>
								<tbody id="taxonomy-table-body" class="divide-y divide-slate-100 bg-white"></tbody>
							</table>
						</div>
						<p
							id="taxonomy-empty-hint"
							class="hidden border-t border-slate-100 bg-slate-50/60 px-4 py-10 text-center text-sm text-slate-500"
						>
							{uiStatusMessages.empty.noCategories}
						</p>
					</section>
				</div>
			</div>
	</div>

	<dialog
		id="dialog-category-seo"
		class="w-[min(100%,28rem)] max-w-lg overflow-hidden rounded-xl border border-slate-200 bg-white p-0 shadow-xl backdrop:bg-black/50 open:backdrop:bg-black/50"
		aria-labelledby="dialog-seo-title"
	>
		<form id="form-category-seo" class="p-6 space-y-4">
			<h2 id="dialog-seo-title" class="text-lg font-semibold text-neutral-900">SEO da categoria</h2>
			<input type="hidden" id="seo-edit-id" value="" />
			<p class="text-xs text-neutral-600">
				Página pública:
				<code id="seo-public-url" class="ml-1 bg-neutral-100 px-1.5 py-0.5 rounded text-neutral-800 text-[11px] break-all"></code>
			</p>
			<div>
				<label for="seo-meta-title" class="block text-sm font-semibold text-neutral-900 mb-1"
					>Título para Google (meta title)</label
				>
				<input
					id="seo-meta-title"
					type="text"
					maxlength="70"
					autocomplete="off"
					class="wp-input w-full rounded border border-neutral-400 px-3 py-2 text-sm shadow-inner bg-white focus:border-[#2271b1] focus:ring-1 focus:ring-[#2271b1] focus:outline-none"
					placeholder="Se vazio, usa o nome da categoria"
				/>
				<p class="text-xs text-neutral-500 mt-1"><span id="seo-count-title">0</span>/70</p>
			</div>
			<div>
				<label for="seo-meta-desc" class="block text-sm font-semibold text-neutral-900 mb-1"
					>Meta description</label
				>
				<textarea
					id="seo-meta-desc"
					maxlength="160"
					rows="3"
					class="wp-input w-full rounded border border-neutral-400 px-3 py-2 text-sm shadow-inner bg-white focus:border-[#2271b1] focus:ring-1 focus:ring-[#2271b1] focus:outline-none resize-y min-h-[4.5rem]"
					placeholder="Resumo para resultados de pesquisa (recomendado até 160 caracteres)"
				></textarea>
				<p class="text-xs text-neutral-500 mt-1"><span id="seo-count-desc">0</span>/160</p>
			</div>
			<div>
				<label for="seo-og-image" class="block text-sm font-semibold text-neutral-900 mb-1"
					>Imagem Open Graph (URL ou caminho)</label
				>
				<input
					id="seo-og-image"
					type="text"
					maxlength="500"
					autocomplete="off"
					class="wp-input w-full rounded border border-neutral-400 px-3 py-2 text-sm shadow-inner bg-white focus:border-[#2271b1] focus:ring-1 focus:ring-[#2271b1] focus:outline-none"
					placeholder="Ex.: /uploads/capa.webp ou https://…"
				/>
			</div>
			<div class="flex items-start gap-2">
				<input id="seo-noindex" type="checkbox" class="mt-1 rounded border-neutral-400" />
				<label for="seo-noindex" class="text-sm text-neutral-800 leading-snug">
					Não indexar esta página de arquivo (<code class="text-xs">noindex</code>)
				</label>
			</div>
			<div class="flex flex-wrap gap-2 justify-end pt-2 border-t border-neutral-200">
				<button
					type="button"
					id="seo-btn-cancel"
					class="rounded border border-neutral-300 bg-white px-4 py-2 text-sm font-medium text-neutral-700 hover:bg-neutral-50"
				>
					Cancelar
				</button>
							<button
								type="submit"
								class="rounded-xl bg-[#6D28D9] px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors duration-200 ease-out hover:bg-[#5b21b6] focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-[#6D28D9]"
							>
								Guardar SEO
							</button>
			</div>
			<p id="seo-form-msg" class="text-sm min-h-[1.25rem]" role="status" aria-live="polite"></p>
		</form>
	</dialog>

	<script is:inline>
		globalThis.__taxonomyModuleLoaded = false;
	</script>

	<!-- Feedback sempre visível (evita mensagens só no parágrafo do formulário). -->
	<div
		id="taxonomy-toast"
		class="pointer-events-none fixed bottom-6 right-6 z-[100] max-w-md translate-y-3 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-800 opacity-0 shadow-lg transition-all duration-300 ease-out"
		role="status"
		aria-live="polite"
		aria-atomic="true"
		hidden
	>
	</div>

	<script is:inline define:vars={{ initialCategories }}>
		globalThis.__taxonomyInitialCategories = initialCategories;
	</script>

	<script>
		import { actions } from 'astro:actions';
		import { uiStatusMessages } from '../../lib/ui-status-messages';

		globalThis.__taxonomyModuleLoaded = true;

		type CategoryRow = {
			id: string;
			name: string;
			slug: string;
			description?: string;
			seo?: {
				metaTitle?: string;
				metaDescription?: string;
				noindex?: boolean;
				ogImage?: string;
			};
		};
		const initialCategoriesRaw = (globalThis as Record<string, unknown>).__taxonomyInitialCategories;
		const initialRows =
			initialCategoriesRaw && Array.isArray(initialCategoriesRaw)
				? (initialCategoriesRaw as CategoryRow[])
				: [];
		let categories: CategoryRow[] = structuredClone(initialRows);

		/** Se o utilizador editou o slug manualmente, deixamos de sobrescrever (até repor). */
		let slugManualLock = false;
		/** Evita tratar `input` no slug quando o valor foi definido a partir do nome (alguns browsers). */
		let syncingSlugFromName = false;
		const countEl = document.querySelector('#taxonomy-count');
		const tbody = document.querySelector('#taxonomy-table-body');
		const emptyHint = document.querySelector('#taxonomy-empty-hint');
		const form = document.querySelector('#taxonomy-add-form');
		const nameInput = document.querySelector('#field-t-name');
		const slugInput = document.querySelector('#field-t-slug');
		const descriptionInput = document.querySelector('#field-t-description');
		const msgEl = document.querySelector('#taxonomy-form-msg');
		const submitBtn = document.querySelector('#taxonomy-submit-btn');
		const toastEl = document.querySelector('#taxonomy-toast');
		let toastTimer = 0;
		const btnResync = document.querySelector('#btn-resync-slug');
		const slugHelpDefault = document.querySelector('#slug-help-default');
		const dialogSeo = document.querySelector('#dialog-category-seo');
		const formSeo = document.querySelector('#form-category-seo');
		const seoEditId = document.querySelector('#seo-edit-id');
		const seoPublicUrl = document.querySelector('#seo-public-url');
		const seoMetaTitle = document.querySelector('#seo-meta-title');
		const seoMetaDesc = document.querySelector('#seo-meta-desc');
		const seoOgImage = document.querySelector('#seo-og-image');
		const seoNoindex = document.querySelector('#seo-noindex');
		const seoCountTitle = document.querySelector('#seo-count-title');
		const seoCountDesc = document.querySelector('#seo-count-desc');
		const seoFormMsg = document.querySelector('#seo-form-msg');
		const seoBtnCancel = document.querySelector('#seo-btn-cancel');
		const searchInput = document.querySelector('#taxonomy-search');
		let filterQuery = '';

		function slugify(raw: string): string {
			return raw
				.normalize('NFD')
				.replace(/\p{M}/gu, '')
				.toLowerCase()
				.replace(/[^a-z0-9]+/g, '-')
				.replace(/^-+|-+$/g, '')
				.slice(0, 80);
		}

		function normalizeSearch(raw: string): string {
			return raw
				.toLowerCase()
				.normalize('NFD')
				.replace(/\p{M}/gu, '')
				.trim();
		}

		/** Alinhado ao schema Zod em `actions/taxonomy.ts` (aceita letras, números, _ e hífens). */
		function isValidSlugSegment(s: string): boolean {
			return /^[\w-]+$/.test(s);
		}

		function actionErrMessage(err: unknown): string {
			if (err instanceof Error && err.message.trim()) return err.message.trim();
			if (typeof err === 'object' && err !== null && 'message' in err) {
				const m = String((err as { message?: unknown }).message ?? '').trim();
				if (m) return m;
			}
			return 'Erro ao comunicar com o servidor.';
		}

		function showToast(message: string, variant: 'success' | 'error' | 'info' = 'info') {
			if (!(toastEl instanceof HTMLElement)) return;
			window.clearTimeout(toastTimer);
			toastEl.hidden = false;
			toastEl.textContent = message;
			toastEl.className =
				'fixed bottom-6 right-6 z-[100] max-w-md translate-y-3 rounded-xl border px-4 py-3 text-sm opacity-0 shadow-lg transition-all duration-300 ease-out pointer-events-none';
			if (variant === 'success') {
				toastEl.classList.add('border-emerald-200', 'bg-emerald-50', 'text-emerald-950');
			} else if (variant === 'error') {
				toastEl.classList.add('border-red-200', 'bg-red-50', 'text-red-950');
			} else {
				toastEl.classList.add('border-slate-200', 'bg-white', 'text-slate-800');
			}
			requestAnimationFrame(() => {
				toastEl.classList.remove('opacity-0', 'translate-y-3');
				toastEl.classList.add('opacity-100', 'translate-y-0');
			});
			toastTimer = window.setTimeout(() => {
				toastEl.classList.add('opacity-0', 'translate-y-3');
				toastEl.classList.remove('opacity-100', 'translate-y-0');
				window.setTimeout(() => {
					toastEl.hidden = true;
				}, 320);
			}, 5200);
		}

		function syncSlugFromName() {
			if (!(slugInput instanceof HTMLInputElement) || !(nameInput instanceof HTMLInputElement)) return;
			if (slugManualLock) return;
			syncingSlugFromName = true;
			slugInput.value = slugify(nameInput.value);
			queueMicrotask(() => {
				syncingSlugFromName = false;
			});
			updateResyncVisibility();
		}

		function updateResyncVisibility() {
			if (!(btnResync instanceof HTMLButtonElement) || !(slugHelpDefault instanceof HTMLElement)) return;
			const show = slugManualLock;
			btnResync.hidden = !show;
			slugHelpDefault.classList.toggle('hidden', show);
		}

		function setRows(next: CategoryRow[]) {
			categories = next;
		}

		function renderTable() {
			if (!(tbody instanceof HTMLTableSectionElement)) return;
			const rows = categories.filter((row) => {
				if (!filterQuery.trim()) return true;
				const haystack = normalizeSearch(`${row.name} ${row.slug} ${row.description ?? ''}`);
				return haystack.includes(filterQuery);
			});
			tbody.replaceChildren();
			if (countEl) {
				const total = categories.length;
				const shown = rows.length;
				countEl.textContent =
					filterQuery.trim().length > 0
						? `${shown} de ${total} itens`
						: `${shown} ${shown === 1 ? 'item' : 'itens'}`;
			}
			if (rows.length === 0) {
				emptyHint?.classList.remove('hidden');
			} else {
				emptyHint?.classList.add('hidden');
			}
			for (const row of rows) {
				const tr = document.createElement('tr');
				tr.className = 'transition-colors hover:bg-slate-50/80';
				const seoBtn = `<button type="button" class="taxonomy-seo text-sm font-medium text-[#6D28D9] hover:text-[#5b21b6] hover:underline focus:outline focus:outline-2 focus:outline-offset-1 focus:outline-[#6D28D9] rounded" data-id="${escapeAttr(row.id)}">Editar SEO</button>`;
				tr.innerHTML = `
					<td class="px-6 py-7 align-top font-mono text-[10px] text-slate-500" title="${escapeAttr(row.id)}">${escapeHtml(row.id.slice(0, 8))}…</td>
					<td class="px-6 py-7 align-top">
						<p class="font-medium text-slate-900">${escapeHtml(row.name)}</p>
						${row.description?.trim() ? `<p class="mt-1 text-xs text-slate-500">${escapeHtml(row.description)}</p>` : ''}
					</td>
					<td class="px-6 py-7 align-top font-mono text-xs text-slate-700">${escapeHtml(row.slug)}</td>
					<td class="col-seo px-6 py-7 align-top text-center">${seoBtn}</td>
					<td class="px-6 py-7 align-top text-right">
						<button type="button" class="taxonomy-del rounded text-sm font-medium text-red-600 hover:text-red-700 hover:underline focus:outline focus:outline-2 focus:outline-offset-1 focus:outline-[#6D28D9]" data-id="${escapeAttr(row.id)}">
							Excluir
						</button>
					</td>
				`;
				tbody.appendChild(tr);
			}
			for (const btn of tbody.querySelectorAll('button.taxonomy-del')) {
				btn.addEventListener('click', onDeleteClick);
			}
			for (const btn of tbody.querySelectorAll('button.taxonomy-seo')) {
				btn.addEventListener('click', onSeoClick);
			}
		}

		searchInput?.addEventListener('input', () => {
			if (!(searchInput instanceof HTMLInputElement)) return;
			filterQuery = normalizeSearch(searchInput.value);
			renderTable();
		});

		function escapeHtml(s: string): string {
			const d = document.createElement('div');
			d.textContent = s;
			return d.innerHTML;
		}

		function escapeAttr(s: string): string {
			return s.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
		}

		function syncSeoCounters() {
			if (seoMetaTitle instanceof HTMLInputElement && seoCountTitle) {
				seoCountTitle.textContent = String(seoMetaTitle.value.length);
			}
			if (seoMetaDesc instanceof HTMLTextAreaElement && seoCountDesc) {
				seoCountDesc.textContent = String(seoMetaDesc.value.length);
			}
		}

		function openSeoDialog(cat: CategoryRow) {
			if (!(dialogSeo instanceof HTMLDialogElement)) return;
			if (seoEditId instanceof HTMLInputElement) seoEditId.value = cat.id;
			if (seoPublicUrl) seoPublicUrl.textContent = `/blog/categoria/${cat.slug}/`;
			if (seoMetaTitle instanceof HTMLInputElement) seoMetaTitle.value = cat.seo?.metaTitle ?? '';
			if (seoMetaDesc instanceof HTMLTextAreaElement) seoMetaDesc.value = cat.seo?.metaDescription ?? '';
			if (seoOgImage instanceof HTMLInputElement) seoOgImage.value = cat.seo?.ogImage ?? '';
			if (seoNoindex instanceof HTMLInputElement) seoNoindex.checked = Boolean(cat.seo?.noindex);
			if (seoFormMsg) {
				seoFormMsg.textContent = '';
				seoFormMsg.className = 'text-sm min-h-[1.25rem]';
			}
			syncSeoCounters();
			dialogSeo.showModal();
		}

		function onSeoClick(ev: Event) {
			const btn = ev.currentTarget;
			if (!(btn instanceof HTMLButtonElement)) return;
			const id = btn.getAttribute('data-id');
			if (!id) return;
			const cat = categories.find((c) => c.id === id);
			if (!cat) return;
			openSeoDialog(cat);
		}

		seoMetaTitle?.addEventListener('input', syncSeoCounters);
		seoMetaDesc?.addEventListener('input', syncSeoCounters);

		seoBtnCancel?.addEventListener('click', () => {
			if (dialogSeo instanceof HTMLDialogElement) dialogSeo.close();
		});

		formSeo?.addEventListener('submit', async (e) => {
			e.preventDefault();
			if (!(seoEditId instanceof HTMLInputElement)) return;
			const id = seoEditId.value.trim();
			if (!id) return;
			const metaTitle = seoMetaTitle instanceof HTMLInputElement ? seoMetaTitle.value : '';
			const metaDescription = seoMetaDesc instanceof HTMLTextAreaElement ? seoMetaDesc.value : '';
			const ogImage = seoOgImage instanceof HTMLInputElement ? seoOgImage.value : '';
			const noindex = seoNoindex instanceof HTMLInputElement ? seoNoindex.checked : false;
			if (seoFormMsg) {
				seoFormMsg.textContent = uiStatusMessages.loading.saving;
				seoFormMsg.className = 'text-sm min-h-[1.25rem] text-neutral-600';
			}
			try {
				const { data, error } = await actions.taxonomy.updateCategorySeo({
					id,
					metaTitle,
					metaDescription,
					noindex,
					ogImage,
				});
				if (error) {
					if (seoFormMsg) {
						seoFormMsg.textContent = error.message;
						seoFormMsg.className = 'text-sm min-h-[1.25rem] text-[#b32d2e]';
					}
					return;
				}
				if (data?.categories) {
					categories = data.categories as CategoryRow[];
					renderTable();
				}
				if (dialogSeo instanceof HTMLDialogElement) dialogSeo.close();
				setMsg('SEO da categoria atualizado.');
			} catch (err) {
				if (seoFormMsg) {
					seoFormMsg.textContent = err instanceof Error ? err.message : uiStatusMessages.error.saveGeneric;
					seoFormMsg.className = 'text-sm min-h-[1.25rem] text-[#b32d2e]';
				}
			}
		});

		function setMsg(
			text: string,
			isError = false,
			toastVariant: 'success' | 'error' | 'info' = 'info',
		) {
			if (!(msgEl instanceof HTMLElement)) return;
			msgEl.textContent = text;
			msgEl.className =
				'text-sm min-h-[1.25rem] ' + (isError ? 'text-[#b32d2e] font-medium' : 'text-neutral-600');
			if (text.trim() && text !== uiStatusMessages.loading.saving) {
				const v = isError ? 'error' : toastVariant;
				showToast(text, v);
			}
		}

		nameInput?.addEventListener('input', syncSlugFromName);
		nameInput?.addEventListener('compositionend', syncSlugFromName);

		slugInput?.addEventListener('input', () => {
			if (syncingSlugFromName) return;
			slugManualLock = true;
			updateResyncVisibility();
		});

		btnResync?.addEventListener('click', () => {
			slugManualLock = false;
			syncSlugFromName();
			setMsg('Slug reposto a partir do nome.');
		});

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			if (!(nameInput instanceof HTMLInputElement) || !(slugInput instanceof HTMLInputElement)) return;
			const name = nameInput.value.trim();
			const slug = slugInput.value.trim().toLowerCase();
			const description =
				descriptionInput instanceof HTMLTextAreaElement ? descriptionInput.value.trim() : '';
			if (!name || !slug) {
				setMsg('Preenche o nome e o slug.', true);
				return;
			}
			if (!isValidSlugSegment(slug)) {
				setMsg('No slug usa apenas letras minúsculas, números e hífens (sem espaços).', true);
				slugInput.focus();
				return;
			}
			const prevBtnText = submitBtn instanceof HTMLButtonElement ? submitBtn.textContent : '';
			if (submitBtn instanceof HTMLButtonElement) {
				submitBtn.disabled = true;
				submitBtn.textContent = uiStatusMessages.loading.saving;
			}
			setMsg(uiStatusMessages.loading.saving);
			try {
				const result = await actions.taxonomy.addCategory({ name, slug, description });
				const { data, error } = result;
				if (error) {
					setMsg(actionErrMessage(error), true);
					return;
				}
				if (!data) {
					setMsg('Resposta vazia do servidor ao criar categoria.', true);
					return;
				}
				if (data.categories) {
					setRows(data.categories as CategoryRow[]);
					renderTable();
				}
				if ('added' in data && data.added === false) {
					setMsg(uiStatusMessages.error.duplicateCategorySlug, false, 'info');
				} else {
					setMsg(uiStatusMessages.success.categoryAdded, false, 'success');
					form.reset();
					slugManualLock = false;
					syncSlugFromName();
				}
			} catch (err) {
				setMsg(actionErrMessage(err), true);
			} finally {
				if (submitBtn instanceof HTMLButtonElement) {
					submitBtn.disabled = false;
					if (prevBtnText) submitBtn.textContent = prevBtnText;
				}
			}
		});

		async function onDeleteClick(ev: Event) {
			const btn = ev.currentTarget;
			if (!(btn instanceof HTMLButtonElement)) return;
			const id = btn.getAttribute('data-id');
			if (!id || !confirm(uiStatusMessages.confirm.deleteCategory)) return;
			setMsg('');
			try {
				const { data, error } = await actions.taxonomy.deleteCategory({ id });
				if (error) {
					setMsg(error.message, true);
					return;
				}
				if (data?.categories) {
					setRows(data.categories as CategoryRow[]);
					renderTable();
				}
				setMsg(data?.removed ? uiStatusMessages.success.categoryRemoved : uiStatusMessages.error.categoryNotFound);
			} catch (err) {
				setMsg(err instanceof Error ? err.message : 'Erro ao excluir.', true);
			}
		}

		renderTable();
		syncSlugFromName();
	</script>

	<script is:inline>
		(function () {
			const form = document.getElementById('taxonomy-add-form');
			const msg = document.getElementById('taxonomy-form-msg');
			if (!form) return;
			form.addEventListener(
				'submit',
				function (e) {
					e.preventDefault();
					if (!globalThis.__taxonomyModuleLoaded) {
						const t =
							'O JavaScript do painel não carregou (erro comum: dependências do Vite). Abre a consola (F12), para outros processos `npm run dev`, apaga `node_modules/.vite` e recarrega. Em deploy na Vercel, gravar `categories.json` no disco não funciona — usa só em desenvolvimento local.';
						if (msg) {
							msg.textContent = t;
							msg.className = 'text-sm min-h-[1.25rem] text-[#b45309] font-medium';
						}
					}
				},
				true,
			);
		})();
	</script>
</DashboardLayout>
