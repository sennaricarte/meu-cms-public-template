---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { readSiteConfig } from '../../lib/site-config';

export const prerender = false;

const config = await readSiteConfig();
const sitemapUrl = new URL('sitemap-index.xml', config.siteUrl).toString();
const robotsUrl = new URL('robots.txt', config.siteUrl).toString();
---

<DashboardLayout
	title="Configurações — Admin"
	heading="Configurações"
	sectionTitle="Configurações globais"
	sectionActionLabel="Central de mídia"
	sectionActionHref="/admin/media"
>
	<!-- Fundo cinza gelo (área da página); card branco em destaque -->
	<div
		class="settings-surface -mx-4 -mt-1 min-h-[calc(100vh-10rem)] rounded-2xl border border-slate-200/90 bg-[#F1F5F9] px-4 py-8 sm:-mx-6 sm:px-6 lg:-mx-10 lg:px-10"
	>
		<div class="mx-auto max-w-3xl space-y-5">
			<p class="text-center text-xs text-slate-500 sm:text-left">
				Estas configurações são aplicadas em todo o site.
			</p>

			<form
				id="form-settings"
				class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8"
				aria-labelledby="settings-form-heading"
			>
				<h2 id="settings-form-heading" class="text-lg font-semibold text-slate-900">
					Identidade e SEO
				</h2>
				<p class="mt-1 text-sm text-slate-500">
					Nome público, URL base e meta descrição global. Logo e favicon vêm da Central de Mídia.
				</p>

				<div class="mt-6 space-y-5">
					<div>
						<label for="field-site-name" class="block text-sm font-medium text-slate-700">Nome do site</label>
						<input
							id="field-site-name"
							name="siteName"
							type="text"
							required
							maxlength="120"
							autocomplete="organization"
							value={config.siteName}
							class="mt-1.5 w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm text-slate-900 shadow-sm transition-colors focus:border-[#6D28D9] focus:outline focus:outline-2 focus:outline-[#6D28D9]"
							placeholder="Ex.: Blogonauta"
						/>
					</div>

					<div>
						<label for="field-site-url" class="block text-sm font-medium text-slate-700">URL</label>
						<input
							id="field-site-url"
							name="siteUrl"
							type="url"
							required
							inputmode="url"
							value={config.siteUrl}
							class="mt-1.5 w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm text-slate-900 shadow-sm transition-colors focus:border-[#6D28D9] focus:outline focus:outline-2 focus:outline-[#6D28D9]"
							placeholder="https://www.exemplo.com/"
							aria-describedby="field-site-url-hint"
						/>
						<p id="field-site-url-hint" class="mt-1.5 text-xs text-slate-500">
							Ao gravar, a URL fica com <strong class="font-medium text-slate-600">barra (/) no fim</strong> para silos de conteúdo.
						</p>
					</div>

					<div>
						<label for="field-meta-desc" class="block text-sm font-medium text-slate-700">
							Meta descrição
						</label>
						<textarea
							id="field-meta-desc"
							name="siteDescription"
							required
							rows="4"
							maxlength="320"
							class="mt-1.5 w-full resize-y rounded-xl border border-slate-200 px-3 py-2.5 text-sm text-slate-900 shadow-sm transition-colors focus:border-[#6D28D9] focus:outline focus:outline-2 focus:outline-[#6D28D9]"
							placeholder="Descrição global para motores de busca (fallback quando a página não define descrição)."
						>{config.siteDescription}</textarea>
						<p class="mt-1 text-xs text-slate-500">
							<span id="meta-desc-count" class="tabular-nums">{config.siteDescription.length}</span>/320
						</p>
					</div>

					<!-- Logo -->
					<div class="rounded-xl border border-slate-100 bg-slate-50/90 p-4 sm:p-5">
						<label class="block text-sm font-medium text-slate-700">Logo</label>
						<p class="mt-0.5 text-xs text-slate-500">
							Miniatura do ficheiro selecionado. Abre a Central de Mídia noutro separador para escolher.
						</p>
						<div class="mt-3 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
							<div
								class="flex h-24 w-24 shrink-0 items-center justify-center overflow-hidden rounded-xl border-2 border-dashed border-slate-200 bg-white shadow-inner"
								aria-hidden="true"
							>
								<img
									id="preview-logo"
									src={config.logoPath}
									alt=""
									class="max-h-[5.5rem] max-w-[5.5rem] object-contain p-1"
									width="96"
									height="96"
									loading="lazy"
									decoding="async"
								/>
							</div>
							<div class="flex min-w-0 flex-1 flex-col gap-2">
								<input type="hidden" id="field-logo-path" name="logoPath" value={config.logoPath} />
								<button
									type="button"
									id="btn-open-media-logo"
									class="inline-flex w-full items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-[#6D28D9] shadow-sm transition-colors hover:border-[#6D28D9]/50 hover:bg-violet-50/80 focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-[#6D28D9] sm:w-auto sm:justify-start"
								>
									Abrir Central de Mídia — escolher logo
								</button>
							</div>
						</div>
					</div>

					<!-- Favicon -->
					<div class="rounded-xl border border-slate-100 bg-slate-50/90 p-4 sm:p-5">
						<label class="block text-sm font-medium text-slate-700">Favicon</label>
						<p class="mt-0.5 text-xs text-slate-500">Ícone do separador; recomendado quadrado (PNG ou WebP).</p>
						<div class="mt-3 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
							<div
								class="flex h-20 w-20 shrink-0 items-center justify-center overflow-hidden rounded-xl border-2 border-dashed border-slate-200 bg-white shadow-inner"
								aria-hidden="true"
							>
								<img
									id="preview-favicon"
									src={config.faviconPath}
									alt=""
									class="max-h-16 max-w-16 object-contain p-1"
									width="64"
									height="64"
									loading="lazy"
									decoding="async"
								/>
							</div>
							<div class="flex min-w-0 flex-1 flex-col gap-2">
								<input type="hidden" id="field-favicon-path" name="faviconPath" value={config.faviconPath} />
								<button
									type="button"
									id="btn-open-media-favicon"
									class="inline-flex w-full items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-[#6D28D9] shadow-sm transition-colors hover:border-[#6D28D9]/50 hover:bg-violet-50/80 focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-[#6D28D9] sm:w-auto sm:justify-start"
								>
									Abrir Central de Mídia — escolher favicon
								</button>
							</div>
						</div>
					</div>

				</div>

				<!-- Preview de busca (snippet Google) — abaixo dos campos -->
				<section
					class="mt-8 rounded-xl border border-slate-200 bg-slate-50/80 p-4 sm:p-5"
					aria-labelledby="snippet-heading"
				>
					<h3 id="snippet-heading" class="text-xs font-bold uppercase tracking-wider text-slate-500">
						Preview de busca (Google)
					</h3>
					<p class="mt-1 text-xs text-slate-500">Simulação de como o resultado pode aparecer na pesquisa.</p>
					<div
						class="mt-4 rounded-lg border border-slate-200 bg-white px-4 py-3.5 shadow-[0_1px_2px_rgba(0,0,0,0.06)]"
						role="region"
						aria-label="Snippet de resultado de pesquisa"
					>
						<div class="flex items-start gap-3">
							<img
								id="serp-favicon"
								src={config.faviconPath}
								alt=""
								class="mt-0.5 h-7 w-7 shrink-0 rounded-full object-cover ring-1 ring-slate-200"
								width="28"
								height="28"
								loading="lazy"
								decoding="async"
							/>
							<div class="min-w-0 flex-1">
								<p id="serp-site-line" class="truncate text-sm text-slate-800"></p>
								<p id="serp-url-line" class="truncate text-xs text-emerald-800"></p>
							</div>
						</div>
						<p id="serp-title" class="mt-2 line-clamp-2 cursor-default text-lg leading-snug text-[#1a0dab]"></p>
						<p id="serp-desc" class="mt-1 line-clamp-3 text-sm leading-relaxed text-[#4d5156]"></p>
					</div>
				</section>

				<p id="settings-save-status" class="mt-6 min-h-[1.25rem] text-sm text-slate-600" role="status" aria-live="polite"
				></p>

				<div class="mt-2">
					<button
						type="submit"
						id="btn-save-settings"
						class="rounded-xl bg-[#6D28D9] px-8 py-2.5 text-sm font-semibold text-white shadow-md transition-colors duration-200 hover:bg-[#5b21b6] focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-[#6D28D9]"
					>
						Salvar
					</button>
				</div>
			</form>

			<section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8" aria-labelledby="seo-indexacao-heading">
				<div class="flex flex-wrap items-center justify-between gap-3">
					<h3 id="seo-indexacao-heading" class="text-lg font-semibold text-slate-900">SEO &amp; Indexação</h3>
					<span
						class="inline-flex items-center gap-1.5 rounded-full border border-emerald-200 bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-700"
						aria-label="Status de sitemap ativo"
					>
						<svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
							<path fill-rule="evenodd" d="M16.704 5.29a1 1 0 010 1.42l-8 8a1 1 0 01-1.42 0l-4-4a1 1 0 011.42-1.42L8 12.59l7.296-7.3a1 1 0 011.408 0z" clip-rule="evenodd" />
						</svg>
						Sitemap Ativo e Otimizado
					</span>
				</div>

				<div class="mt-5">
					<label for="field-sitemap-url" class="block text-sm font-medium text-slate-700">URL do Sitemap</label>
					<div class="mt-1.5 flex flex-col gap-2 sm:flex-row sm:items-center">
						<input
							id="field-sitemap-url"
							type="text"
							readonly
							value={sitemapUrl}
							class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2.5 text-sm text-slate-800 shadow-sm"
							aria-readonly="true"
						/>
						<button
							type="button"
							id="btn-copy-sitemap"
							class="inline-flex shrink-0 items-center justify-center gap-1.5 rounded-xl bg-[#6D28D9] px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-[#5b21b6] focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-[#6D28D9]"
						>
							<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
								<rect x="9" y="9" width="13" height="13" rx="2"></rect>
								<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
							</svg>
							Copiar Link
						</button>
					</div>
				</div>

				<div class="mt-5">
					<p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Links Úteis</p>
					<div class="mt-2 flex flex-wrap gap-2">
						<a
							id="link-view-sitemap"
							href={sitemapUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center gap-1.5 rounded-xl bg-[#6D28D9] px-3 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-[#5b21b6] focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-[#6D28D9]"
							aria-label="Abrir sitemap em nova aba"
						>
							<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
								<path d="M14 3h7v7"></path>
								<path d="M10 14L21 3"></path>
								<path d="M21 14v7h-7"></path>
								<path d="M3 10V3h7"></path>
							</svg>
							Abrir Sitemap
							<span class="text-[11px] font-medium text-violet-200">(nova aba)</span>
						</a>
						<a
							id="link-view-robots"
							href={robotsUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center gap-1.5 rounded-xl bg-[#6D28D9] px-3 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-[#5b21b6] focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-[#6D28D9]"
							aria-label="Abrir robots.txt em nova aba"
						>
							<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
								<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
								<path d="M14 2v6h6"></path>
								<path d="M8 13h8"></path>
								<path d="M8 17h5"></path>
							</svg>
							Abrir Robots.txt
							<span class="text-[11px] font-medium text-violet-200">(nova aba)</span>
						</a>
					</div>
				</div>
			</section>
		</div>
	</div>

	<script>
		import { actions } from 'astro:actions';
		import { uiStatusMessages } from '../../lib/ui-status-messages';

		const MEDIA_SETTINGS_CHANNEL = 'blogonauta-settings-media';

		const form = document.getElementById('form-settings') as HTMLFormElement | null;
		const fieldName = document.getElementById('field-site-name') as HTMLInputElement | null;
		const fieldUrl = document.getElementById('field-site-url') as HTMLInputElement | null;
		const fieldMeta = document.getElementById('field-meta-desc') as HTMLTextAreaElement | null;
		const fieldLogo = document.getElementById('field-logo-path') as HTMLInputElement | null;
		const fieldFav = document.getElementById('field-favicon-path') as HTMLInputElement | null;
		const previewLogo = document.getElementById('preview-logo') as HTMLImageElement | null;
		const previewFav = document.getElementById('preview-favicon') as HTMLImageElement | null;
		const serpFav = document.getElementById('serp-favicon') as HTMLImageElement | null;
		const serpSite = document.getElementById('serp-site-line');
		const serpUrlLine = document.getElementById('serp-url-line');
		const serpTitle = document.getElementById('serp-title');
		const serpDesc = document.getElementById('serp-desc');
		const metaCount = document.getElementById('meta-desc-count');
		const statusEl = document.getElementById('settings-save-status');
		const btnMediaLogo = document.getElementById('btn-open-media-logo');
		const btnMediaFav = document.getElementById('btn-open-media-favicon');
		const fieldSitemapUrl = document.getElementById('field-sitemap-url') as HTMLInputElement | null;
		const btnCopySitemap = document.getElementById('btn-copy-sitemap');
		const linkViewSitemap = document.getElementById('link-view-sitemap') as HTMLAnchorElement | null;
		const linkViewRobots = document.getElementById('link-view-robots') as HTMLAnchorElement | null;

		const bc =
			typeof BroadcastChannel !== 'undefined' ? new BroadcastChannel(MEDIA_SETTINGS_CHANNEL) : null;

		function setText(el: HTMLElement | null, text: string) {
			if (!el) return;
			el.textContent = text;
		}

		function displayPathForGoogle(urlStr: string): string {
			try {
				const u = new URL(urlStr);
				const path = u.pathname === '/' ? '' : u.pathname;
				return (u.hostname + path).replace(/^www\./, '');
			} catch {
				return urlStr;
			}
		}

		function buildSitemapUrl(baseUrl: string): string {
			const t = baseUrl.trim();
			if (!t) return '/sitemap-index.xml';
			try {
				return new URL('sitemap-index.xml', t.endsWith('/') ? t : `${t}/`).toString();
			} catch {
				return '/sitemap-index.xml';
			}
		}

		function syncSitemapUi() {
			const base = fieldUrl?.value ?? '';
			const sitemap = buildSitemapUrl(base);
			const robots = sitemap.replace(/sitemap-index\.xml$/i, 'robots.txt');
			if (fieldSitemapUrl) fieldSitemapUrl.value = sitemap;
			if (linkViewSitemap) linkViewSitemap.href = sitemap;
			if (linkViewRobots) linkViewRobots.href = robots;
		}

		function syncSerp() {
			const name = fieldName?.value?.trim() ?? '';
			const url = fieldUrl?.value?.trim() ?? '';
			const desc = fieldMeta?.value?.trim() ?? '';
			setText(serpSite, name || 'Nome do site');
			setText(serpUrlLine, url ? displayPathForGoogle(url) : 'www.exemplo.com/');
			setText(serpTitle, name || 'Título do site');
			setText(serpDesc, desc || 'A descrição do resultado aparece aqui.');
			if (serpFav && fieldFav?.value) serpFav.src = fieldFav.value;
		}

		function syncMetaCount() {
			if (metaCount && fieldMeta) metaCount.textContent = String(fieldMeta.value.length);
		}

		function setAssetPreview(which: 'logo' | 'favicon', path: string) {
			if (which === 'logo') {
				if (fieldLogo) fieldLogo.value = path;
				if (previewLogo) previewLogo.src = path;
			} else {
				if (fieldFav) fieldFav.value = path;
				if (previewFav) previewFav.src = path;
			}
			syncSerp();
			if (statusEl) {
				statusEl.textContent = 'Imagem selecionada na Central de Mídia.';
				statusEl.className = 'mt-6 min-h-[1.25rem] text-sm text-emerald-700';
			}
		}

		function openMediaCentral(target: 'logo' | 'favicon') {
			const u = `/admin/media?picker=1&for=${target}`;
			const width = 1200;
			const height = 820;
			const left = Math.max(0, Math.round(window.screenX + (window.outerWidth - width) / 2));
			const top = Math.max(0, Math.round(window.screenY + (window.outerHeight - height) / 2));
			const features =
				`popup=yes,width=${width},height=${height},left=${left},top=${top},` +
				'resizable=yes,scrollbars=yes,toolbar=no,menubar=no,location=no,status=no';
			const popup = window.open(u, 'mediaPickerWindow', features);
			if (!popup && statusEl) {
				statusEl.textContent =
					'O navegador bloqueou o popup. Permite popups para este domínio e tenta novamente.';
				statusEl.className = 'mt-6 min-h-[1.25rem] text-sm text-amber-700';
				return;
			}
			popup?.focus();
		}

		if (bc) {
			bc.addEventListener('message', (ev: MessageEvent) => {
				const d = ev.data;
				if (
					d &&
					typeof d === 'object' &&
					d.type === 'picked' &&
					typeof d.url === 'string' &&
					(d.target === 'logo' || d.target === 'favicon')
				) {
					setAssetPreview(d.target, d.url);
				}
			});
		}

		btnMediaLogo?.addEventListener('click', () => openMediaCentral('logo'));
		btnMediaFav?.addEventListener('click', () => openMediaCentral('favicon'));

		btnCopySitemap?.addEventListener('click', async () => {
			const url = fieldSitemapUrl?.value?.trim() || '';
			if (!url) return;
			try {
				await navigator.clipboard.writeText(url);
				if (statusEl) {
					statusEl.textContent = 'Link do sitemap copiado.';
					statusEl.className = 'mt-6 min-h-[1.25rem] text-sm text-emerald-700';
				}
			} catch {
				if (statusEl) {
					statusEl.textContent = 'Não foi possível copiar automaticamente. Copia manualmente o campo do sitemap.';
					statusEl.className = 'mt-6 min-h-[1.25rem] text-sm text-amber-700';
				}
			}
		});

		fieldName?.addEventListener('input', syncSerp);
		fieldUrl?.addEventListener('input', () => {
			syncSerp();
			syncSitemapUi();
		});
		fieldMeta?.addEventListener('input', () => {
			syncMetaCount();
			syncSerp();
		});

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			if (!fieldName || !fieldUrl || !fieldMeta || !fieldLogo || !fieldFav) return;
			const payload = {
				siteName: fieldName.value.trim(),
				siteUrl: fieldUrl.value.trim(),
				siteDescription: fieldMeta.value.trim(),
				logoPath: fieldLogo.value.trim(),
				faviconPath: fieldFav.value.trim(),
			};
			if (statusEl) {
				statusEl.textContent = uiStatusMessages.loading.saving;
				statusEl.className = 'mt-6 min-h-[1.25rem] text-sm text-slate-600';
			}
			const btn = document.getElementById('btn-save-settings') as HTMLButtonElement | null;
			if (btn) btn.disabled = true;
			try {
				const { data, error } = await actions.updateSettings(payload);
				if (error) {
					if (statusEl) {
						statusEl.textContent = error.message || 'Erro ao gravar.';
						statusEl.className = 'mt-6 min-h-[1.25rem] text-sm text-red-600';
					}
					return;
				}
				if (data?.ok && statusEl) {
					statusEl.textContent = uiStatusMessages.success.saved;
					statusEl.className = 'mt-6 min-h-[1.25rem] text-sm text-emerald-700';
					if ('config' in data && data.config?.siteUrl && fieldUrl) {
						fieldUrl.value = data.config.siteUrl;
						syncSerp();
						syncSitemapUi();
					}
				}
			} catch {
				if (statusEl) {
					statusEl.textContent = uiStatusMessages.error.saveGeneric;
					statusEl.className = 'mt-6 min-h-[1.25rem] text-sm text-red-600';
				}
			} finally {
				if (btn) btn.disabled = false;
			}
		});

		syncSerp();
		syncMetaCount();
		syncSitemapUi();
	</script>
</DashboardLayout>
