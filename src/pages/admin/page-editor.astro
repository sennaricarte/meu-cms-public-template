	<script is:inline define:vars={{ initialPayload }}>
		globalThis.__pageEditorInitialPayload = initialPayload;
	</script>

	<script>
		import { actions } from 'astro:actions';
		import { uiStatusMessages } from '../../lib/ui-status-messages';

		const SAFE_PAGES_REL_PATH_JS =
			/^(?:[a-zA-Z0-9_-]+\/)*[a-zA-Z0-9_-]+\.(?:md|mdx)$/;

		type PageEditorInitialPayload = {
			relativePath: string;
			slugBase: string;
			ext: '.md' | '.mdx';
			title: string;
			seoTitle?: string;
			description: string;
			draft: boolean;
			heroImage?: string;
			canonical?: string;
			body: string;
		};
		const initialPayloadRaw = (globalThis as Record<string, unknown>).__pageEditorInitialPayload;
		const initialPayload: PageEditorInitialPayload | null =
			initialPayloadRaw !== null &&
			initialPayloadRaw !== undefined &&
			typeof initialPayloadRaw === 'object'
				? (initialPayloadRaw as PageEditorInitialPayload)
				: null;

		const fileInput = document.querySelector('#image-upload');
		const previewContainer = document.querySelector('#preview-container');
		const imagePreview = document.querySelector('#image-preview');
		const heroHidden = document.querySelector('#heroImage-url');

		let currentRelativePath = initialPayload?.relativePath ?? null;
		let slugManuallyEdited = !!initialPayload;

		function slugifyTitle(raw: string): string {
			return raw
				.normalize('NFD')
				.replace(/\p{M}/gu, '')
				.toLowerCase()
				.replace(/[^a-z0-9]+/g, '-')
				.replace(/^-+|-+$/g, '')
				.slice(0, 80);
		}

		function updateSeoFieldCounts() {
			const seo = document.querySelector('#field-seo-title');
			const desc = document.querySelector('#field-description');
			const seoC = document.querySelector('#seo-title-count');
			const descC = document.querySelector('#meta-desc-count');
			if (seo instanceof HTMLInputElement && seoC) {
				seoC.textContent = `${seo.value.length} / 60`;
			}
			if (desc instanceof HTMLTextAreaElement && descC) {
				const n = desc.value.length;
				descC.textContent = `${n} / 160`;
				descC.classList.toggle('text-amber-700', n > 0 && n < 50);
				descC.classList.toggle('text-neutral-400', n === 0);
				descC.classList.toggle('text-neutral-500', n >= 50);
			}
			updateSeoIntelligence();
		}

		function normText(s: string): string {
			return s
				.toLowerCase()
				.normalize('NFD')
				.replace(/\p{M}/gu, '')
				.replace(/\s+/g, ' ')
				.trim();
		}

		function textIncludesKeyword(haystack: string, keyword: string): boolean {
			const k = normText(keyword);
			const h = normText(haystack);
			if (!k.length) return false;
			return h.includes(k);
		}

		function getFirstParagraphText(html: string): string {
			const tpl = document.createElement('template');
			tpl.innerHTML = html.trim();
			const p = tpl.content.querySelector('p');
			if (p) return (p.textContent ?? '').trim();
			const first = tpl.content.firstElementChild;
			return (first?.textContent ?? '').trim();
		}

		function bodyHasKeywordInH2OrH3(html: string, keyword: string): boolean {
			const tpl = document.createElement('template');
			tpl.innerHTML = html.trim();
			for (const el of tpl.content.querySelectorAll('h2, h3')) {
				if (textIncludesKeyword(el.textContent ?? '', keyword)) return true;
			}
			return false;
		}

		function allImagesHaveNonEmptyAlt(html: string): boolean {
			const tpl = document.createElement('template');
			tpl.innerHTML = html.trim();
			const imgs = tpl.content.querySelectorAll('img');
			if (imgs.length === 0) return true;
			for (const img of imgs) {
				const alt = img.getAttribute('alt');
				if (alt === null || !alt.trim()) return false;
			}
			return true;
		}

		function slugMatchesKeyword(slugRaw: string, keyword: string): boolean {
			const cleaned = slugRaw.replace(/\.(md|mdx)$/i, '');
			const slugFlat = normText(cleaned.replace(/[-/]/g, ' '));
			const words = normText(keyword)
				.split(/\s+/)
				.map((w) => w.trim())
				.filter(Boolean);
			if (!words.length) return false;
			return words.every((w) => slugFlat.includes(w));
		}

		/** Score para páginas estáticas: termo principal = título SEO ou título da página (sem campo «foco»). */
		function computeStaticPageSeoScore(input: {
			pageTitle: string;
			seoTitle: string;
			metaDescription: string;
			slug: string;
			bodyHtml: string;
		}): { score: number; missing: string[] } {
			const missing: string[] = [];
			let score = 0;
			const seoTrim = input.seoTitle.trim();
			const titleTrim = input.pageTitle.trim();
			const kw = seoTrim || titleTrim;
			const titleTagForSerp = seoTrim || titleTrim;

			const plain = stripHtmlToPlain(input.bodyHtml);
			const wordCount = plain.trim() ? plain.trim().split(/\s+/).filter(Boolean).length : 0;

			if (!kw.length) {
				missing.push('Preencha o título da página ou o título SEO para calcular o score completo.');
				if (wordCount <= 600) missing.push('Amplie o conteúdo para mais de 600 palavras.');
				if (!allImagesHaveNonEmptyAlt(input.bodyHtml)) {
					missing.push('Defina o atributo alt em todas as imagens do corpo.');
				}
				const descLen = input.metaDescription.trim().length;
				if (descLen < 50) missing.push('Complete a meta description (mín. 50 caracteres).');
				return { score: 0, missing };
			}

			if (titleTagForSerp.length >= 25 && titleTagForSerp.length <= 65) {
				score += 20;
			} else {
				missing.push('Ajuste o título SEO ou o título da página para ~25–65 caracteres (bom comprimento em SERP).');
			}

			const firstP = getFirstParagraphText(input.bodyHtml);
			if (firstP.length && textIncludesKeyword(firstP, kw)) {
				score += 10;
			} else {
				missing.push('Inclua o termo principal (do título) no primeiro parágrafo.');
			}

			if (bodyHasKeywordInH2OrH3(input.bodyHtml, kw)) {
				score += 10;
			} else {
				missing.push('Inclua o termo principal num título H2 ou H3.');
			}

			if (wordCount > 600) {
				score += 10;
			} else {
				missing.push('Escreva mais de 600 palavras no corpo da página.');
			}

			const desc = input.metaDescription.trim();
			if (desc.length >= 50 && textIncludesKeyword(desc, kw)) {
				score += 10;
			} else {
				if (desc.length < 50) {
					missing.push('Meta description com pelo menos 50 caracteres e com o termo principal.');
				} else {
					missing.push('Inclua o termo principal na meta description.');
				}
			}

			if (allImagesHaveNonEmptyAlt(input.bodyHtml)) {
				score += 20;
			} else {
				missing.push('Todas as imagens no corpo devem ter alt descritivo.');
			}

			if (slugMatchesKeyword(input.slug, kw)) {
				score += 20;
			} else {
				missing.push('Alinhe o slug (URL) com o termo principal (palavras-chave no caminho).');
			}

			return { score: Math.min(100, score), missing };
		}

		function updateSeoIntelligence() {
			const titleEl = document.querySelector('#field-title');
			const seoEl = document.querySelector('#field-seo-title');
			const descEl = document.querySelector('#field-description');
			const slugEl = document.querySelector('#field-slug');
			const src = document.querySelector('#wysiwyg-source-view');
			const ed = document.querySelector('#wysiwyg-editor');
			let bodyHtml = '';
			if (src instanceof HTMLTextAreaElement && !src.classList.contains('hidden')) {
				bodyHtml = src.value;
			} else if (ed instanceof HTMLElement) {
				bodyHtml = ed.innerHTML;
			}

			const { score, missing } = computeStaticPageSeoScore({
				pageTitle: titleEl instanceof HTMLInputElement ? titleEl.value : '',
				seoTitle: seoEl instanceof HTMLInputElement ? seoEl.value : '',
				metaDescription: descEl instanceof HTMLTextAreaElement ? descEl.value : '',
				slug: slugEl instanceof HTMLInputElement ? slugEl.value : '',
				bodyHtml,
			});

			const dial = document.querySelector('#seo-score-dial');
			const bar = document.querySelector('#seo-score-bar');
			const labelEl = document.querySelector('#seo-score-label');
			const inline = document.querySelector('#seo-score-value-inline');
			const list = document.querySelector('#seo-score-checklist');

			if (dial) dial.textContent = String(score);

			if (bar instanceof HTMLElement) {
				bar.style.width = `${score}%`;
				bar.className =
					'h-full rounded-full transition-[width] duration-300 ease-out ' +
					(score < 50 ? 'bg-red-500' : score < 80 ? 'bg-amber-400' : 'bg-emerald-600');
			}

			if (labelEl) {
				labelEl.textContent =
					score < 50 ? 'Fraco' : score < 80 ? 'Razoável' : score < 100 ? 'Bom' : 'Excelente';
				labelEl.className =
					'text-xs font-semibold ' +
					(score < 50 ? 'text-red-600' : score < 80 ? 'text-amber-700' : 'text-emerald-700');
			}

			if (inline) inline.textContent = `${score} / 100`;

			if (list instanceof HTMLUListElement) {
				list.replaceChildren();
				if (missing.length === 0) {
					const li = document.createElement('li');
					li.className = 'list-none -ml-4 text-emerald-800 font-medium';
					li.textContent = '✓ Todos os critérios analisados estão cumpridos.';
					list.appendChild(li);
				} else {
					for (const msg of missing) {
						const li = document.createElement('li');
						li.textContent = msg;
						list.appendChild(li);
					}
				}
			}
		}

		/** Markdown/texto simples → HTML mínimo para o contenteditable; HTML existente mantém-se. */
		function bodyToHtml(body: string): string {
			const t = body.replace(/^\uFEFF/, '').trimEnd();
			if (!t) return '<p><br></p>';
			if (/^\s*</.test(t)) return t;
			return t
				.split(/\n\n+/)
				.map((block) => `<p>${block.split(/\n/).join('<br>')}</p>`)
				.join('');
		}

		function getWysiwygEls() {
			const ed = document.querySelector('#wysiwyg-editor');
			const ta = document.querySelector('#field-content');
			return {
				editor: ed instanceof HTMLElement ? ed : null,
				textarea: ta instanceof HTMLTextAreaElement ? ta : null,
			};
		}

		function syncWysiwygToTextarea() {
			const { editor, textarea } = getWysiwygEls();
			if (!(textarea instanceof HTMLTextAreaElement)) return;
			const sourceView = document.querySelector('#wysiwyg-source-view');
			if (sourceView instanceof HTMLTextAreaElement && !sourceView.classList.contains('hidden')) {
				textarea.value = sourceView.value;
			} else if (editor) {
				textarea.value = editor.innerHTML;
			}
		}

		function stripHtmlToPlain(html: string): string {
			const d = document.createElement('div');
			d.innerHTML = html;
			return (d.innerText ?? '').trim();
		}

		/** Tabela 3×3 com bordas visíveis (Tailwind); espelhada no bloco oculto do template para o JIT. */
		function buildTable3x3Markup(): string {
			let rows = '';
			for (let r = 0; r < 3; r++) {
				rows += '<tr>';
				for (let c = 0; c < 3; c++) {
					rows +=
						'<td class="border border-slate-300 p-2 min-w-[4rem] align-top">&nbsp;</td>';
				}
				rows += '</tr>';
			}
			return `<table class="border-collapse border-2 border-slate-400 w-full text-sm my-2"><tbody>${rows}</tbody></table>`;
		}

		function updateWysiwygMetrics() {
			const src = document.querySelector('#wysiwyg-source-view');
			const ed = document.querySelector('#wysiwyg-editor');
			let html = '';
			if (src instanceof HTMLTextAreaElement && !src.classList.contains('hidden')) {
				html = src.value;
			} else if (ed instanceof HTMLElement) {
				html = ed.innerHTML;
			}
			const plain = stripHtmlToPlain(html);
			const words = plain.trim() ? plain.trim().split(/\s+/).filter(Boolean).length : 0;
			const charCount = plain.length;
			const metricsEl = document.querySelector('#wysiwyg-seo-metrics');
			if (metricsEl) {
				metricsEl.textContent = `Palavras: ${words.toLocaleString('pt-BR')} | Caracteres: ${charCount.toLocaleString('pt-BR')}`;
			}
			updateSeoIntelligence();
		}

		function selectionAnchorInEditor(editor: HTMLElement): boolean {
			const sel = window.getSelection();
			if (!sel?.anchorNode) return false;
			return editor.contains(sel.anchorNode);
		}

		function clearToolbarFormatHighlight(toolbar: HTMLElement) {
			toolbar.querySelectorAll('.wysiwyg-btn-active').forEach((el) => el.classList.remove('wysiwyg-btn-active'));
		}

		function updateToolbarActiveStates() {
			const editor = document.querySelector('#wysiwyg-editor');
			const toolbar = document.querySelector('#wysiwyg-toolbar');
			const sourceView = document.querySelector('#wysiwyg-source-view');
			if (!(editor instanceof HTMLElement) || !(toolbar instanceof HTMLElement)) return;

			if (sourceView instanceof HTMLTextAreaElement && !sourceView.classList.contains('hidden')) {
				clearToolbarFormatHighlight(toolbar);
				return;
			}
			if (!selectionAnchorInEditor(editor)) {
				clearToolbarFormatHighlight(toolbar);
				return;
			}

			let format = '';
			try {
				format = String(document.queryCommandValue('formatBlock') ?? '')
					.replace(/[<>]/g, '')
					.trim()
					.toLowerCase();
			} catch {
				format = '';
			}

			toolbar.querySelectorAll('button[data-cmd="formatBlock"][data-value]').forEach((btn) => {
				if (!(btn instanceof HTMLButtonElement)) return;
				const val = btn.getAttribute('data-value')?.toLowerCase() ?? '';
				btn.classList.toggle('wysiwyg-btn-active', val === format);
			});

			try {
				const ulBtn = toolbar.querySelector('button[data-cmd="insertUnorderedList"]');
				const olBtn = toolbar.querySelector('button[data-cmd="insertOrderedList"]');
				const boldBtn = toolbar.querySelector('button[data-cmd="bold"]');
				if (ulBtn) ulBtn.classList.toggle('wysiwyg-btn-active', document.queryCommandState('insertUnorderedList'));
				if (olBtn) olBtn.classList.toggle('wysiwyg-btn-active', document.queryCommandState('insertOrderedList'));
				if (boldBtn) boldBtn.classList.toggle('wysiwyg-btn-active', document.queryCommandState('bold'));
			} catch {
				/* Safari / contexto sem comando */
			}
		}

		let toolbarSelectionRaf = 0;

		function sanitizePastedSubtree(node: Node, ownerDoc: Document): void {
			if (node.nodeType === Node.COMMENT_NODE) {
				node.parentNode?.removeChild(node);
				return;
			}
			if (node.nodeType === Node.TEXT_NODE) return;
			if (node.nodeType !== Node.ELEMENT_NODE) return;

			const el = node as HTMLElement;
			const tag = el.tagName;

			if (tag === 'SCRIPT' || tag === 'STYLE' || tag === 'LINK' || tag === 'META' || tag === 'TITLE') {
				el.remove();
				return;
			}

			el.removeAttribute('style');
			el.removeAttribute('class');
			el.removeAttribute('id');
			el.removeAttribute('lang');
			el.removeAttribute('dir');
			el.removeAttribute('face');
			el.removeAttribute('size');
			el.removeAttribute('color');
			el.removeAttribute('width');
			el.removeAttribute('height');
			el.removeAttribute('align');
			el.removeAttribute('valign');
			el.removeAttribute('bgcolor');
			el.removeAttribute('cellpadding');
			el.removeAttribute('cellspacing');
			el.removeAttribute('border');

			if (el.tagName === 'A') {
				const href = el.getAttribute('href');
				if (href && /^javascript:/i.test(href.trim())) {
					el.removeAttribute('href');
				}
			}

			if (tag === 'FONT') {
				const span = ownerDoc.createElement('span');
				while (el.firstChild) span.appendChild(el.firstChild);
				el.parentNode?.replaceChild(span, el);
				Array.from(span.childNodes).forEach((ch) => sanitizePastedSubtree(ch, ownerDoc));
				return;
			}

			Array.from(el.childNodes).forEach((ch) => sanitizePastedSubtree(ch, ownerDoc));
		}

		/**
		 * Quebras duplas em nós de texto → vários <p> (respeita células de tabela).
		 * Quebras simples dentro do parágrafo viram <br>.
		 */
		function convertDoubleNewlinesInTextNodes(root: HTMLElement): void {
			const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
				acceptNode(text: Node) {
					let p = text.parentElement;
					while (p) {
						if (p.tagName === 'SCRIPT' || p.tagName === 'STYLE') {
							return NodeFilter.FILTER_REJECT;
						}
						p = p.parentElement;
					}
					if (!/\n\n/.test(text.textContent ?? '')) return NodeFilter.FILTER_REJECT;
					return NodeFilter.FILTER_ACCEPT;
				},
			});

			const toSplit: Text[] = [];
			let w: Node | null;
			while ((w = walker.nextNode())) {
				toSplit.push(w as Text);
			}

			for (const textNode of toSplit) {
				const raw = textNode.data;
				if (!/\n\n/.test(raw)) continue;
				const parent = textNode.parentNode;
				if (!parent) continue;
				const doc = textNode.ownerDocument;
				const blocks = raw.split(/\n\n+/);
				const fragment = doc.createDocumentFragment();
				for (const block of blocks) {
					const p = doc.createElement('p');
					const lines = block.split('\n');
					lines.forEach((line, i) => {
						if (i > 0) p.appendChild(doc.createElement('br'));
						if (line.length) p.appendChild(doc.createTextNode(line));
					});
					if (!p.childNodes.length) p.appendChild(doc.createElement('br'));
					fragment.appendChild(p);
				}
				parent.replaceChild(fragment, textNode);
			}
		}

		function skipEmptyTextNodes(node: ChildNode | null): ChildNode | null {
			let n = node;
			while (
				n &&
				n.nodeType === Node.TEXT_NODE &&
				!(n as Text).data.replace(/\u00a0/g, ' ').trim()
			) {
				n = n.nextSibling;
			}
			return n;
		}

		/** Colapsa pares &lt;br&gt;&lt;br&gt; (ex.: Word/Docs) num novo &lt;p&gt;; estrutura de tabela mantém-se. */
		function convertDoubleBrToParagraphs(root: HTMLElement): void {
			const doc = root.ownerDocument;
			let progress = true;
			while (progress) {
				progress = false;
				const brs = Array.from(root.getElementsByTagName('br'));
				for (const br1 of brs) {
					const afterFirst = skipEmptyTextNodes(br1.nextSibling);
					if (!afterFirst || afterFirst.nodeName !== 'BR') continue;

					const br2 = afterFirst as HTMLBRElement;
					const parent = br1.parentNode;
					if (!parent) continue;

					progress = true;
					const newP = doc.createElement('p');
					let cur: ChildNode | null = br2.nextSibling;
					br1.remove();
					br2.remove();
					parent.insertBefore(newP, cur);

					while (cur) {
						const next = cur.nextSibling;
						if (cur.nodeName === 'BR') {
							const afterBr = skipEmptyTextNodes(cur.nextSibling);
							if (afterBr?.nodeName === 'BR') break;
						}
						newP.appendChild(cur);
						cur = next;
					}
					break;
				}
			}
		}

		function buildPasteFragmentFromHtml(html: string): DocumentFragment {
			const parsed = new DOMParser().parseFromString(html, 'text/html');
			sanitizePastedSubtree(parsed.body, parsed);
			convertDoubleNewlinesInTextNodes(parsed.body);
			convertDoubleBrToParagraphs(parsed.body);

			const frag = document.createDocumentFragment();
			while (parsed.body.firstChild) {
				frag.appendChild(parsed.body.firstChild);
			}
			return frag;
		}

		function insertFragmentAtSelection(editor: HTMLElement, fragment: DocumentFragment) {
			const sel = window.getSelection();
			if (!sel || sel.rangeCount === 0) return;
			const range = sel.getRangeAt(0);
			if (!editor.contains(range.commonAncestorContainer) && editor !== range.commonAncestorContainer) {
				range.selectNodeContents(editor);
				range.collapse(false);
			}
			range.deleteContents();
			const last = fragment.lastChild;
			range.insertNode(fragment);
			if (last) {
				range.setStartAfter(last);
				range.collapse(true);
				sel.removeAllRanges();
				sel.addRange(range);
			}
			syncWysiwygToTextarea();
			updateWysiwygMetrics();
		}

		function parseYouTubeId(raw: string): string | null {
			const t = raw.trim();
			if (!t) return null;
			let m = /youtu\.be\/([a-zA-Z0-9_-]{11})\b/.exec(t);
			if (m) return m[1];
			m = /[?&]v=([a-zA-Z0-9_-]{11})\b/.exec(t);
			if (m) return m[1];
			m = /youtube\.com\/embed\/([a-zA-Z0-9_-]{11})\b/.exec(t);
			if (m) return m[1];
			m = /youtube\.com\/shorts\/([a-zA-Z0-9_-]{11})\b/.exec(t);
			if (m) return m[1];
			return null;
		}

		function rangeInsideEditor(editor: HTMLElement, range: Range): boolean {
			const root = range.commonAncestorContainer;
			return editor === root || editor.contains(root);
		}

		function escapeHtmlAttr(s: string): string {
			return s
				.replace(/&/g, '&amp;')
				.replace(/"/g, '&quot;')
				.replace(/</g, '&lt;');
		}

		function findAnchorAtSelection(editor: HTMLElement): HTMLAnchorElement | null {
			const sel = window.getSelection();
			if (!sel?.anchorNode) return null;
			let n: Node | null = sel.anchorNode;
			if (n.nodeType === Node.TEXT_NODE) n = n.parentNode;
			let el: Element | null = n instanceof Element ? n : null;
			while (el && el !== editor) {
				if (el.tagName === 'A') return el as HTMLAnchorElement;
				el = el.parentElement;
			}
			return null;
		}

		function applyLinkOptions(anchor: HTMLAnchorElement, nofollow: boolean, newTab: boolean) {
			const parts: string[] = [];
			if (nofollow) parts.push('nofollow');
			if (newTab) {
				anchor.target = '_blank';
				parts.push('noopener', 'noreferrer');
			} else {
				anchor.removeAttribute('target');
			}
			const rel = [...new Set(parts)].join(' ');
			if (rel) anchor.setAttribute('rel', rel);
			else anchor.removeAttribute('rel');
		}

		function insertHtmlAtCaret(editor: HTMLElement, html: string, saved: Range | null) {
			editor.focus();
			let range: Range;
			if (saved && rangeInsideEditor(editor, saved)) {
				range = saved.cloneRange();
			} else {
				range = document.createRange();
				range.selectNodeContents(editor);
				range.collapse(false);
			}
			const tpl = document.createElement('template');
			tpl.innerHTML = html.trim();
			const frag = tpl.content;
			const last = frag.lastChild;
			range.deleteContents();
			range.insertNode(frag);
			if (last?.isConnected) {
				range.setStartAfter(last);
				range.collapse(true);
				const sel = window.getSelection();
				sel?.removeAllRanges();
				sel?.addRange(range);
			}
			syncWysiwygToTextarea();
			updateWysiwygMetrics();
		}

		function initWysiwygToolbar() {
			const { editor, textarea } = getWysiwygEls();
			const toolbar = document.querySelector('#wysiwyg-toolbar');
			const colorInput = document.querySelector('#wysiwyg-fg-color');
			if (!editor || !textarea || !toolbar) return;

			let lastCaretRange: Range | null = null;

			function rememberCaret() {
				const sel = window.getSelection();
				if (!sel?.rangeCount) return;
				if (!editor.contains(sel.anchorNode) && editor !== sel.anchorNode) return;
				lastCaretRange = sel.getRangeAt(0).cloneRange();
			}

			editor.addEventListener('mouseup', rememberCaret);
			editor.addEventListener('keyup', rememberCaret);
			editor.addEventListener('input', () => {
				syncWysiwygToTextarea();
				updateWysiwygMetrics();
			});

			const btnYoutube = document.querySelector('#toolbar-insert-youtube');
			const btnMedia = document.querySelector('#toolbar-open-media');
			const mediaModal = document.querySelector('#media-modal');
			const mediaModalTitleEl = document.querySelector('#media-modal-title');
			const mediaModalClose = document.querySelector('#media-modal-close');
			const mediaGrid = document.querySelector('#media-modal-grid');
			const mediaLoading = document.querySelector('#media-modal-loading');
			const mediaEmpty = document.querySelector('#media-modal-empty');

			const MEDIA_MODAL_TITLE_DEFAULT = 'Imagens em /uploads';
			const MEDIA_MODAL_TITLE_HERO = 'Escolher imagem de destaque';
			let mediaModalPurpose: 'wysiwyg' | 'hero' = 'wysiwyg';

			function applyHeroFromLibrary(url: string, meta?: { alt?: string }) {
				if (heroHidden instanceof HTMLInputElement) heroHidden.value = url;
				if (imagePreview instanceof HTMLImageElement) {
					imagePreview.src = url;
					imagePreview.alt =
						meta?.alt?.trim() || 'Pré-visualização da imagem de destaque';
				}
				previewContainer?.classList.remove('hidden');
			}

			function openMediaModal(purpose: 'wysiwyg' | 'hero' = 'wysiwyg') {
				if (!(mediaModal instanceof HTMLElement)) return;
				mediaModalPurpose = purpose;
				if (mediaModalTitleEl instanceof HTMLElement) {
					mediaModalTitleEl.textContent =
						purpose === 'hero' ? MEDIA_MODAL_TITLE_HERO : MEDIA_MODAL_TITLE_DEFAULT;
				}
				mediaModal.classList.remove('hidden');
				mediaModal.setAttribute('aria-hidden', 'false');
				mediaModalClose?.focus();
				void loadMediaGrid();
			}

			function closeMediaModal() {
				if (!(mediaModal instanceof HTMLElement)) return;
				mediaModalPurpose = 'wysiwyg';
				if (mediaModalTitleEl instanceof HTMLElement) {
					mediaModalTitleEl.textContent = MEDIA_MODAL_TITLE_DEFAULT;
				}
				mediaModal.classList.add('hidden');
				mediaModal.setAttribute('aria-hidden', 'true');
				editor.focus();
			}

			async function loadMediaGrid() {
				if (
					!(mediaGrid instanceof HTMLElement) ||
					!(mediaLoading instanceof HTMLElement) ||
					!(mediaEmpty instanceof HTMLElement)
				) {
					return;
				}
				mediaGrid.classList.add('hidden');
				mediaEmpty.classList.add('hidden');
				mediaLoading.classList.remove('hidden');
				mediaGrid.replaceChildren();

				try {
					const res = await fetch('/api/list-uploads', { credentials: 'same-origin' });
					const data = (await res.json()) as {
						images?: { url: string; name: string; alt?: string; title?: string }[];
						error?: string;
					};
					mediaLoading.classList.add('hidden');
					if (!res.ok) {
						mediaEmpty.textContent = data.error ?? 'Não foi possível listar as imagens.';
						mediaEmpty.classList.remove('hidden');
						return;
					}
					const images = data.images ?? [];
					if (!images.length) {
						mediaEmpty.classList.remove('hidden');
						return;
					}
					mediaGrid.classList.remove('hidden');
					for (const row of images) {
						const { url, name } = row;
						const btn = document.createElement('button');
						btn.type = 'button';
						btn.className =
							'relative aspect-square rounded-lg overflow-hidden border border-neutral-200 hover:border-blue-500 focus:outline focus:outline-2 focus:outline-blue-600 bg-neutral-50 group';
						btn.setAttribute(
							'aria-label',
							mediaModalPurpose === 'hero'
								? `Usar como imagem de destaque: ${name}`
								: `Inserir imagem ${name}`,
						);
						const img = document.createElement('img');
						img.src = url;
						img.alt = '';
						img.loading = 'lazy';
						img.decoding = 'async';
						img.className = 'w-full h-full object-cover';
						btn.appendChild(img);
						btn.addEventListener('click', () => {
							if (mediaModalPurpose === 'hero') {
								applyHeroFromLibrary(url, row);
								closeMediaModal();
								return;
							}
							const dot = name.lastIndexOf('.');
							const fallbackAlt = dot > 0 ? name.slice(0, dot) : name;
							const altText = row.alt?.trim() || fallbackAlt;
							const titleAttr = row.title?.trim();
							const titlePart = titleAttr ? ` title="${escapeHtmlAttr(titleAttr)}"` : '';
							const block = `<p><img class="wysiwyg-inserted-img" src="${escapeHtmlAttr(url)}" alt="${escapeHtmlAttr(altText)}"${titlePart} loading="lazy" decoding="async" /></p>`;
							insertHtmlAtCaret(editor, block, lastCaretRange);
							closeMediaModal();
						});
						mediaGrid.appendChild(btn);
					}
				} catch {
					mediaLoading.classList.add('hidden');
					mediaEmpty.textContent = uiStatusMessages.error.loadImages;
					mediaEmpty.classList.remove('hidden');
				}
			}

			/** iframes via innerHTML são eliminados em contenteditable — DOM + modo HTML. */
			function insertYoutubeEmbed(videoId: string) {
				const embedUrl = `https://www.youtube-nocookie.com/embed/${videoId}`;
				const htmlBlock = `<figure class="wysiwyg-youtube-embed" contenteditable="false" data-youtube-id="${videoId}"><div class="wysiwyg-youtube-inner"><iframe src="${embedUrl}" title="YouTube" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen loading="lazy" referrerpolicy="strict-origin-when-cross-origin"></iframe></div></figure><p><br></p>`;

				const sourceView = document.querySelector('#wysiwyg-source-view');
				if (sourceView instanceof HTMLTextAreaElement && !sourceView.classList.contains('hidden')) {
					const start = sourceView.selectionStart ?? sourceView.value.length;
					const end = sourceView.selectionEnd ?? start;
					const before = sourceView.value.slice(0, start);
					const after = sourceView.value.slice(end);
					sourceView.value = before + htmlBlock + after;
					const pos = start + htmlBlock.length;
					sourceView.selectionStart = sourceView.selectionEnd = pos;
					sourceView.focus();
					syncWysiwygToTextarea();
					updateWysiwygMetrics();
					return;
				}

				editor.focus();
				let range: Range;
				if (lastCaretRange && rangeInsideEditor(editor, lastCaretRange)) {
					range = lastCaretRange.cloneRange();
				} else {
					range = document.createRange();
					range.selectNodeContents(editor);
					range.collapse(false);
				}

				const figure = document.createElement('figure');
				figure.className = 'wysiwyg-youtube-embed';
				figure.setAttribute('contenteditable', 'false');
				figure.dataset.youtubeId = videoId;

				const inner = document.createElement('div');
				inner.className = 'wysiwyg-youtube-inner';

				const iframe = document.createElement('iframe');
				iframe.src = embedUrl;
				iframe.title = 'YouTube';
				iframe.setAttribute(
					'allow',
					'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share',
				);
				iframe.setAttribute('allowfullscreen', '');
				iframe.loading = 'lazy';
				iframe.setAttribute('referrerpolicy', 'strict-origin-when-cross-origin');

				inner.appendChild(iframe);
				figure.appendChild(inner);

				const tail = document.createElement('p');
				tail.innerHTML = '<br>';

				const frag = document.createDocumentFragment();
				frag.appendChild(figure);
				frag.appendChild(tail);

				range.deleteContents();
				range.insertNode(frag);

				if (tail.parentNode) {
					range.setStart(tail, 0);
					range.collapse(true);
					const sel = window.getSelection();
					sel?.removeAllRanges();
					sel?.addRange(range);
				}

				syncWysiwygToTextarea();
				updateWysiwygMetrics();
			}

			btnYoutube?.addEventListener('mousedown', () => {
				rememberCaret();
			});
			btnYoutube?.addEventListener('click', (e) => {
				e.preventDefault();
				const url = window.prompt('URL do vídeo (YouTube):', 'https://www.youtube.com/watch?v=');
				if (url == null) return;
				const id = parseYouTubeId(url);
				if (!id) {
					window.alert('URL do YouTube inválida. Use um link de um vídeo (watch, youtu.be, embed ou Shorts).');
					return;
				}
				insertYoutubeEmbed(id);
			});

			btnMedia?.addEventListener('mousedown', () => {
				rememberCaret();
			});
			btnMedia?.addEventListener('click', (e) => {
				e.preventDefault();
				openMediaModal('wysiwyg');
			});

			document.querySelector('#hero-open-media')?.addEventListener('click', (e) => {
				e.preventDefault();
				openMediaModal('hero');
			});

			mediaModalClose?.addEventListener('click', () => closeMediaModal());
			mediaModal?.addEventListener('click', (e) => {
				if (e.target === mediaModal) closeMediaModal();
			});

			const linkModal = document.querySelector('#link-modal');
			const linkForm = document.querySelector('#link-modal-form');
			const linkHrefInput = document.querySelector('#link-modal-href');
			const linkNofollowInput = document.querySelector('#link-modal-nofollow');
			const linkNewtabInput = document.querySelector('#link-modal-newtab');

			function closeLinkModal() {
				if (!(linkModal instanceof HTMLElement)) return;
				linkModal.classList.add('hidden');
				linkModal.setAttribute('aria-hidden', 'true');
				editor.focus();
			}

			function openLinkModal() {
				if (!(linkModal instanceof HTMLElement)) return;
				if (linkForm instanceof HTMLFormElement) linkForm.reset();
				const existing = findAnchorAtSelection(editor);
				if (existing?.getAttribute('href')) {
					if (linkHrefInput instanceof HTMLInputElement) linkHrefInput.value = existing.href;
					if (linkNofollowInput instanceof HTMLInputElement) {
						linkNofollowInput.checked = /\bnofollow\b/i.test(existing.getAttribute('rel') ?? '');
					}
					if (linkNewtabInput instanceof HTMLInputElement) {
						linkNewtabInput.checked = existing.target === '_blank';
					}
				} else if (linkHrefInput instanceof HTMLInputElement) {
					linkHrefInput.value = 'https://';
				}
				linkModal.classList.remove('hidden');
				linkModal.setAttribute('aria-hidden', 'false');
				linkHrefInput?.focus();
				if (linkHrefInput instanceof HTMLInputElement) linkHrefInput.select();
			}

			document.querySelector('#toolbar-insert-link')?.addEventListener('mousedown', rememberCaret);

			linkForm?.addEventListener('submit', (ev) => {
				ev.preventDefault();
				if (!(linkHrefInput instanceof HTMLInputElement)) return;
				const href = linkHrefInput.value.trim();
				if (!href) return;
				const nofollow = linkNofollowInput instanceof HTMLInputElement && linkNofollowInput.checked;
				const newTab = linkNewtabInput instanceof HTMLInputElement && linkNewtabInput.checked;

				editor.focus();
				if (lastCaretRange) {
					const sel = window.getSelection();
					sel?.removeAllRanges();
					sel?.addRange(lastCaretRange);
				}

				document.execCommand('createLink', false, href);
				const anchor = findAnchorAtSelection(editor);
				if (anchor) applyLinkOptions(anchor, nofollow, newTab);

				closeLinkModal();
				syncWysiwygToTextarea();
				updateWysiwygMetrics();
				updateToolbarActiveStates();
			});

			document.querySelector('#link-modal-cancel')?.addEventListener('click', () => closeLinkModal());
			linkModal?.addEventListener('click', (ev) => {
				if (ev.target === linkModal) closeLinkModal();
			});

			document.addEventListener('keydown', (e) => {
				if (e.key !== 'Escape') return;
				if (linkModal && !linkModal.classList.contains('hidden')) {
					closeLinkModal();
					return;
				}
				if (mediaModal && !mediaModal.classList.contains('hidden')) {
					closeMediaModal();
				}
			});

			editor.addEventListener('paste', (e: ClipboardEvent) => {
				e.preventDefault();
				const cd = e.clipboardData;
				if (!cd) return;

				const htmlRaw = cd.getData('text/html').trim();
				const plain = cd.getData('text/plain').replace(/\r\n/g, '\n');

				if (htmlRaw.length > 0) {
					const frag = buildPasteFragmentFromHtml(htmlRaw);
					insertFragmentAtSelection(editor, frag);
				} else {
					const html = bodyToHtml(plain);
					const wrap = document.createElement('div');
					wrap.innerHTML = html;
					const frag = document.createDocumentFragment();
					while (wrap.firstChild) frag.appendChild(wrap.firstChild);
					insertFragmentAtSelection(editor, frag);
				}
			});

			editor.addEventListener('input', () => {
				syncWysiwygToTextarea();
				updateWysiwygMetrics();
			});
			editor.addEventListener('blur', syncWysiwygToTextarea);

			const btnInsertTable = document.querySelector('#toolbar-insert-table');
			btnInsertTable?.addEventListener('mousedown', rememberCaret);

			toolbar.addEventListener('click', (e) => {
				const t = e.target;
				if (!(t instanceof HTMLElement)) return;
				const btn = t.closest('button[data-cmd]');
				if (!(btn instanceof HTMLButtonElement)) return;
				e.preventDefault();
				const cmd = btn.getAttribute('data-cmd');
				const value = btn.getAttribute('data-value');

				if (cmd === 'createLink') {
					openLinkModal();
					return;
				}

				editor.focus();

				if (cmd === 'formatBlock' && value) {
					document.execCommand('formatBlock', false, value);
				} else if (cmd === 'insertUnorderedList') {
					document.execCommand('insertUnorderedList', false);
				} else if (cmd === 'insertOrderedList') {
					document.execCommand('insertOrderedList', false);
				} else if (cmd === 'insertTable') {
					document.execCommand('insertHTML', false, buildTable3x3Markup());
				} else if (cmd === 'bold') {
					document.execCommand('bold', false);
				} else if (cmd === 'removeFormat') {
					document.execCommand('removeFormat', false);
					document.execCommand('unlink', false);
				}
				syncWysiwygToTextarea();
				updateWysiwygMetrics();
				updateToolbarActiveStates();
			});

			if (colorInput instanceof HTMLInputElement) {
				colorInput.addEventListener('input', () => {
					editor.focus();
					document.execCommand('foreColor', false, colorInput.value);
					syncWysiwygToTextarea();
					updateWysiwygMetrics();
					updateToolbarActiveStates();
				});
			}

			const sourceView = document.querySelector('#wysiwyg-source-view');
			const btnToggleSource = document.querySelector('#toolbar-toggle-source');

			sourceView?.addEventListener('input', () => {
				syncWysiwygToTextarea();
				updateWysiwygMetrics();
			});

			btnToggleSource?.addEventListener('click', () => {
				if (!(sourceView instanceof HTMLTextAreaElement) || !(btnToggleSource instanceof HTMLButtonElement)) return;

				const inSourceMode = !sourceView.classList.contains('hidden');

				if (inSourceMode) {
					editor.innerHTML = sourceView.value;
					sourceView.classList.add('hidden');
					sourceView.setAttribute('aria-hidden', 'true');
					editor.classList.remove('hidden');
					editor.removeAttribute('aria-hidden');
					toolbar.classList.remove('wysiwyg-toolbar--source');
					btnToggleSource.textContent = 'HTML';
					btnToggleSource.setAttribute('aria-pressed', 'false');
					editor.focus();
				} else {
					sourceView.value = editor.innerHTML;
					sourceView.classList.remove('hidden');
					sourceView.removeAttribute('aria-hidden');
					editor.classList.add('hidden');
					editor.setAttribute('aria-hidden', 'true');
					toolbar.classList.add('wysiwyg-toolbar--source');
					btnToggleSource.textContent = 'Edição visual';
					btnToggleSource.setAttribute('aria-pressed', 'true');
					sourceView.focus();
				}
				syncWysiwygToTextarea();
				updateWysiwygMetrics();
				updateToolbarActiveStates();
			});

			document.addEventListener('selectionchange', () => {
				cancelAnimationFrame(toolbarSelectionRaf);
				toolbarSelectionRaf = requestAnimationFrame(() => updateToolbarActiveStates());
			});

			syncWysiwygToTextarea();
			updateWysiwygMetrics();
			updateToolbarActiveStates();
		}

		function fillFromInitial() {
			if (!initialPayload) return;
			const m = initialPayload;
			const titleEl = document.querySelector('#field-title');
			const slugEl = document.querySelector('#field-slug');
			const descEl = document.querySelector('#field-description');
			const canonicalEl = document.querySelector('#field-canonical');
			const draftEl = document.querySelector('#field-draft');
			const contentEl = document.querySelector('#field-content');
			const wysiwyg = document.querySelector('#wysiwyg-editor');
			const extEl = document.querySelector('#field-page-ext');
			const slugExtHint = document.querySelector('#slug-ext-hint');

			if (titleEl instanceof HTMLInputElement) titleEl.value = m.title;
			const seoEl = document.querySelector('#field-seo-title');
			if (seoEl instanceof HTMLInputElement) seoEl.value = m.seoTitle ?? '';
			if (slugEl instanceof HTMLInputElement) slugEl.value = m.slugBase;
			if (descEl instanceof HTMLTextAreaElement) descEl.value = m.description;
			if (canonicalEl instanceof HTMLInputElement) canonicalEl.value = m.canonical ?? '';
			if (draftEl instanceof HTMLInputElement) draftEl.checked = m.draft;
			if (extEl instanceof HTMLInputElement) extEl.value = m.ext;
			if (slugExtHint) slugExtHint.textContent = m.ext;

			const html = bodyToHtml(m.body);
			if (wysiwyg instanceof HTMLElement && contentEl instanceof HTMLTextAreaElement) {
				wysiwyg.innerHTML = html;
				contentEl.value = html;
			} else if (contentEl instanceof HTMLTextAreaElement) {
				contentEl.value = m.body;
			}
			if (heroHidden instanceof HTMLInputElement && m.heroImage) {
				heroHidden.value = m.heroImage;
			}
			if (m.heroImage && imagePreview instanceof HTMLImageElement) {
				imagePreview.src = m.heroImage;
				previewContainer?.classList.remove('hidden');
			}
			updateWysiwygMetrics();
			updateSeoFieldCounts();
			updateToolbarActiveStates();
		}

		fillFromInitial();
		initWysiwygToolbar();

		const titleElBind = document.querySelector('#field-title');
		const slugElBind = document.querySelector('#field-slug');
		titleElBind?.addEventListener('input', () => {
			if (
				!slugManuallyEdited &&
				slugElBind instanceof HTMLInputElement &&
				titleElBind instanceof HTMLInputElement
			) {
				const s = slugifyTitle(titleElBind.value);
				if (s) slugElBind.value = s;
			}
			updateSeoIntelligence();
		});
		slugElBind?.addEventListener('input', () => {
			slugManuallyEdited = true;
			updateSeoIntelligence();
		});
		document.querySelector('#field-seo-title')?.addEventListener('input', updateSeoFieldCounts);
		document.querySelector('#field-description')?.addEventListener('input', updateSeoFieldCounts);
		updateSeoFieldCounts();

		fileInput?.addEventListener('change', async (e) => {
			const target = e.target;
			if (!(target instanceof HTMLInputElement) || !target.files?.length) return;
			const file = target.files[0];
			const formData = new FormData();
			formData.append('image', file);
			formData.append('title', document.querySelector('#field-title')?.value ?? file.name);

			try {
				const response = await fetch('/api/upload', {
					method: 'POST',
					body: formData,
					credentials: 'same-origin',
				});
				const data = await response.json();

				if (!response.ok) {
					alert(data.error ?? uiStatusMessages.error.upload);
					return;
				}

				if (data.url && heroHidden instanceof HTMLInputElement) {
					heroHidden.value = data.url;
				}
				if (data.url && imagePreview instanceof HTMLImageElement) {
					imagePreview.src = data.url;
				}
				previewContainer?.classList.remove('hidden');
			} catch (err) {
				alert(err instanceof Error ? err.message : uiStatusMessages.error.upload);
			}
		});

		function resetEditorAfterSave(options: { isNewPage: boolean }) {
			if (!options.isNewPage) return;

			const empty = '<p><br></p>';
			const { editor: ed, textarea: ta } = getWysiwygEls();
			if (ed) {
				ed.innerHTML = empty;
				ed.classList.remove('hidden');
				ed.removeAttribute('aria-hidden');
			}
			if (ta instanceof HTMLTextAreaElement) ta.value = empty;
			const srcReset = document.querySelector('#wysiwyg-source-view');
			if (srcReset instanceof HTMLTextAreaElement) {
				srcReset.value = empty;
				srcReset.classList.add('hidden');
				srcReset.setAttribute('aria-hidden', 'true');
			}
			const toolbarReset = document.querySelector('#wysiwyg-toolbar');
			toolbarReset?.classList.remove('wysiwyg-toolbar--source');
			const btnSrc = document.querySelector('#toolbar-toggle-source');
			if (btnSrc instanceof HTMLButtonElement) {
				btnSrc.textContent = 'HTML';
				btnSrc.setAttribute('aria-pressed', 'false');
			}
			updateWysiwygMetrics();

			const formEl = document.querySelector('#page-editor-form');
			if (formEl instanceof HTMLFormElement) {
				formEl.reset();
			}
			const extReset = document.querySelector('#field-page-ext');
			if (extReset instanceof HTMLInputElement) extReset.value = '.md';
			const slugExtHintReset = document.querySelector('#slug-ext-hint');
			if (slugExtHintReset) slugExtHintReset.textContent = '.md';
			const canonicalReset = document.querySelector('#field-canonical');
			if (canonicalReset instanceof HTMLInputElement) canonicalReset.value = '';
			const heroInput = document.querySelector('#heroImage-url');
			if (heroInput instanceof HTMLInputElement) heroInput.value = '';
			const previewContainerEl = document.querySelector('#preview-container');
			previewContainerEl?.classList.add('hidden');
			if (imagePreview instanceof HTMLImageElement) {
				imagePreview.removeAttribute('src');
			}
			if (fileInput instanceof HTMLInputElement) fileInput.value = '';
			const seoReset = document.querySelector('#field-seo-title');
			if (seoReset instanceof HTMLInputElement) seoReset.value = '';
			slugManuallyEdited = false;
			currentRelativePath = null;
			updateSeoFieldCounts();
		}

		function normalizePageSlugSegments(raw: string): string {
			let s = raw.trim().replace(/\\/g, '/').replace(/^\/+|\/+$/g, '');
			if (!s) return '';
			const withoutExt = s.replace(/\.(md|mdx)$/i, '');
			const parts = withoutExt.split('/').filter(Boolean);
			for (const p of parts) {
				if (!/^[\w-]+$/.test(p)) return '';
			}
			return parts.join('/');
		}

		const form = document.querySelector('#page-editor-form');
		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			if (!(form instanceof HTMLFormElement)) return;

			const { editor, textarea } = getWysiwygEls();
			const sourcePanel = document.querySelector('#wysiwyg-source-view');
			const htmlBody =
				sourcePanel instanceof HTMLTextAreaElement && !sourcePanel.classList.contains('hidden')
					? sourcePanel.value
					: (editor?.innerHTML ?? '');
			if (textarea instanceof HTMLTextAreaElement) {
				textarea.value = htmlBody;
			}

			const plain = stripHtmlToPlain(htmlBody);
			const hasEmbeddedMedia = /<(iframe|img|figure|video|table)\b/i.test(htmlBody);
			if (!plain && !hasEmbeddedMedia) {
				window.alert('O conteúdo da página é obrigatório.');
				if (sourcePanel instanceof HTMLTextAreaElement && !sourcePanel.classList.contains('hidden')) {
					sourcePanel.focus();
				} else {
					editor?.focus();
				}
				return;
			}

			const fd = new FormData(form);

			const slugRaw = (fd.get('slug') ?? '').toString().trim();
			const base = normalizePageSlugSegments(slugRaw);
			if (!base.length) {
				alert(
					'Defina um slug válido: segmentos com letras, números e hífens, separados por / (ex.: contactos ou legal/privacidade).',
				);
				return;
			}

			const extEl = document.querySelector('#field-page-ext');
			const ext =
				extEl instanceof HTMLInputElement && extEl.value.trim().toLowerCase() === '.mdx'
					? '.mdx'
					: '.md';
			const relativePath = `${base}${ext}`;

			if (!SAFE_PAGES_REL_PATH_JS.test(relativePath)) {
				alert('Caminho do ficheiro inválido. Verifique o slug e a extensão.');
				return;
			}

			const draftEl = document.querySelector('#field-draft');
			const draft = draftEl instanceof HTMLInputElement && draftEl.checked;

			const heroEl = document.querySelector('#heroImage-url');
			const heroImage =
				heroEl instanceof HTMLInputElement && heroEl.value.trim()
					? heroEl.value.trim()
					: undefined;

			const seoTitleRaw = (fd.get('seoTitle') ?? '').toString().trim();
			const canonicalEl = document.querySelector('#field-canonical');
			const canonicalRaw =
				canonicalEl instanceof HTMLInputElement ? canonicalEl.value.trim() : '';

			const { data, error } = await actions.saveStaticPage({
				relativePath,
				previousRelativePath:
					currentRelativePath && currentRelativePath !== relativePath
						? currentRelativePath
						: undefined,
				title: (fd.get('title') ?? '').toString().trim(),
				seoTitle: seoTitleRaw || undefined,
				description: (fd.get('description') ?? '').toString().trim(),
				draft,
				heroImage,
				canonical: canonicalRaw || undefined,
				body: htmlBody,
			});

			if (error) {
				alert(error.message);
				return;
			}
			currentRelativePath = data.relativePath;
			window.alert(uiStatusMessages.success.pageSaved(data.relativePath));
			resetEditorAfterSave({ isNewPage: !initialPayload });
		});
	</script>
</DashboardLayout>
