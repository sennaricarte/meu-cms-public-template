---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { SAFE_PAGES_REL_PATH } from './editor-server';
import { loadStaticPageForEditor } from '../../lib/pages-editor-load';
import { uiStatusMessages } from '../../lib/ui-status-messages';

export const prerender = false;

const fileParam = Astro.url.searchParams.get('file');
let initialPage = null as Awaited<ReturnType<typeof loadStaticPageForEditor>> | null;
let loadError: string | null = null;

if (fileParam) {
	if (!SAFE_PAGES_REL_PATH.test(fileParam)) {
		loadError = 'Parâmetro «file» inválido.';
	} else {
		try {
			initialPage = await loadStaticPageForEditor(fileParam);
		} catch {
			loadError = 'Não foi possível ler este ficheiro.';
		}
	}
}

const initialPayload = initialPage
	? {
			relativePath: initialPage.relativePath,
			slugBase: initialPage.relativePath.replace(/\.(md|mdx)$/i, ''),
			ext: initialPage.relativePath.toLowerCase().endsWith('.mdx') ? ('.mdx' as const) : ('.md' as const),
			title: initialPage.title,
			seoTitle: initialPage.seoTitle,
			description: initialPage.description,
			draft: initialPage.draft,
			heroImage: initialPage.heroImage,
			canonical: initialPage.canonical,
			body: initialPage.body,
		}
	: null;

const pageExtDefault =
	initialPage?.relativePath?.toLowerCase().endsWith('.mdx') === true ? '.mdx' : '.md';
---

<DashboardLayout
	title={initialPage ? 'Editar página' : 'Nova página'}
	heading={initialPage ? 'Editar página estática' : 'Nova página estática'}
	sectionTitle="Páginas estáticas"
	sectionActionLabel="Adicionar Novo"
	sectionActionHref="/admin/page-editor"
>
	<div class="space-y-6">
		{
			loadError && (
				<div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 shadow-sm" role="alert">
					{loadError}
				</div>
			)
		}
		<div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
			<p class="text-sm text-slate-600">
				O slug define o URL da página (ex.:
				<code class="text-xs text-slate-800">contatos</code> -> <code class="text-xs text-slate-800">/contatos/</code>,
				<code class="text-xs text-slate-800">legal/privacidade</code> -> <code class="text-xs text-slate-800">/legal/privacidade/</code>).
			</p>
		</div>

		<form id="page-editor-form" class="space-y-8">
			<input type="hidden" id="field-page-ext" value={pageExtDefault} />
			<div class="grid grid-cols-1 xl:grid-cols-[minmax(0,1fr)_minmax(18rem,22rem)] gap-8 items-start">
				<div class="min-w-0 space-y-6 rounded-xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
					<div>
						<label for="field-title" class="block font-medium text-neutral-800">Título da página</label>
						<p class="text-xs text-neutral-500 mt-0.5 mb-1">Aparece como H1 na página pública.</p>
						<input
							id="field-title"
							type="text"
							name="title"
							maxlength="60"
							required
							class="w-full border border-neutral-300 p-2 rounded bg-white"
							autocomplete="off"
						/>
					</div>

					<div class="flex items-center gap-2">
						<input id="field-draft" type="checkbox" name="draft" class="rounded border-neutral-300" />
						<label for="field-draft" class="font-medium text-neutral-800">Salvar como rascunho (draft)</label>
					</div>

					<!-- Upload de Imagem com Preview -->
					<div class="rounded-xl border-2 border-dashed border-slate-200 bg-slate-50/60 p-5 text-center">
						<p class="font-medium mb-1">Imagem de destaque</p>
						<p id="upload-hint" class="text-sm text-neutral-500 mb-3">
							Envie um ficheiro novo ou escolha uma imagem já na{' '}
							<a href="/admin/media" class="font-medium text-[#6D28D9] underline hover:text-[#5b21b6]"
								>Central de mídia</a
							>
							(WebP em <code class="text-xs bg-white px-1 rounded border border-neutral-200">public/uploads/</code>).
						</p>
						<div class="flex flex-col sm:flex-row gap-3 justify-center items-stretch sm:items-center mb-4">
							<label class="sr-only" for="image-upload">Carregar imagem do computador</label>
							<input
								id="image-upload"
								type="file"
								accept="image/jpeg,image/png,image/webp"
								class="text-sm text-left sm:flex-1 file:mr-3 file:rounded-lg file:border-0 file:bg-white file:px-3 file:py-2 file:text-sm file:font-medium file:text-neutral-800 hover:file:bg-neutral-50"
								aria-describedby="upload-hint"
							/>
							<button
								type="button"
								id="hero-open-media"
								class="rounded-xl border border-[#6D28D9]/30 bg-violet-50 px-4 py-2.5 text-sm font-semibold text-[#5b21b6] shadow-sm transition-colors hover:bg-violet-100 focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-[#6D28D9]"
							>
								Escolher da biblioteca
							</button>
						</div>
						<input type="hidden" name="heroImage" id="heroImage-url" value="" />
						<div id="preview-container" class="hidden">
							<img id="image-preview" src="" alt="Pré-visualização da imagem de destaque" class="max-h-48 mx-auto rounded" width="800" height="450" />
						</div>
					</div>

					<div>
						<label for="field-canonical" class="block font-medium text-neutral-800">URL canónica (opcional)</label>
						<input
							id="field-canonical"
							type="url"
							name="canonical"
							class="w-full border border-neutral-300 p-2 rounded bg-white text-sm"
							placeholder="https://..."
							autocomplete="off"
						/>
					</div>

			<!-- Área de Conteúdo — WYSIWYG nativo (document.execCommand) -->
			<div class="space-y-2">
				<span id="field-content-label" class="block font-medium">Conteúdo</span>
				<div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
					<div
						id="wysiwyg-toolbar"
						class="flex flex-wrap items-center gap-1 p-2 border-b border-neutral-200 bg-neutral-50"
						role="toolbar"
						aria-labelledby="field-content-label"
					>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="formatBlock"
							data-value="h1"
							aria-label="Título nível 1"
						>
							H1
						</button>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="formatBlock"
							data-value="h2"
							aria-label="Título nível 2"
						>
							H2
						</button>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="formatBlock"
							data-value="h3"
							aria-label="Título nível 3"
						>
							H3
						</button>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="formatBlock"
							data-value="h4"
							aria-label="Título nível 4"
						>
							H4
						</button>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="formatBlock"
							data-value="h5"
							aria-label="Título nível 5"
						>
							H5
						</button>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="formatBlock"
							data-value="h6"
							aria-label="Título nível 6"
						>
							H6
						</button>
						<span class="w-px h-6 bg-neutral-300 mx-0.5 self-center shrink-0" aria-hidden="true"></span>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="insertUnorderedList"
							aria-label="Lista com marcadores"
						>
							Marcadores
						</button>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="insertOrderedList"
							aria-label="Lista numerada"
						>
							Numerada
						</button>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="formatBlock"
							data-value="blockquote"
							aria-label="Citação"
						>
							Citação
						</button>
						<button
							type="button"
							id="toolbar-insert-table"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="insertTable"
							aria-label="Inserir tabela 3 por 3 com bordas"
						>
							Tabela
						</button>
						<span class="w-px h-6 bg-neutral-300 mx-0.5 self-center shrink-0" aria-hidden="true"></span>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="bold"
							aria-label="Negrito"
						>
							Negrito
						</button>
						<button
							type="button"
							id="toolbar-insert-link"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="createLink"
							aria-label="Inserir link"
						>
							Link
						</button>
						<label class="inline-flex items-center gap-1.5 px-1 text-xs font-medium text-neutral-600">
							<span aria-hidden="true">Cor</span>
							<input
								type="color"
								id="wysiwyg-fg-color"
								value="#0f172a"
								class="h-9 w-11 cursor-pointer rounded border border-neutral-300 bg-white p-0"
								aria-label="Cor do texto"
								title="Cor do texto"
							/>
						</label>
						<button
							type="button"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							data-cmd="removeFormat"
							aria-label="Limpar formatação"
						>
							Limpar formatação
						</button>
						<span class="w-px h-6 bg-neutral-300 mx-0.5 self-center shrink-0" aria-hidden="true"></span>
						<button
							type="button"
							id="toolbar-insert-youtube"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							aria-label="Inserir vídeo do YouTube"
						>
							Vídeo
						</button>
						<button
							type="button"
							id="toolbar-open-media"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							aria-label="Inserir imagem das uploads"
						>
							Mídia
						</button>
						<span class="w-px h-6 bg-neutral-300 mx-0.5 self-center shrink-0" aria-hidden="true"></span>
						<button
							type="button"
							id="toolbar-toggle-source"
							class="wysiwyg-btn px-2.5 py-1.5 text-xs font-semibold rounded border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus:outline focus:outline-2 focus:outline-offset-0 focus:outline-blue-600"
							aria-pressed="false"
							aria-label="Alternar entre edição visual e código HTML bruto"
						>
							HTML
						</button>
					</div>
					<div class="relative">
						<div
							id="wysiwyg-editor"
							contenteditable="true"
							lang="pt-br"
							class="wysiwyg-editor min-h-[20rem] max-h-[min(70vh,36rem)] overflow-y-auto p-3 text-sm text-neutral-800 leading-relaxed focus:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-blue-500"
							role="textbox"
							aria-multiline="true"
							aria-labelledby="field-content-label"
							spellcheck="false"
						></div>
						<label for="wysiwyg-source-view" class="sr-only">Código HTML do conteúdo</label>
						<textarea
							id="wysiwyg-source-view"
							class="hidden wysiwyg-source-view min-h-[20rem] max-h-[min(70vh,36rem)] w-full overflow-y-auto p-3 text-xs font-mono text-neutral-800 leading-relaxed border-0 focus:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-blue-500 resize-y"
							spellcheck="false"
							wrap="off"
							aria-hidden="true"
						></textarea>
					</div>
					<div
						id="wysiwyg-metrics-footer"
						class="flex flex-wrap items-center justify-between gap-2 px-3 py-2 border-t border-neutral-200 bg-neutral-50 text-xs text-neutral-600"
						aria-live="polite"
					>
						<span id="wysiwyg-seo-metrics" class="font-medium tabular-nums">Palavras: 0 | Caracteres: 0</span>
						<span class="text-neutral-400 hidden sm:inline">Texto visível (sem tags HTML)</span>
					</div>
				</div>
				<textarea id="field-content" name="content" required class="sr-only" tabindex="-1" aria-hidden="true"></textarea>
				<p class="text-sm text-neutral-500">
					Edição visual: o conteúdo HTML é guardado automaticamente no corpo da página.
				</p>
			</div>
			<style>
				.wysiwyg-editor h1 {
					font-size: 1.75rem;
					font-weight: 700;
					margin: 0.75rem 0 0.5rem;
				}
				.wysiwyg-editor h2 {
					font-size: 1.375rem;
					font-weight: 700;
					margin: 0.75rem 0 0.5rem;
				}
				.wysiwyg-editor h3 {
					font-size: 1.125rem;
					font-weight: 600;
					margin: 0.5rem 0 0.35rem;
				}
				.wysiwyg-editor h4 {
					font-size: 1.0625rem;
					font-weight: 600;
					margin: 0.45rem 0 0.3rem;
				}
				.wysiwyg-editor h5 {
					font-size: 1rem;
					font-weight: 600;
					margin: 0.4rem 0 0.28rem;
				}
				.wysiwyg-editor h6 {
					font-size: 0.9375rem;
					font-weight: 600;
					margin: 0.35rem 0 0.25rem;
					color: #334155;
				}
				.wysiwyg-editor a {
					color: #2563eb;
					text-decoration: underline;
				}
				.wysiwyg-editor p {
					margin: 0.35rem 0;
				}
				.wysiwyg-editor figure.wysiwyg-youtube-embed {
					display: block;
					width: 100%;
					max-width: 100%;
					margin: 1rem auto;
				}
				.wysiwyg-editor .wysiwyg-youtube-inner {
					position: relative;
					width: 100%;
					padding-bottom: 56.25%;
					height: 0;
					overflow: hidden;
					border-radius: 8px;
					background: #0f172a;
				}
				.wysiwyg-editor .wysiwyg-youtube-inner iframe {
					position: absolute;
					inset: 0;
					width: 100%;
					height: 100%;
					border: 0;
				}
				.wysiwyg-editor img.wysiwyg-inserted-img {
					max-width: 100%;
					height: auto;
					border-radius: 6px;
					vertical-align: middle;
				}
				#wysiwyg-toolbar.wysiwyg-toolbar--source .wysiwyg-btn:not(#toolbar-toggle-source),
				#wysiwyg-toolbar.wysiwyg-toolbar--source label {
					pointer-events: none;
					opacity: 0.45;
				}
				#wysiwyg-toolbar .wysiwyg-btn.wysiwyg-btn-active {
					background: #dbeafe;
					border-color: #2563eb;
					color: #1e40af;
					box-shadow: 0 0 0 1px #2563eb;
				}
				.wysiwyg-editor blockquote {
					margin: 0.75rem 0;
					padding: 0.5rem 0 0.5rem 1rem;
					border-left: 4px solid #cbd5e1;
					color: #475569;
					font-style: italic;
				}
				.wysiwyg-editor ul,
				.wysiwyg-editor ol {
					margin: 0.35rem 0;
					padding-left: 1.5rem;
				}
				.wysiwyg-editor li {
					margin: 0.15rem 0;
				}
			</style>
			<!-- Referência Tailwind para tabela 3×3 inserida por buildTable3x3Markup() -->
			<div class="hidden" aria-hidden="true">
				<table class="border-collapse border-2 border-slate-400 w-full text-sm my-2">
					<tbody>
						<tr>
							<td class="border border-slate-300 p-2 min-w-[4rem] align-top"></td>
							<td class="border border-slate-300 p-2 min-w-[4rem] align-top"></td>
							<td class="border border-slate-300 p-2 min-w-[4rem] align-top"></td>
						</tr>
						<tr>
							<td class="border border-slate-300 p-2 align-top"></td>
							<td class="border border-slate-300 p-2 align-top"></td>
							<td class="border border-slate-300 p-2 align-top"></td>
						</tr>
						<tr>
							<td class="border border-slate-300 p-2 align-top"></td>
							<td class="border border-slate-300 p-2 align-top"></td>
							<td class="border border-slate-300 p-2 align-top"></td>
						</tr>
					</tbody>
				</table>
			</div>

					<button
						type="submit"
						class="w-full rounded-xl bg-[#6D28D9] px-6 py-2.5 font-semibold text-white shadow-sm transition-colors duration-200 ease-out hover:bg-[#5b21b6] focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-[#6D28D9] sm:w-auto"
					>
						Guardar página
					</button>
				</div>

				<aside
					class="space-y-5 self-start rounded-xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6 xl:sticky xl:top-6"
					aria-labelledby="seo-aside-heading"
				>
					<h2 id="seo-aside-heading" class="border-b border-slate-200 pb-2 text-sm font-semibold text-neutral-900">
						Configurações de SEO
					</h2>
					<p class="text-xs text-neutral-600 leading-relaxed">
						O <strong class="font-semibold text-neutral-800">score SEO</strong> analisa o conteúdo usando como palavra-chave de referência o teu
						<strong class="font-semibold text-neutral-800">título SEO</strong> (se preenchido) ou o <strong class="font-semibold text-neutral-800">título da página</strong>.
					</p>

					<div>
						<label for="field-seo-title" class="block text-sm font-medium text-neutral-800">Título SEO (opcional)</label>
						<p class="text-xs text-neutral-500 mt-0.5 mb-1">
							Sobrescreve o título do separador e das pré-visualizações sociais. Se vazio, usa o título da página.
						</p>
						<input
							id="field-seo-title"
							type="text"
							name="seoTitle"
							maxlength="60"
							class="w-full border border-neutral-300 p-2 rounded text-sm bg-white"
							placeholder="Máx. 60 caracteres"
							autocomplete="off"
							aria-describedby="seo-title-count"
						/>
						<p id="seo-title-count" class="text-xs text-neutral-500 mt-1 tabular-nums" aria-live="polite">0 / 60</p>
					</div>

					<div>
						<label for="field-description" class="block text-sm font-medium text-neutral-800">Meta description</label>
						<textarea
							id="field-description"
							name="description"
							rows="4"
							minlength="50"
							maxlength="160"
							required
							class="w-full border border-neutral-300 p-2 rounded text-sm bg-white"
							aria-describedby="meta-desc-count"
						></textarea>
						<p id="meta-desc-count" class="text-xs text-neutral-500 mt-1 tabular-nums" aria-live="polite">0 / 160</p>
						<p class="text-xs text-neutral-500 mt-1">Recomendado: 50–160 caracteres (regra da collection).</p>
					</div>

					<div>
						<label for="field-slug" class="block text-sm font-medium text-neutral-800">Slug (URL)</label>
						<input
							id="field-slug"
							type="text"
							name="slug"
							required
							class="w-full border border-neutral-300 p-2 rounded text-sm bg-white"
							placeholder="ex: meu-novo-post"
							spellcheck="false"
							autocomplete="off"
							aria-describedby="slug-hint"
						/>
						<p id="slug-hint" class="text-xs text-neutral-500 mt-1">
