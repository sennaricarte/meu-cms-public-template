---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { listPagesForDashboard } from '../../lib/pages-admin-list';

export const prerender = false;

const pages = await listPagesForDashboard();
---

<DashboardLayout
	title="Páginas estáticas — Admin"
	heading="Páginas estáticas"
	sectionTitle="Conteúdo"
	sectionActionLabel="Adicionar Novo"
	sectionActionHref="/admin/page-editor"
>
	<div class="space-y-6">
		<div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
			<p class="text-sm text-slate-600">
				Gerencie aqui as páginas institucionais e seus URLs públicos.
			</p>
		</div>

		{
			pages.length === 0 ? (
				<div class="rounded-xl border border-dashed border-slate-200 bg-white p-12 text-center shadow-sm">
					<p class="mb-4 text-slate-600">Ainda não há ficheiros .md ou .mdx nesta pasta.</p>
					<a href="/admin/page-editor" class="font-medium text-violet-600 hover:text-violet-700 hover:underline">
						Criar a primeira página
					</a>
				</div>
			) : (
				<>
					<div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
						<label for="admin-page-search" class="block text-sm font-medium text-slate-800">Buscar por página</label>
						<input
							id="admin-page-search"
							type="search"
							class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-200"
							placeholder="Filtrar por título ou ficheiro..."
							autocomplete="off"
							aria-describedby="admin-page-search-feedback"
						/>
						<p id="admin-page-search-feedback" class="mt-2 text-xs text-slate-500" aria-live="polite">
							A mostrar {pages.length} de {pages.length} páginas.
						</p>
					</div>

					<div class="hidden overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm md:block">
						<table class="min-w-full text-left text-sm">
							<thead>
								<tr class="border-b border-slate-200 bg-slate-50">
									<th scope="col" class="px-6 py-5 text-xs font-semibold uppercase tracking-wider text-slate-800">
										Título
									</th>
									<th scope="col" class="px-6 py-5 text-xs font-semibold uppercase tracking-wider text-slate-800">
										Ficheiro
									</th>
									<th scope="col" class="w-32 px-6 py-5 text-xs font-semibold uppercase tracking-wider text-slate-800">
										Estado
									</th>
									<th scope="col" class="w-24 px-6 py-5 text-right text-xs font-semibold uppercase tracking-wider text-slate-800">
										Ações
									</th>
								</tr>
							</thead>
							<tbody class="divide-y divide-slate-100">
								{pages.map((row) => (
									<tr class="transition-colors hover:bg-slate-50/80" data-search-item data-search-text={`${row.title} ${row.relativePath}`.toLowerCase()}>
										<td class="px-6 py-7 align-middle font-medium text-slate-900">{row.title}</td>
										<td class="px-6 py-7 align-middle font-mono text-xs text-slate-600">{row.relativePath}</td>
										<td class="px-6 py-7 align-middle">
											{row.draft ? (
												<span class="inline-flex rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-800">
													Rascunho
												</span>
											) : (
												<span class="text-xs text-slate-500">Publicado</span>
											)}
										</td>
										<td class="px-6 py-7 align-middle">
											<div class="flex justify-end">
												<a
													href={'/admin/page-editor?file=' + encodeURIComponent(row.relativePath)}
													class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-slate-500 transition-colors hover:bg-violet-50 hover:text-violet-700 focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-violet-600"
													aria-label={'Editar «' + row.title + '»'}
													title="Editar"
												>
													<svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
														<path
															stroke-linecap="round"
															stroke-linejoin="round"
															d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10"
														/>
													</svg>
												</a>
											</div>
										</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>

					<ul class="space-y-3 md:hidden" role="list">
						{pages.map((row) => (
							<li class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm" data-search-item data-search-text={`${row.title} ${row.relativePath}`.toLowerCase()}>
								<div class="flex items-start justify-between gap-2">
									<div class="min-w-0 flex-1">
										<h2 class="font-semibold text-slate-900">{row.title}</h2>
										<p class="mt-1 font-mono text-xs text-slate-500">{row.relativePath}</p>
									</div>
									<a
										href={'/admin/page-editor?file=' + encodeURIComponent(row.relativePath)}
										class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg text-slate-500 hover:bg-violet-50 hover:text-violet-700 focus:outline focus:outline-2 focus:outline-violet-600"
										aria-label={'Editar «' + row.title + '»'}
									>
										<svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10"
											/>
										</svg>
									</a>
								</div>
								<div class="mt-3 border-t border-slate-100 pt-3">
									{row.draft ? (
										<span class="inline-flex rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-800">
											Rascunho
										</span>
									) : (
										<span class="text-xs text-slate-500">Publicado</span>
									)}
								</div>
							</li>
						))}
					</ul>
				</>
			)
		}
	</div>

	<script>
		const searchInput = document.querySelector('#admin-page-search');
		const searchFeedback = document.querySelector('#admin-page-search-feedback');
		const searchableItems = Array.from(document.querySelectorAll('[data-search-item]'));

		function normalizeSearch(text) {
			return text
				.toLowerCase()
				.normalize('NFD')
				.replace(/\p{M}/gu, '')
				.trim();
		}

		function applyPageSearchFilter() {
			if (!(searchInput instanceof HTMLInputElement)) return;
			const query = normalizeSearch(searchInput.value);
			let visibleCount = 0;

			searchableItems.forEach((item) => {
				if (!(item instanceof HTMLElement)) return;
				const raw = item.dataset.searchText ?? '';
				const normalized = normalizeSearch(raw);
				const visible = query.length === 0 || normalized.includes(query);
				item.classList.toggle('hidden', !visible);
				if (visible) visibleCount += 1;
			});

			if (searchFeedback instanceof HTMLElement) {
				searchFeedback.textContent = `A mostrar ${visibleCount} de ${pages.length} páginas.`;
			}
		}

		searchInput?.addEventListener('input', applyPageSearchFilter);
	</script>
</DashboardLayout>
