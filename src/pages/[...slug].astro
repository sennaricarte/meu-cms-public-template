---
/**
 * Páginas estáticas a partir de `src/content/pages/*.{md,mdx}`.
 * URLs não entram em conflito com `/blog`, `/admin`, `/api`, etc., porque essas rotas são mais específicas.
 */
export const prerender = true;

import { type CollectionEntry, getCollection, render } from 'astro:content';
import ContentPage from '../layouts/ContentPage.astro';

export async function getStaticPaths() {
	const docs = await getCollection('pages', ({ data }) => !data.draft);
	return docs.map((entry) => ({
		params: { slug: entry.id },
		props: entry,
	}));
}

type Props = CollectionEntry<'pages'>;

const entry = Astro.props;
const { Content } = await render(entry);
---

<ContentPage {...entry.data}>
	<Content />
</ContentPage>
