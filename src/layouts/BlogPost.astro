---
import { Image } from 'astro:assets';
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { readTags } from '../lib/taxonomy-data';

type Props = CollectionEntry<'blog'>['data'] & { slug?: string };

const {
	title,
	seoTitle,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags = [],
	author,
	canonical,
	slug,
} = Astro.props;

const knownTags = await readTags();
const slugByTagName = new Map(knownTags.map((t) => [t.name.trim(), t.slug]));

function slugifyTagLabel(raw: string): string {
	return raw
		.normalize('NFD')
		.replace(/\p{M}/gu, '')
		.toLowerCase()
		.replace(/[^a-z0-9]+/g, '-')
		.replace(/^-+|-+$/g, '')
		.slice(0, 80);
}

function tagArchiveUrl(tagLabel: string): string {
	const t = tagLabel.trim();
	const slug = slugByTagName.get(t) || slugifyTagLabel(t) || encodeURIComponent(t.toLowerCase());
	return `/blog/tags/${slug}/`;
}

/* ── Artigos relacionados por tags compartilhadas ─────────────────────────── */
const allPosts = await getCollection('blog');

const related = allPosts
	.filter((p) => !p.data.draft && p.id !== slug)
	.map((p) => ({
		post: p,
		score: p.data.tags?.filter((t) => tags.includes(t)).length ?? 0,
	}))
	.filter(({ score }) => score > 0)
	.sort((a, b) => b.score - a.score)
	.slice(0, 3)
	.map(({ post }) => post);
---

<html lang="pt-br">
	<head>
		<BaseHead
			title={title}
			seoTitle={seoTitle}
			description={description}
			image={heroImage}
			tags={tags}
			author={author}
			pubDate={pubDate}
			updatedDate={updatedDate}
			canonical={canonical}
		/>
	</head>

	<body class="bg-white antialiased">

		<!-- ═══════════════════════════════════════════════════════════════ -->
		<!-- BARRA DE PROGRESSO DE LEITURA                                   -->
		<!-- ═══════════════════════════════════════════════════════════════ -->
		<div
			id="reading-progress"
			role="progressbar"
			aria-valuenow="0"
			aria-valuemin="0"
			aria-valuemax="100"
			aria-label="Progresso de leitura do artigo"
			class="fixed top-0 left-0 z-[200] h-1 w-0 bg-[var(--accent)] transition-[width] duration-75 ease-out"
		></div>

		<Header />

		<main class="mx-auto w-full max-w-3xl px-4 py-10 sm:px-6 lg:py-14">
			<article aria-labelledby="post-title">

				<!-- ─── Hero image ────────────────────────────────────────── -->
				{heroImage && (
					<div class="mb-10 overflow-hidden rounded-2xl shadow-md">
						<Image
							src={heroImage}
							alt={title}
							width={1020}
							height={510}
							class="w-full object-cover"
						/>
					</div>
				)}

				<!-- ─── Cabeçalho do post ─────────────────────────────────── -->
				<header class="mb-10 border-b border-gray-100 pb-8 text-center">

					<!-- Tags -->
					{tags.length > 0 && (
						<nav class="mb-4 flex flex-wrap justify-center gap-2" aria-label="Tags do artigo">
							{tags.map((tag) => (
								<a
									href={tagArchiveUrl(tag)}
									class="rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-[var(--accent-dark)] transition-colors duration-200 hover:bg-[var(--accent)] hover:text-white"
									aria-label={`Ver todos os posts com a tag ${tag}`}
								>
									#{tag}
								</a>
							))}
						</nav>
					)}

					<!-- Título principal -->
					<h1
						id="post-title"
						class="mb-4 text-3xl font-extrabold leading-tight tracking-tight text-gray-900 sm:text-4xl lg:text-5xl"
					>
						{title}
					</h1>

					<!-- Descrição / lead -->
					<p class="mx-auto mb-6 max-w-2xl text-lg leading-relaxed text-gray-600">
						{description}
					</p>

					<!-- Meta: data, atualização e autor -->
					<div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-sm text-gray-600">
						<span class="inline-flex items-center gap-1.5">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
								<path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
							</svg>
							<FormattedDate date={pubDate} />
						</span>

						{updatedDate && (
							<span class="inline-flex items-center gap-1.5 italic">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
									<path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"></path>
								</svg>
								Atualizado em <FormattedDate date={updatedDate} />
							</span>
						)}

						{author && (
							<>
								<span aria-hidden="true" class="text-gray-200">|</span>
								<span class="inline-flex items-center gap-1.5">
									<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
										<path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path>
									</svg>
									<span aria-label={`Autor: ${author}`}>{author}</span>
								</span>
							</>
						)}
					</div>
				</header>

				<!-- ─── Conteúdo do artigo (typography plugin) ────────────── -->
				<div class="prose prose-lg mx-auto max-w-none
					prose-headings:font-bold prose-headings:tracking-tight
					prose-h2:mt-10 prose-h2:text-2xl
					prose-h3:mt-8 prose-h3:text-xl
					prose-a:font-medium prose-a:no-underline hover:prose-a:underline
					prose-blockquote:not-italic prose-blockquote:font-normal
					prose-img:rounded-xl prose-img:shadow-md
					prose-pre:rounded-xl prose-pre:text-sm
					prose-code:rounded prose-code:px-1.5 prose-code:py-0.5 prose-code:before:content-none prose-code:after:content-none
					prose-table:text-sm prose-th:font-semibold
				">
					<slot />
				</div>

			</article>

			<!-- ═══════════════════════════════════════════════════════════ -->
			<!-- ARTIGOS RELACIONADOS                                         -->
			<!-- ═══════════════════════════════════════════════════════════ -->
			{related.length > 0 && (
				<aside aria-labelledby="related-heading" class="mt-16 border-t border-gray-100 pt-12">

					<h2
						id="related-heading"
						class="mb-8 text-xs font-bold uppercase tracking-[0.15em] text-gray-600"
					>
						Artigos relacionados
					</h2>

					<ul class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3" role="list">
						{related.map((post) => {
							const sharedTags = post.data.tags?.filter((t) => tags.includes(t)) ?? [];
							return (
								<li>
									<a
										href={`/blog/${post.id}/`}
										class="group flex h-full flex-col overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--accent)]"
										aria-label={`Ler artigo relacionado: ${post.data.title}`}
									>
										<!-- Imagem do card -->
										{post.data.heroImage ? (
											<div class="aspect-video overflow-hidden bg-gray-100">
												<Image
													src={post.data.heroImage}
													alt={post.data.title}
													width={400}
													height={225}
													class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
												/>
											</div>
										) : (
											<div class="aspect-video bg-gradient-to-br from-blue-50 to-indigo-100" aria-hidden="true"></div>
										)}

										<div class="flex flex-1 flex-col p-5">
											<!-- Tags compartilhadas -->
											{sharedTags.length > 0 && (
												<div class="mb-2 flex flex-wrap gap-1" aria-label="Tags em comum">
													{sharedTags.slice(0, 2).map((tag) => (
														<span class="rounded-full bg-blue-100 px-2 py-0.5 text-xs font-semibold text-[var(--accent-dark)]">
															#{tag}
														</span>
													))}
												</div>
											)}

											<!-- Título -->
											<h3 class="mb-2 line-clamp-2 text-sm font-bold leading-snug text-gray-900 transition-colors duration-200 group-hover:text-[var(--accent)]">
												{post.data.title}
											</h3>

											<!-- Data -->
											<div class="mt-auto pt-3 text-xs text-gray-600">
												<FormattedDate date={post.data.pubDate} />
											</div>
										</div>
									</a>
								</li>
							);
						})}
					</ul>
				</aside>
			)}

		</main>

		<Footer />

		<!-- ═══════════════════════════════════════════════════════════════ -->
		<!-- SCRIPT DA BARRA DE PROGRESSO                                    -->
		<!-- Vanilla JS — zero dependências, executa após o DOM estar pronto -->
		<!-- ═══════════════════════════════════════════════════════════════ -->
		<script>
			const bar = document.getElementById('reading-progress') as HTMLElement | null;
			if (!bar) throw new Error('reading-progress element not found');

			function updateProgress(): void {
				const doc          = document.documentElement;
				const scrollTop    = doc.scrollTop || document.body.scrollTop;
				const scrollHeight = doc.scrollHeight - doc.clientHeight;
				const progress     = scrollHeight > 0
					? Math.min(100, Math.round((scrollTop / scrollHeight) * 1000) / 10)
					: 0;

				bar.style.width = `${progress}%`;
				bar.setAttribute('aria-valuenow', String(Math.round(progress)));
			}

			// Atualização eficiente via requestAnimationFrame (evita jank de scroll)
			let ticking = false;
			window.addEventListener('scroll', () => {
				if (!ticking) {
					requestAnimationFrame(() => {
						updateProgress();
						ticking = false;
					});
					ticking = true;
				}
			}, { passive: true });

			// Estado inicial
			updateProgress();
		</script>

	</body>
</html>
