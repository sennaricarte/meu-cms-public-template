---
/**
 * Layout para páginas da coleção `pages` (Markdown/MDX em src/content/pages).
 */
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'pages'>['data'];

const { title, seoTitle, description, heroImage, canonical, updatedDate } = Astro.props;
---

<html lang="pt-br">
	<head>
		<BaseHead
			title={title}
			seoTitle={seoTitle}
			description={description}
			image={heroImage}
			canonical={canonical}
		/>
	</head>

	<body class="bg-white antialiased">
		<Header />

		<main class="mx-auto w-full max-w-3xl px-4 py-10 sm:px-6 lg:py-14">
			<article aria-labelledby="page-title">
				<nav aria-label="Trilha" class="mb-6 text-sm text-gray-500">
					<a href="/" class="underline-offset-2 hover:text-[var(--accent)] hover:underline">Home</a>
					<span aria-hidden="true"> / </span>
					<span class="text-gray-800">{title}</span>
				</nav>

				{
					heroImage && (
						<div class="mb-10 overflow-hidden rounded-2xl shadow-md">
							<Image
								src={heroImage}
								alt={title}
								width={1020}
								height={510}
								class="w-full object-cover"
								format="webp"
								quality="mid"
							/>
						</div>
					)
				}

				<header class="mb-10 border-b border-gray-100 pb-8">
					<h1
						id="page-title"
						class="text-3xl font-extrabold tracking-tight text-gray-900 sm:text-4xl lg:text-5xl"
					>
						{title}
					</h1>
					<p class="mt-4 max-w-2xl text-lg leading-relaxed text-gray-500">{description}</p>
					{
						updatedDate && (
							<p class="mt-4 text-sm text-gray-400">
								Última atualização: <FormattedDate date={updatedDate} />
							</p>
						)
					}
				</header>

				<div
					class="prose prose-lg mx-auto max-w-none
					prose-headings:font-bold prose-headings:tracking-tight
					prose-h2:mt-10 prose-h2:text-2xl
					prose-h3:mt-8 prose-h3:text-xl
					prose-a:font-medium prose-a:no-underline hover:prose-a:underline
					prose-blockquote:not-italic prose-blockquote:font-normal
					prose-img:rounded-xl prose-img:shadow-md
					prose-pre:rounded-xl prose-pre:text-sm
					prose-code:rounded prose-code:px-1.5 prose-code:py-0.5 prose-code:before:content-none prose-code:after:content-none
					prose-table:text-sm prose-th:font-semibold"
				>
					<slot />
				</div>
			</article>
		</main>

		<Footer />
	</body>
</html>
