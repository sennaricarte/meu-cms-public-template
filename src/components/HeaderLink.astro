---
import type { HTMLAttributes } from 'astro/types';
import { isActiveNavLink } from '../lib/nav-active';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;
const isActive =
	typeof href === 'string' && isActiveNavLink(pathname, href, baseUrl);
---

<a
	href={href}
	aria-current={isActive ? 'page' : undefined}
	class:list={[
		'nav-link',
		'inline-flex items-center rounded-lg px-3 py-1.5 text-sm font-medium transition-all duration-200',
		isActive ? 'nav-link-active bg-blue-50 font-semibold text-[var(--accent)]' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900',
		className,
	]}
	{...props}
>
	<slot />
</a>
