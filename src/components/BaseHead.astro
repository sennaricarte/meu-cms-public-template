---
/**
 * BaseHead.astro
 * Componente de metadados SEO para ser usado dentro de <head>.
 *
 * Props obrigatórias:
 *   - title       Título da página (máx. 60 chars — limite das SERPs).
 *   - description Meta description (máx. 160 chars — limite das SERPs).
 *
 * Props opcionais (enriquecimento SEO):
 *   - image       Imagem para Open Graph e Twitter Card.
 *   - tags        Array de palavras-chave / categorias do post.
 *   - author      Nome do autor do conteúdo.
 *   - pubDate     Data de publicação do artigo.
 *   - updatedDate Data da última atualização.
 *   - canonical   URL canônica explícita (use quando o conteúdo tiver origem externa).
 *   - robots      Meta robots (ex.: noindex, follow).
 *   - ogImageSrc  URL absoluta ou caminho público para OG/Twitter (substitui `image`).
 */
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import { Font } from 'astro:assets';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import JsonLd from './JsonLd.astro';
import {
	buildWebSiteSchema,
	buildWebPageSchema,
	buildBlogPostingSchema,
	buildBreadcrumbSchema,
} from '../lib/schema';

interface Props {
	/** Título da página — fica dentro de <title> e das meta tags. Máx. 60 chars. */
	title: string;
	/** Se definido, substitui `title` apenas em &lt;title&gt;, OG e Twitter (título H1 continua `title`). */
	seoTitle?: string;
	/** Meta description exibida nas SERPs. Máx. 160 chars. */
	description: string;
	/** Imagem de capa usada no Open Graph e Twitter Card. */
	image?: ImageMetadata;
	/** Palavras-chave do post — geradas a partir do campo `tags` do frontmatter. */
	tags?: string[];
	/** Autor do conteúdo. */
	author?: string;
	/** Data de publicação — ativa metatags de artigo (article:published_time). */
	pubDate?: Date;
	/** Data de atualização — ativa article:modified_time. */
	updatedDate?: Date;
	/** URL canônica explícita. Quando omitida, é gerada automaticamente por Astro.site. */
	canonical?: string;
	/** Valor da meta `robots` (predefinição: index, follow). */
	robots?: string;
	/** Imagem OG/Twitter por URL ou caminho público (ex.: /uploads/capa.webp). */
	ogImageSrc?: string;
}

const {
	title,
	seoTitle,
	description,
	image = FallbackImage,
	tags = [],
	author,
	pubDate,
	updatedDate,
	canonical: canonicalProp,
	robots = 'index, follow',
	ogImageSrc,
} = Astro.props;

/* ─── URLs ───────────────────────────────────────────────────────────────── */
const canonicalURL = canonicalProp
	? new URL(canonicalProp)
	: new URL(Astro.url.pathname, Astro.site);

function resolveOgImageUrl(): string {
	const raw = ogImageSrc?.trim();
	if (raw) {
		if (/^https?:\/\//i.test(raw)) return raw;
		const path = raw.startsWith('/') ? raw : `/${raw}`;
		return new URL(path, Astro.site).toString();
	}
	return new URL(image.src, Astro.url).toString();
}

const ogImageURL = resolveOgImageUrl();

/* ─── Títulos e textos ───────────────────────────────────────────────────── */
const brandingTitle = seoTitle?.trim() ? seoTitle.trim() : title;
const pageTitle    = brandingTitle ? `${brandingTitle} | ${SITE_TITLE}` : SITE_TITLE;
const pageDesc     = description || SITE_DESCRIPTION;
const keywords     = tags.join(', ');

/* ─── Tipo Open Graph ────────────────────────────────────────────────────── */
const ogType = pubDate ? 'article' : 'website';

/* ─── Schema.org — nós do @graph ─────────────────────────────────────────── */
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';

const schemaNodes = [
	// WebSite: presente em todas as páginas — ativa Sitelinks Search Box.
	buildWebSiteSchema({
		siteUrl,
		siteName:    SITE_TITLE,
		description: SITE_DESCRIPTION,
	}),

	// WebPage: representa a página atual.
	buildWebPageSchema({
		url:         canonicalURL.toString(),
		title:       brandingTitle || SITE_TITLE,
		description: pageDesc,
	}),

	// BlogPosting + BreadcrumbList: apenas para posts de blog.
	...(pubDate
		? [
				buildBlogPostingSchema({
					url:          canonicalURL.toString(),
					title,
					description:  pageDesc,
					imageUrl:     ogImageURL,
					datePublished: pubDate,
					dateModified:  updatedDate,
					authorName:    author,
					keywords:      keywords || undefined,
					publisherName: SITE_TITLE,
				}),
				buildBreadcrumbSchema({
					items: [
						{ name: 'Home', url: siteUrl + '/'    },
						{ name: 'Blog', url: siteUrl + '/blog' },
						{ name: title,  url: canonicalURL.toString() },
					],
				}),
			]
		: []),
];
---

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- 1. Metadados globais                                                    -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Ícones -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" sizes="any" />

<!-- Descoberta de feeds e sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>

<!-- Pré-carregamento de fontes (performance / CLS) -->
<Font cssVariable="--font-atkinson" preload />

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- 2. Tags primárias — <title> e meta description                         -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<title>{pageTitle}</title>
<meta name="title"       content={pageTitle} />
<meta name="description" content={pageDesc} />
{keywords && <meta name="keywords" content={keywords} />}
{author   && <meta name="author"   content={author} />}
<meta name="robots" content={robots} />

<!-- URL canônica — evita conteúdo duplicado -->
<link rel="canonical" href={canonicalURL} />

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- 3. Open Graph — Facebook, LinkedIn e WhatsApp                          -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<meta property="og:type"        content={ogType} />
<meta property="og:url"         content={Astro.url} />
<meta property="og:site_name"   content={SITE_TITLE} />
<meta property="og:locale"      content="pt_BR" />
<meta property="og:title"       content={pageTitle} />
<meta property="og:description" content={pageDesc} />
<meta property="og:image"       content={ogImageURL} />
<meta property="og:image:alt"   content={title} />
<meta property="og:image:width"  content="1200" />
<meta property="og:image:height" content="630" />

<!-- Open Graph: campos extras para artigos -->
{pubDate     && <meta property="article:published_time" content={pubDate.toISOString()} />}
{updatedDate && <meta property="article:modified_time"  content={updatedDate.toISOString()} />}
{author      && <meta property="article:author"         content={author} />}
{tags.map((tag) => (
	<meta property="article:tag" content={tag} />
))}

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- 4. Twitter Card — summary_large_image (pré-visualização grande)        -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:url"         content={Astro.url} />
<meta name="twitter:title"       content={pageTitle} />
<meta name="twitter:description" content={pageDesc} />
<meta name="twitter:image"       content={ogImageURL} />
<meta name="twitter:image:alt"   content={title} />

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- 5. Schema.org JSON-LD — dados estruturados para Google Rich Results    -->
<!--    WebSite + WebPage em todas as páginas.                              -->
<!--    BlogPosting + BreadcrumbList apenas em posts de blog.               -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<JsonLd nodes={schemaNodes} />
